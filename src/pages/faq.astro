---
import BaseLayout from '../layouts/BaseLayout.astro';
import { faqs } from '../data/faqs';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<BaseLayout title="Business Automation & n8n Workflows FAQ | Smesh.dev" description="Find clear answers about project scope, timelines, database structures, and pricing for custom n8n automation and AI chatbot systems.">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <section class="section-frame pt-6 md:pt-8">
    <div class="site-shell">
      <div class="max-w-3xl">
        <div class="section-kicker">FAQ</div>
        <h1 class="display-title mt-4 text-[color:var(--ink)]">Common questions before starting a project.</h1>
        <p class="body-copy mt-4">
          This FAQ page provides clear answers about the project scope, development timelines, packages, and technical configurations for n8n automation, Supabase, and custom AI chatbots designed by Smesh.Dev.
        </p>
      </div>

      <div class="card-grid-tight mt-8 lg:grid-cols-2">
        {faqs.map((faq, index) => (
          <article class="surface-card rounded-[18px] p-4" data-reveal style={`--reveal-delay: ${index * 50}ms;`}>
            <h2 class="text-[1rem] font-semibold leading-6 text-[color:var(--ink)]">{faq.question}</h2>
            <p class="mt-3 text-[13px] leading-7 text-[color:var(--muted)]">{faq.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
