<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Interactive AI Auditor Calculator logic
    const taskSelect = document.getElementById('auditor-task') as HTMLSelectElement;
    const hoursRange = document.getElementById('auditor-hours-range') as HTMLInputElement;
    const hoursVal = document.getElementById('auditor-hours-val');
    const outputHours = document.getElementById('output-hours');
    const outputSavings = document.getElementById('output-savings');

    const calculateSavings = () => {
      if (!taskSelect || !hoursRange) return;
      const rate = parseFloat(taskSelect.value);
      const hours = parseInt(hoursRange.value, 10);
      
      if (hoursVal) hoursVal.textContent = `${hours}h`;
      
      const annualHoursSaved = Math.round(hours * 52 * rate);
      const annualSavings = Math.round(annualHoursSaved * 30); // $30/hr average operational rate
      
      if (outputHours) outputHours.textContent = `${annualHoursSaved} hours`;
      if (outputSavings) outputSavings.textContent = `$${annualSavings.toLocaleString()}`;
    };

    if (taskSelect && hoursRange) {
      taskSelect.addEventListener('change', calculateSavings);
      hoursRange.addEventListener('input', calculateSavings);
      calculateSavings(); // Initial run
    }

    // Modal Trigger listeners
    const heroBtn = document.getElementById('hero-audit-btn');
    const auditorCta = document.getElementById('auditor-cta');
    const auditModal = document.getElementById('audit-modal');

    const openModal = () => {
      if (!auditModal) return;
      auditModal.classList.remove('hidden');
      auditModal.classList.add('flex');
      setTimeout(() => {
        auditModal.classList.remove('opacity-0');
        auditModal.querySelector('.bg-white')?.classList.remove('scale-95');
      }, 10);
    };

    if (heroBtn) {
      heroBtn.addEventListener('click', openModal);
    }
    if (auditorCta) {
      auditorCta.addEventListener('click', openModal);
    }
  });
</script>
