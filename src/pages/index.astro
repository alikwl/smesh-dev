---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import SmartImage from '../components/SmartImage.astro';
import { getCollection } from 'astro:content';

const services = (await getCollection('services')).filter(s => !s.id.includes('sample'));
const portfolio = (await getCollection('portfolio')).filter(p => !p.id.includes('sample'));
const demos = (await getCollection('demos')).filter(d => !d.id.includes('sample'));
const resources = (await getCollection('resources')).filter(r => !r.id.includes('sample'));
const posts = (await getCollection('posts')).filter(p => !p.id.includes('sample'));

// Slice the latest items
const latestPortfolio = portfolio.slice(0, 3);
const latestDemos = demos.slice(0, 3);
const latestResources = resources.slice(0, 3);
const latestPosts = posts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// FAQs matching user intent (AEO/GEO target)
const homepageFaqs = [
  {
    q: "How to automate dev workflow with n8n and Supabase?",
    a: "To automate your dev workflow, you can connect your database triggers in Supabase to n8n workflow nodes. Smesh.dev helps you integrate these systems, allowing you to automate lead captures, webhook parsing, and multi-channel notifications in minutes instead of manual vibe coding."
  },
  {
    q: "What tools does Smesh.dev provide?",
    a: "Smesh.dev provides production-ready n8n workflows, offline-first local POS sync guides, custom AI support agent prompts (with RAG), and pre-built Supabase schemas to scale your operations rapidly."
  },
  {
    q: "How does n8n automation scale business operations?",
    a: "n8n connects your sales triggers (like a POS transaction) directly to your delivery channels (WhatsApp, logistics APIs, SMS) and databases (Supabase). This eliminates manual copy-pasting, automates shipping notifications, and sends alerts to inventory managers the second stock falls below a critical threshold."
  },
  {
    q: "What is an offline-first POS structure?",
    a: "An offline-first POS structure ensures that your sales checkout system continues running locally (using local databases like SQLite or browser IndexedDB) even if internet access drops. Once connection is restored, the local transactions are automatically synced back to your centralized Supabase database without data loss."
  },
  {
    q: "Why do you use Supabase instead of traditional SQL servers?",
    a: "Supabase offers PostgreSQL speed and reliability coupled with built-in user authentication, real-time sync, and Row Level Security (RLS) policies. For AI features, its pgvector extension allows us to build semantic vector search engines directly within your relational database, keeping hosting costs close to zero."
  },
  {
    q: "What is Vibe Coding and how does it speed up MVP launches?",
    a: "Vibe Coding focuses on shipping functional layouts and backend logic at maximum speed by utilizing high-context AI agent code generation tools (like Gemini/Claude) coupled with pre-integrated boilerplates. This reduces standard MVP development cycles from months to weeks."
  }
];

const demoImageMap: Record<string, string> = {
  'whatsapp-order-system': '/assets/images/whatsapp-phone-mockup.png',
  'ai-support-chatbot': '/assets/images/ai-network-illustration.png',
  'booking-dashboard': '/assets/images/calendar-booking-mockup.png',
  'pos-inventory-dashboard': '/assets/images/saas-dashboard-illustration.png',
  'saas-mvp-dashboard': '/assets/images/saas-dashboard-illustration.png',
  'lead-capture-workflow': '/assets/images/automation-workflow-illustration.png',
};

const borderColors = [
  'border-t-teal-600',
  'border-t-indigo-600',
  'border-t-orange-500',
  'border-t-rose-500',
  'border-t-amber-500',
  'border-t-sky-500',
];
---

<BaseLayout title="Grounded AI Systems & Custom n8n Automation | Smesh.Dev" description="Smesh.Dev is an AI automation studio run by Haider Ali that designs custom n8n workflows, database integrations, local retail POS systems, and grounded RAG support chatbots to automate operations." schemaType="home">
  <!-- FAQ Structured Schema for AEO/GEO discovery -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": homepageFaqs.map(faq => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.a
      }
    }))
  })} />
  
  <header>
    <!-- Section 1: The Hero Engine -->
    <section class="site-shell py-16 md:py-28 text-center space-y-8 bg-gradient-to-b from-indigo-50/20 via-white to-transparent relative overflow-hidden">
      <!-- Background Glow Orbs -->
      <div class="absolute -top-12 left-1/4 w-72 h-72 bg-teal-500/5 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute top-1/4 -right-12 w-96 h-96 bg-indigo-500/5 rounded-full blur-3xl pointer-events-none"></div>

      <!-- Animated Floating Badges (Hidden on XS Mobile) -->
      <div class="hidden sm:inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-slate-200/50 bg-white/70 backdrop-blur-xs text-[10px] font-semibold text-teal-700 shadow-sm absolute top-12 left-6 lg:left-24 animate-float-1">
        <i data-lucide="zap" class="w-3.5 h-3.5 text-teal-600"></i>
        Astro SSG Speed
      </div>
      <div class="hidden sm:inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-slate-200/50 bg-white/70 backdrop-blur-xs text-[10px] font-semibold text-indigo-700 shadow-sm absolute bottom-24 left-10 lg:left-32 animate-float-2">
        <i data-lucide="git-merge" class="w-3.5 h-3.5 text-indigo-600"></i>
        n8n Workflow Hub
      </div>
      <div class="hidden sm:inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-slate-200/50 bg-white/70 backdrop-blur-xs text-[10px] font-semibold text-orange-700 shadow-sm absolute top-24 right-6 lg:right-28 animate-float-3">
        <i data-lucide="database" class="w-3.5 h-3.5 text-orange-600"></i>
        Supabase DB Engine
      </div>

      <div class="max-w-4xl mx-auto space-y-6 relative z-10 px-2">
        <span class="inline-flex items-center gap-1.5 px-3.5 py-1 rounded-full border border-teal-200 bg-[color:var(--accent-soft)] text-[color:var(--accent-strong)] text-xs font-bold uppercase tracking-wider font-sans">
          <i data-lucide="sparkles" class="h-3.5 w-3.5 text-[color:var(--accent)] animate-pulse"></i>
          Smesh.Dev Automation Studio // Powered by BismillahTC
        </span>
        <h1 class="display-title text-slate-900 text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight leading-[1.1] font-display">
          Automate your business workflows by 30%
        </h1>
        <p class="body-copy max-w-2xl mx-auto text-sm sm:text-base md:text-lg font-light text-slate-655 leading-relaxed">
          We design custom n8n workflows, database integrations, local retail POS systems, and grounded RAG support chatbots to automate your operations, reduce manual tasks, and launch your software products in weeks.
        </p>
      </div>

      <div class="flex flex-wrap items-center justify-center gap-4 pt-4 font-sans relative z-10">
        <button id="hero-audit-btn" class="button-primary px-8 py-3.5 rounded-xl text-sm font-bold shadow-md cursor-pointer hover:shadow-lg transition">
          Request Free Audit
          <i data-lucide="sparkles" class="h-4 w-4 ml-1.5"></i>
        </button>
        <a href="/resources/" class="button-secondary px-8 py-3.5 rounded-xl text-sm font-bold shadow-sm hover:shadow transition">
          Free Resources
          <i data-lucide="folder-open" class="h-4 w-4 ml-1.5"></i>
        </a>
      </div>
    </section>
  </header>

  <main>
    <!-- Section 2: Trust Strip (Proof of Authority) -->
    <section class="site-shell py-8 border-t border-slate-200/60 bg-white/40 rounded-[24px] border border-slate-200/85 mb-16">
      <div class="grid gap-6 md:grid-cols-3 items-center">
        <!-- Metric Column -->
        <div class="flex items-center gap-4 px-6 md:border-r border-slate-200/80 last:border-none">
          <div class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-teal-50 text-[color:var(--accent)] shrink-0">
            <i data-lucide="trending-down" class="h-5 w-5"></i>
          </div>
          <div>
            <div class="flex items-baseline gap-1">
              <span class="text-3xl font-extrabold text-[color:var(--accent)] font-display shrink-0">70%</span>
              <span class="text-xs font-bold text-[color:var(--ink)] font-sans uppercase tracking-wider">Reduction</span>
            </div>
            <p class="text-xs text-[color:var(--muted)] font-light mt-0.5">Average reduction in manual ops admin time.</p>
          </div>
        </div>
        <!-- Fleet Logistics Case Study Column -->
        <div class="flex items-center gap-4 px-6 md:border-r border-slate-200/80 last:border-none">
          <div class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-[color:var(--accent-soft)] text-[color:var(--accent)] shrink-0">
            <i data-lucide="zap" class="h-5 w-5"></i>
          </div>
          <div>
            <h4 class="text-xs font-bold text-[color:var(--ink)] font-sans uppercase tracking-wider">Fleet Logistics Case</h4>
            <p class="text-xs text-[color:var(--muted)] font-light mt-0.5">Scheduling time reduced from 4 hours/day to 30 minutes.</p>
          </div>
        </div>
        <!-- Philosophy Quote Column -->
        <div class="flex items-center gap-4 px-6">
          <div class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-orange-50 text-orange-600 shrink-0">
            <i data-lucide="quote" class="h-5 w-5"></i>
          </div>
          <p class="text-xs italic text-[color:var(--muted)] font-medium leading-relaxed">
            "AI must not only be implemented, it must be measurable."
          </p>
        </div>
      </div>
    </section>

    <!-- Section 3: Interactive AI Auditor Calculator Widget -->
    <section class="site-shell py-16 md:py-20 border-t border-slate-200/60 bg-slate-50/20 rounded-[32px] border border-slate-100 mb-16" aria-label="Interactive AI Auditor">
      <div class="max-w-4xl mx-auto px-4 md:px-0">
        <div class="text-center space-y-4 mb-10">
          <span class="section-kicker">
            <i data-lucide="calculator" class="w-3 h-3 text-[color:var(--accent-strong)]"></i>
            ROI Calculator
          </span>
          <h2 class="text-3xl font-extrabold text-[color:var(--ink)] leading-tight">Check Your Workflow Efficiency</h2>
          <p class="text-xs md:text-sm text-[color:var(--muted)] font-light max-w-lg mx-auto">
            Calculate how much time and money you can save by automating manual tasks with n8n and Supabase.
          </p>
        </div>

        <div class="grid gap-8 grid-cols-1 md:grid-cols-[1.1fr_0.9fr] bg-white rounded-[24px] p-5 sm:p-8 border border-slate-200 shadow-sm">
          <!-- Inputs -->
          <div class="space-y-6">
            <div class="space-y-2.5">
              <label for="auditor-task" class="block text-xs font-bold text-[color:var(--ink)] uppercase tracking-wider font-sans">
                What task wastes the most time?
              </label>
              <select id="auditor-task" class="w-full rounded-xl border border-slate-250 bg-slate-50/60 px-4 py-3 text-xs text-[color:var(--ink)] focus:bg-white focus:outline-none font-sans">
                <option value="0.80" data-task-name="Copying POS sales to Excel">Copying sales POS data to spreadsheets (80% automatable)</option>
                <option value="0.75" data-task-name="Replying to customer support tickets">Answering routine customer support tickets (75% automatable)</option>
                <option value="0.90" data-task-name="Manual fleet scheduling & dispatch">Fleet scheduling and logistics dispatch coordination (90% automatable)</option>
                <option value="0.85" data-task-name="Manual email lead follow-ups">Manual email lead sorting and CRM follow-up (85% automatable)</option>
                <option value="0.70" data-task-name="Other manual copy-paste workflow">General manual copy-paste data entry operations (70% automatable)</option>
              </select>
            </div>

            <div class="space-y-3">
              <div class="flex justify-between items-center">
                <label for="auditor-hours-range" class="block text-xs font-bold text-[color:var(--ink)] uppercase tracking-wider font-sans">
                  Weekly hours spent by your team:
                </label>
                <span id="auditor-hours-val" class="font-display font-bold text-xs bg-[color:var(--accent-soft)] text-[color:var(--accent-strong)] px-2.5 py-1 rounded-lg font-mono">10h</span>
              </div>
              <input type="range" id="auditor-hours-range" min="2" max="60" value="10" class="w-full accent-[color:var(--accent)] cursor-pointer" />
              <div class="flex justify-between text-[10px] text-slate-400 font-sans">
                <span>2 hours</span>
                <span>60 hours</span>
              </div>
            </div>
          </div>

          <!-- Outputs -->
          <div class="p-5 sm:p-6 bg-slate-50 rounded-2xl border border-slate-200 flex flex-col justify-between space-y-6">
            <div class="space-y-4">
              <h4 class="text-xs font-bold text-[color:var(--ink)] uppercase tracking-wider font-sans border-b border-slate-200 pb-2">
                Estimated Impact Report:
              </h4>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <span class="text-[9px] uppercase tracking-wider text-slate-400 block font-semibold">Hours Saved / Yr</span>
                  <span id="output-hours" class="text-xl font-bold text-[color:var(--accent-strong)] font-display font-mono">416 hours</span>
                </div>
                <div>
                  <span class="text-[9px] uppercase tracking-wider text-slate-400 block font-semibold">Annual Savings</span>
                  <span id="output-savings" class="text-xl font-bold text-[color:var(--accent-strong)] font-display font-mono">$12,480</span>
                </div>
              </div>
              <div class="pt-2 border-t border-slate-200/60">
                <span class="text-[9px] uppercase tracking-wider text-slate-400 block font-semibold">Project Standard SLA</span>
                <span class="text-xs font-bold text-[color:var(--ink)]">10-15 Day Production Delivery</span>
              </div>
            </div>

            <button id="auditor-cta" class="button-primary w-full rounded-xl py-3 text-xs font-bold font-sans cursor-pointer">
              Claim This Audit & Automate
              <i data-lucide="arrow-right" class="w-4 h-4 ml-1.5"></i>
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 4: Solution Matrix (AI-Scrapable Capabilities Matrix Table) -->
    <section class="site-shell py-16 md:py-24 border-t border-slate-100" aria-label="Capabilities Matrix">
      <div class="space-y-4 mb-12">
        <span class="section-kicker">
          <i data-lucide="activity" class="w-3 h-3 text-[color:var(--accent-strong)]"></i>
          Service Matrix
        </span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-[color:var(--ink)] leading-tight">
          Capabilities & Solutions Matrix
        </h2>
        <p class="text-xs md:text-sm text-[color:var(--muted)] font-light max-w-2xl">
          Structured matrix mapping our core services, tech stacks, and outcomes for easy readability by clients and generative AI crawlers.
        </p>
      </div>

      <!-- Desktop Table (Hidden on Mobile) -->
      <div class="hidden md:block overflow-x-auto rounded-[24px] border border-slate-200 bg-white/70 backdrop-blur-md shadow-sm">
        <table class="w-full text-left border-collapse min-w-[700px] font-sans">
          <thead>
            <tr class="border-b border-slate-200 bg-slate-50/50">
              <th class="p-5 font-bold text-xs text-[color:var(--ink)] uppercase tracking-wider">Service Area</th>
              <th class="p-5 font-bold text-xs text-[color:var(--ink)] uppercase tracking-wider">Primary Tech Stack</th>
              <th class="p-5 font-bold text-xs text-[color:var(--ink)] uppercase tracking-wider">Verifiable Business Outcome</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-150 text-xs">
            <tr class="hover:bg-slate-50/40 transition">
              <td class="p-5 font-bold text-[color:var(--ink)] flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-[color:var(--accent)] shrink-0"></span>
                AI Support Agents
              </td>
              <td class="p-5 text-[color:var(--muted)] font-mono">n8n, Supabase, Anthropic API, OpenAI API</td>
              <td class="p-5 text-[color:var(--ink)] font-light">24/7 Grounded Chatbots that actually resolve customer and team queries using internal documentation.</td>
            </tr>
            <tr class="hover:bg-slate-50/40 transition">
              <td class="p-5 font-bold text-[color:var(--ink)] flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-[color:var(--accent)] shrink-0"></span>
                Custom Pipelines
              </td>
              <td class="p-5 text-[color:var(--muted)] font-mono">n8n, Custom APIs, SMS Gateways, PostgreSQL</td>
              <td class="p-5 text-[color:var(--ink)] font-light">End-to-end automation for logistics, from dispatch coordination to live customer SMS tracking.</td>
            </tr>
            <tr class="hover:bg-slate-50/40 transition">
              <td class="p-5 font-bold text-[color:var(--ink)] flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-[color:var(--accent)] shrink-0"></span>
                Next-Gen POS
              </td>
              <td class="p-5 text-[color:var(--muted)] font-mono">Astro, SQLite, IndexedDB, Supabase</td>
              <td class="p-5 text-[color:var(--ink)] font-light">Offline-first, high-efficiency dashboards engineered for real-time local commerce checkouts.</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Mobile Card Layout (Shown on Mobile) -->
      <div class="grid gap-4 md:hidden">
        <article class="p-5 bg-white rounded-2xl border border-slate-200 shadow-sm space-y-3">
          <div class="flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-[color:var(--accent)] shrink-0"></span>
            <h3 class="font-bold text-sm text-[color:var(--ink)]">AI Support Agents</h3>
          </div>
          <div>
            <span class="text-[9px] uppercase tracking-wider text-slate-400 block font-semibold">Primary Tech Stack</span>
            <p class="text-xs font-mono text-[color:var(--muted)] bg-slate-50 p-2 rounded-lg mt-1">n8n, Supabase, Anthropic API, OpenAI API</p>
          </div>
          <div>
            <span class="text-[9px] uppercase tracking-wider text-slate-400 block font-semibold">Verifiable Business Outcome</span>
            <p class="text-xs font-light text-[color:var(--ink)] mt-1">24/7 Grounded Chatbots that actually resolve customer and team queries using internal documentation.</p>
          </div>
        </article>
        <article class="p-5 bg-white rounded-2xl border border-slate-200 shadow-sm space-y-3">
          <div class="flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-[color:var(--accent)] shrink-0"></span>
            <h3 class="font-bold text-sm text-[color:var(--ink)]">Custom Pipelines</h3>
          </div>
          <div>
            <span class="text-[9px] uppercase tracking-wider text-slate-400 block font-semibold">Primary Tech Stack</span>
            <p class="text-xs font-mono text-[color:var(--muted)] bg-slate-50 p-2 rounded-lg mt-1">n8n, Custom APIs, SMS Gateways, PostgreSQL</p>
          </div>
          <div>
            <span class="text-[9px] uppercase tracking-wider text-slate-400 block font-semibold">Verifiable Business Outcome</span>
            <p class="text-xs font-light text-[color:var(--ink)] mt-1">End-to-end automation for logistics, from dispatch coordination to live customer SMS tracking.</p>
          </div>
        </article>
        <article class="p-5 bg-white rounded-2xl border border-slate-200 shadow-sm space-y-3">
          <div class="flex items-center gap-2">
            <span class="w-2.5 h-2.5 rounded-full bg-[color:var(--accent)] shrink-0"></span>
            <h3 class="font-bold text-sm text-[color:var(--ink)]">Next-Gen POS</h3>
          </div>
          <div>
            <span class="text-[9px] uppercase tracking-wider text-slate-400 block font-semibold">Primary Tech Stack</span>
            <p class="text-xs font-mono text-[color:var(--muted)] bg-slate-50 p-2 rounded-lg mt-1">Astro, SQLite, IndexedDB, Supabase</p>
          </div>
          <div>
            <span class="text-[9px] uppercase tracking-wider text-slate-400 block font-semibold">Verifiable Business Outcome</span>
            <p class="text-xs font-light text-[color:var(--ink)] mt-1">Offline-first, high-efficiency dashboards engineered for real-time local commerce checkouts.</p>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 5: The Engineering Engine -->
    <section class="site-shell py-16 md:py-24 border-t border-slate-100" aria-label="Our Stack Standards">
      <div class="space-y-4 mb-12 text-center">
        <span class="section-kicker">
          <i data-lucide="cpu" class="w-3 h-3 text-[color:var(--accent-strong)]"></i>
          Standards
        </span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-[color:var(--ink)] leading-tight">
          The Engineering Engine
        </h2>
        <p class="text-xs md:text-sm text-[color:var(--muted)] font-light max-w-xl mx-auto">
          We maintain lean development cycles and implement reliable open standards.
        </p>
      </div>

      <div class="grid gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-4">
        <!-- Astro + Tailwind -->
        <article class="surface-card rounded-[24px] p-6 bg-white flex flex-col justify-between border border-slate-200 hover:-translate-y-1 hover:shadow-md hover:border-slate-300 transition-all duration-300">
          <div class="space-y-4">
            <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-indigo-50 text-indigo-700">
              <!-- Custom Astro Logo SVG -->
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2L2 22h4l6-12 6 12h4L12 2z" />
                <path d="M12 10l-4 8h8l-4-8z" />
              </svg>
            </div>
            <h3 class="text-base font-bold text-[color:var(--ink)] leading-snug">Astro + Tailwind</h3>
            <p class="text-xs text-[color:var(--muted)] font-light leading-relaxed">
              Sub-second static load times, clean semantics, and crawlable layouts optimized for search engine indexing.
            </p>
          </div>
        </article>

        <!-- n8n Ecosystem -->
        <article class="surface-card rounded-[24px] p-6 bg-white flex flex-col justify-between border border-slate-200 hover:-translate-y-1 hover:shadow-md hover:border-slate-300 transition-all duration-300">
          <div class="space-y-4">
            <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-orange-50 text-orange-700">
              <!-- Custom n8n Nodes Logo SVG -->
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="6" cy="12" r="3" />
                <circle cx="18" cy="6" r="3" />
                <circle cx="18" cy="18" r="3" />
                <line x1="9" y1="12" x2="15" y2="7" />
                <line x1="9" y1="12" x2="15" y2="17" />
              </svg>
            </div>
            <h3 class="text-base font-bold text-[color:var(--ink)] leading-snug">n8n Ecosystem</h3>
            <p class="text-xs text-[color:var(--muted)] font-light leading-relaxed">
              Complex, non-linear logic gates linking customer channels, internal systems, and APIs without lock-in.
            </p>
          </div>
        </article>

        <!-- Supabase -->
        <article class="surface-card rounded-[24px] p-6 bg-white flex flex-col justify-between border border-slate-200 hover:-translate-y-1 hover:shadow-md hover:border-slate-300 transition-all duration-300">
          <div class="space-y-4">
            <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-50 text-emerald-700">
