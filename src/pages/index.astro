---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import SmartImage from '../components/SmartImage.astro';
import { getCollection } from 'astro:content';

const services = await getCollection('services');
const portfolio = await getCollection('portfolio');
const demos = await getCollection('demos');
const resources = await getCollection('resources');
const posts = await getCollection('posts');

// Slice the latest items
const latestPortfolio = portfolio.slice(0, 3);
const latestDemos = demos.slice(0, 3);
const latestResources = resources.slice(0, 3);
const latestPosts = posts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// FAQs matching user intent (AEO/GEO target)
const homepageFaqs = [
  {
    q: "How to automate dev workflow with n8n and Supabase?",
    a: "To automate your dev workflow, you can connect your database triggers in Supabase to n8n workflow nodes. Smesh.dev helps you integrate these systems, allowing you to automate lead captures, webhook parsing, and multi-channel notifications in minutes instead of manual vibe coding."
  },
  {
    q: "What tools does Smesh.dev provide?",
    a: "Smesh.dev provides production-ready n8n workflows, offline-first local POS sync guides, custom AI support agent prompts (with RAG), and pre-built Supabase schemas to scale your operations rapidly."
  },
  {
    q: "How does n8n automation scale business operations?",
    a: "n8n connects your sales triggers (like a POS transaction) directly to your delivery channels (WhatsApp, logistics APIs, SMS) and databases (Supabase). This eliminates manual copy-pasting, automates shipping notifications, and sends alerts to inventory managers the second stock falls below a critical threshold."
  },
  {
    q: "What is an offline-first POS structure?",
    a: "An offline-first POS structure ensures that your sales checkout system continues running locally (using local databases like SQLite or browser IndexedDB) even if internet access drops. Once connection is restored, the local transactions are automatically synced back to your centralized Supabase database without data loss."
  },
  {
    q: "Why do you use Supabase instead of traditional SQL servers?",
    a: "Supabase offers PostgreSQL speed and reliability coupled with built-in user authentication, real-time sync, and Row Level Security (RLS) policies. For AI features, its pgvector extension allows us to build semantic vector search engines directly within your relational database, keeping hosting costs close to zero."
  },
  {
    q: "What is Vibe Coding and how does it speed up MVP launches?",
    a: "Vibe Coding focuses on shipping functional layouts and backend logic at maximum speed by utilizing high-context AI agent code generation tools (like Gemini/Claude) coupled with pre-integrated boilerplates. This reduces standard MVP development cycles from months to weeks."
  }
];

const demoImageMap: Record<string, string> = {
  'whatsapp-order-system': '/assets/images/whatsapp-phone-mockup.png',
  'ai-support-chatbot': '/assets/images/ai-network-illustration.png',
  'booking-dashboard': '/assets/images/calendar-booking-mockup.png',
  'pos-inventory-dashboard': '/assets/images/saas-dashboard-illustration.png',
  'saas-mvp-dashboard': '/assets/images/saas-dashboard-illustration.png',
  'lead-capture-workflow': '/assets/images/automation-workflow-illustration.png',
};
---

<BaseLayout title="Grounded AI Systems & Custom n8n Automation | Smesh.Dev" description="Smesh.Dev designs custom n8n workflows, local retail POS features, and AI support chatbots to automate your business operations. Run by Haider Ali." schemaType="home">
  <!-- FAQ Structured Schema for AEO/GEO discovery -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": homepageFaqs.map(faq => ({
      "@type": "Question",
      "name": faq.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.a
      }
    }))
  })} />
  
  <header>
    <!-- Section 1: The Hero Engine -->
    <section class="site-shell py-20 md:py-28 text-center space-y-8 bg-gradient-to-b from-indigo-50/20 via-white to-transparent">
      <div class="max-w-4xl mx-auto space-y-6">
        <span class="px-3.5 py-1 rounded-full bg-[color:var(--accent-soft)] text-[color:var(--accent-strong)] text-xs font-bold uppercase tracking-wider font-sans">
          Smesh.Dev Automation Studio // Powered by BismillahTC
        </span>
        <h1 class="display-title text-slate-900 text-4xl md:text-6xl font-extrabold tracking-tight leading-[1.08]">
          Automate your dev workflow by 30% with Smesh.dev
        </h1>
        <p class="body-copy max-w-2xl mx-auto text-base md:text-lg font-light text-slate-600 leading-relaxed">
          Verified extensions and custom automations for developers using n8n and Supabase. Scale your operations without adding to your payroll.
        </p>
      </div>

      <div class="flex flex-wrap items-center justify-center gap-4 pt-4 font-sans">
        <button id="hero-audit-btn" class="button-primary px-8 py-3.5 rounded-xl text-sm font-bold shadow-md cursor-pointer">
          Request Free Audit
          <i data-lucide="sparkles" class="h-4 w-4 ml-1.5"></i>
        </button>
        <a href="/resources/" class="button-secondary px-8 py-3.5 rounded-xl text-sm font-bold">
          Free Resources
          <i data-lucide="folder-open" class="h-4 w-4 ml-1.5"></i>
        </a>
      </div>
    </section>
  </header>

  <main>
    <!-- Section 2: Trust Strip (Proof of Authority) -->
    <section class="site-shell py-8 border-t border-slate-200/60 bg-white/40 rounded-[24px] border border-slate-200/85 mb-16">
      <div class="grid gap-6 md:grid-cols-3 items-center">
        <!-- Metric Column -->
        <div class="flex items-center gap-4 px-6 md:border-r border-slate-200/80 last:border-none">
          <span class="text-4xl font-extrabold text-[color:var(--accent)] font-display shrink-0">70%</span>
          <div>
            <h4 class="text-xs font-bold text-[color:var(--ink)] font-sans uppercase tracking-wider">Average Reduction</h4>
            <p class="text-xs text-[color:var(--muted)] font-light mt-0.5">In operational admin time across implemented systems.</p>
          </div>
        </div>
        <!-- Fleet Logistics Case Study Column -->
        <div class="flex items-center gap-4 px-6 md:border-r border-slate-200/80 last:border-none">
          <div class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-[color:var(--accent-soft)] text-[color:var(--accent)] shrink-0">
            <i data-lucide="zap" class="h-5 w-5"></i>
          </div>
          <div>
            <h4 class="text-xs font-bold text-[color:var(--ink)] font-sans uppercase tracking-wider">Fleet Logistics Case</h4>
            <p class="text-xs text-[color:var(--muted)] font-light mt-0.5">Scheduling time reduced from 4 hours/day to 30 minutes.</p>
          </div>
        </div>
        <!-- Philosophy Quote Column -->
        <div class="flex items-center gap-4 px-6">
          <div class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-orange-50 text-orange-600 shrink-0">
            <i data-lucide="quote" class="h-5 w-5"></i>
          </div>
          <p class="text-xs italic text-[color:var(--muted)] font-medium leading-relaxed">
            "AI must not only be implemented, it must be measurable."
          </p>
        </div>
      </div>
    </section>

    <!-- Section 3: Interactive AI Auditor Calculator Widget -->
    <section class="site-shell py-16 md:py-20 border-t border-slate-200/60 bg-slate-50/20 rounded-[32px] border border-slate-100 mb-16" aria-label="Interactive AI Auditor">
      <div class="max-w-4xl mx-auto px-4 md:px-0">
        <div class="text-center space-y-4 mb-10">
          <span class="section-kicker">ROI Calculator</span>
          <h2 class="text-3xl font-extrabold text-[color:var(--ink)] leading-tight">Check Your Workflow Efficiency</h2>
          <p class="text-xs md:text-sm text-[color:var(--muted)] font-light max-w-lg mx-auto">
            Calculate how much time and money you can save by automating manual tasks with n8n and Supabase.
          </p>
        </div>

        <div class="grid gap-8 md:grid-cols-[1.1fr_0.9fr] bg-white rounded-[24px] p-6 sm:p-8 border border-slate-200 shadow-sm">
          <!-- Inputs -->
          <div class="space-y-6">
            <div class="space-y-2.5">
              <label for="auditor-task" class="block text-xs font-bold text-[color:var(--ink)] uppercase tracking-wider font-sans">
                What task wastes the most time?
              </label>
              <select id="auditor-task" class="w-full rounded-xl border border-slate-250 bg-slate-50/60 px-4 py-3 text-xs text-[color:var(--ink)] focus:bg-white focus:outline-none font-sans">
                <option value="0.80" data-task-name="Copying POS sales to Excel">Copying sales POS data to spreadsheets (80% automatable)</option>
                <option value="0.75" data-task-name="Replying to customer support tickets">Answering routine customer support tickets (75% automatable)</option>
                <option value="0.90" data-task-name="Manual fleet scheduling & dispatch">Fleet scheduling and logistics dispatch coordination (90% automatable)</option>
                <option value="0.85" data-task-name="Manual email lead follow-ups">Manual email lead sorting and CRM follow-up (85% automatable)</option>
                <option value="0.70" data-task-name="Other manual copy-paste workflow">General manual copy-paste data entry operations (70% automatable)</option>
              </select>
            </div>

            <div class="space-y-3">
              <div class="flex justify-between items-center">
                <label for="auditor-hours-range" class="block text-xs font-bold text-[color:var(--ink)] uppercase tracking-wider font-sans">
                  Weekly hours spent by your team:
                </label>
                <span id="auditor-hours-val" class="font-display font-bold text-xs bg-[color:var(--accent-soft)] text-[color:var(--accent-strong)] px-2.5 py-1 rounded-lg">10h</span>
              </div>
              <input type="range" id="auditor-hours-range" min="2" max="60" value="10" class="w-full accent-[color:var(--accent)] cursor-pointer" />
              <div class="flex justify-between text-[10px] text-slate-400 font-sans">
                <span>2 hours</span>
                <span>60 hours</span>
              </div>
            </div>
          </div>

          <!-- Outputs -->
          <div class="p-6 bg-slate-50 rounded-2xl border border-slate-200 flex flex-col justify-between space-y-6">
            <div class="space-y-4">
              <h4 class="text-xs font-bold text-[color:var(--ink)] uppercase tracking-wider font-sans border-b border-slate-200 pb-2">
                Estimated Impact Report:
              </h4>
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <span class="text-[9px] uppercase tracking-wider text-slate-400 block font-semibold">Hours Saved / Yr</span>
                  <span id="output-hours" class="text-xl font-bold text-[color:var(--accent-strong)] font-display">416 hours</span>
                </div>
                <div>
                  <span class="text-[9px] uppercase tracking-wider text-slate-400 block font-semibold">Annual Savings</span>
                  <span id="output-savings" class="text-xl font-bold text-[color:var(--accent-strong)] font-display">$12,480</span>
                </div>
              </div>
              <div class="pt-2 border-t border-slate-200/60">
                <span class="text-[9px] uppercase tracking-wider text-slate-400 block font-semibold">Project Standard SLA</span>
                <span class="text-xs font-bold text-[color:var(--ink)]">10-15 Day Production Delivery</span>
              </div>
            </div>

            <button id="auditor-cta" class="button-primary w-full rounded-xl py-3 text-xs font-bold font-sans">
              Claim This Audit & Automate
              <i data-lucide="arrow-right" class="w-4 h-4 ml-1.5"></i>
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 4: Solution Matrix (AI-Scrapable Capabilities Matrix Table) -->
    <section class="site-shell py-16 md:py-24 border-t border-slate-100" aria-label="Capabilities Matrix">
      <div class="space-y-4 mb-12">
        <span class="section-kicker">Service Matrix</span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-[color:var(--ink)] leading-tight">
          Capabilities & Solutions Matrix
        </h2>
        <p class="text-xs md:text-sm text-[color:var(--muted)] font-light max-w-2xl">
          Structured matrix mapping our core services, tech stacks, and outcomes for easy readability by clients and generative AI crawlers.
        </p>
      </div>

      <div class="overflow-x-auto rounded-[24px] border border-slate-200 bg-white/70 backdrop-blur-md shadow-sm">
        <table class="w-full text-left border-collapse min-w-[700px] font-sans">
          <thead>
            <tr class="border-b border-slate-200 bg-slate-50/50">
              <th class="p-5 font-bold text-xs text-[color:var(--ink)] uppercase tracking-wider">Service Area</th>
              <th class="p-5 font-bold text-xs text-[color:var(--ink)] uppercase tracking-wider">Primary Tech Stack</th>
              <th class="p-5 font-bold text-xs text-[color:var(--ink)] uppercase tracking-wider">Verifiable Business Outcome</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-150 text-xs">
            <tr class="hover:bg-slate-50/40 transition">
              <td class="p-5 font-bold text-[color:var(--ink)] flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-[color:var(--accent)] shrink-0"></span>
                AI Support Agents
              </td>
              <td class="p-5 text-[color:var(--muted)] font-mono">n8n, Supabase, Anthropic API, OpenAI API</td>
              <td class="p-5 text-[color:var(--ink)] font-light">24/7 Grounded Chatbots that actually resolve customer and team queries using internal documentation.</td>
            </tr>
            <tr class="hover:bg-slate-50/40 transition">
              <td class="p-5 font-bold text-[color:var(--ink)] flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-[color:var(--accent)] shrink-0"></span>
                Custom Pipelines
              </td>
              <td class="p-5 text-[color:var(--muted)] font-mono">n8n, Custom APIs, SMS Gateways, PostgreSQL</td>
              <td class="p-5 text-[color:var(--ink)] font-light">End-to-end automation for logistics, from dispatch coordination to live customer SMS tracking.</td>
            </tr>
            <tr class="hover:bg-slate-50/40 transition">
              <td class="p-5 font-bold text-[color:var(--ink)] flex items-center gap-2">
                <span class="w-2 h-2 rounded-full bg-[color:var(--accent)] shrink-0"></span>
                Next-Gen POS
              </td>
              <td class="p-5 text-[color:var(--muted)] font-mono">Astro, SQLite, IndexedDB, Supabase</td>
              <td class="p-5 text-[color:var(--ink)] font-light">Offline-first, high-efficiency dashboards engineered for real-time local commerce checkouts.</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Section 5: The Engineering Engine -->
    <section class="site-shell py-16 md:py-24 border-t border-slate-100" aria-label="Our Stack Standards">
      <div class="space-y-4 mb-12 text-center">
        <span class="section-kicker">Standards</span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-[color:var(--ink)] leading-tight">
          The Engineering Engine
        </h2>
        <p class="text-xs md:text-sm text-[color:var(--muted)] font-light max-w-xl mx-auto">
          We maintain lean development cycles and implement reliable open standards.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        <!-- Astro + Tailwind -->
        <article class="surface-card rounded-[24px] p-6 bg-white flex flex-col justify-between border border-slate-200 hover:shadow-md transition">
          <div class="space-y-4">
            <div class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-indigo-50 text-indigo-700">
              <i data-lucide="chrome" class="h-5 w-5"></i>
            </div>
            <h3 class="text-base font-bold text-[color:var(--ink)] leading-snug">Astro + Tailwind</h3>
            <p class="text-xs text-[color:var(--muted)] font-light leading-relaxed">
              Sub-second static load times, clean semantics, and crawlable layouts optimized for search engine indexing.
            </p>
          </div>
        </article>

        <!-- n8n Ecosystem -->
        <article class="surface-card rounded-[24px] p-6 bg-white flex flex-col justify-between border border-slate-200 hover:shadow-md transition">
          <div class="space-y-4">
            <div class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-orange-50 text-orange-700">
              <i data-lucide="git-merge" class="h-5 w-5"></i>
            </div>
            <h3 class="text-base font-bold text-[color:var(--ink)] leading-snug">n8n Ecosystem</h3>
            <p class="text-xs text-[color:var(--muted)] font-light leading-relaxed">
              Complex, non-linear logic gates linking customer channels, internal systems, and APIs without lock-in.
            </p>
          </div>
        </article>

        <!-- Supabase -->
        <article class="surface-card rounded-[24px] p-6 bg-white flex flex-col justify-between border border-slate-200 hover:shadow-md transition">
          <div class="space-y-4">
            <div class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-50 text-emerald-700">
              <i data-lucide="database" class="h-5 w-5"></i>
            </div>
            <h3 class="text-base font-bold text-[color:var(--ink)] leading-snug">Supabase Persistence</h3>
            <p class="text-xs text-[color:var(--muted)] font-light leading-relaxed">
              PostgreSQL relational database power, secure row-level auth, and vector search embeddings for RAG tools.
            </p>
          </div>
        </article>

        <!-- Vibe Coding -->
        <article class="surface-card rounded-[24px] p-6 bg-white flex flex-col justify-between border border-slate-200 hover:shadow-md transition">
          <div class="space-y-4">
            <div class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-teal-50 text-teal-700">
              <i data-lucide="sparkles" class="h-5 w-5"></i>
            </div>
            <h3 class="text-base font-bold text-[color:var(--ink)] leading-snug">Vibe Coding Cycle</h3>
            <p class="text-xs text-[color:var(--muted)] font-light leading-relaxed">
              Iterative, high-velocity software production utilizing advanced agent tools to launch client MVPs in days.
            </p>
          </div>
        </article>
      </div>
    </section>

    <!-- Section 6: Dynamic Capabilities / Services Collections -->
    <section class="site-shell py-16 md:py-24 border-t border-slate-100" aria-label="Capabilities Grid">
      <div class="space-y-4 mb-12">
        <span class="section-kicker">Scope Areas</span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 leading-tight">Automation systems that scale your operations.</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {services.slice(0, 6).map((service) => {
          const title = service.data.title;
          const desc = service.data.description || service.data.headline || '';
          const price = service.data.price || service.data.starting_price || 'Custom Scope';
          const icon = service.data.icon || service.data.hero_icon || 'cpu';
          const tag = service.data.tag || '';
          const slug = service.id.replace(/\.md$/, '');
          return (
            <article class="surface-card rounded-[30px] p-6 border border-slate-200/80 bg-white/50 flex flex-col justify-between hover:shadow-lg transition-all duration-300">
              <div class="space-y-4">
                <div class="flex items-center justify-between">
                  <div class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-[color:var(--accent-soft)] text-[color:var(--accent-strong)]">
                    <i data-lucide={icon} class="h-5 w-5"></i>
                  </div>
                  {tag && <span class="chip capitalize font-sans">{tag}</span>}
                </div>

                <div>
                  <h3 class="text-xl font-bold text-slate-955 leading-snug">{title}</h3>
                  <p class="mt-2.5 text-xs leading-relaxed text-slate-500 line-clamp-3 font-light">{desc}</p>
                </div>
              </div>

              <div class="mt-6 pt-6 border-t border-slate-100 flex items-center justify-between font-sans">
                <div>
                  <span class="text-[9px] uppercase tracking-wider text-slate-400 block font-semibold">Starting at</span>
                  <span class="text-sm font-bold text-slate-800">{price}</span>
                </div>
                <a href={`/services/${slug}/`} class="inline-flex h-8 px-3.5 items-center justify-center rounded-lg bg-slate-900 hover:bg-slate-800 text-white text-xs font-semibold transition">
                  Scope
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </section>

    <!-- Section 7: Case Studies & Live Demos -->
    <section class="site-shell py-16 md:py-24 border-t border-slate-100 bg-slate-50/40" aria-label="Portfolio and Demos">
      <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr] mb-12 lg:items-end">
        <div>
          <span class="section-kicker">Case Studies</span>
          <h2 class="text-3xl md:text-4xl font-bold text-slate-950 leading-tight mt-3">Concrete business setups built and verified.</h2>
        </div>
        <p class="text-xs md:text-sm text-slate-500 font-light leading-relaxed">
          Instead of slide decks, we launch live demo widgets so clients can test the exact flow states (WhatsApp catalogs, support AI bots, scheduling loops) before booking a project.
        </p>
      </div>

      <!-- Portfolio Grid -->
      <div class="grid gap-6 md:grid-cols-2 mb-12">
        {latestPortfolio.map((project) => {
          const slug = project.id.replace(/\.md$/, '');
          const image = project.data.image || '/assets/images/placeholder.png';
          return (
            <article class="surface-card rounded-[32px] overflow-hidden border border-slate-200 bg-white shadow-sm flex flex-col justify-between hover:shadow-md transition">
              <div>
                <div class="relative overflow-hidden aspect-[16/10]">
                  <SmartImage src={image} alt={project.data.title} class="w-full h-full object-cover" />
                </div>
                <div class="p-6 space-y-3">
                  <span class="chip text-[10px] font-sans font-bold capitalize bg-indigo-50 border border-indigo-100/50 text-indigo-700">
                    {project.data.client || 'Client Study'}
                  </span>
                  <h3 class="text-xl font-bold text-slate-900 leading-snug">{project.data.title}</h3>
                  <p class="text-xs text-slate-500 leading-relaxed line-clamp-3 font-light">{project.data.description}</p>
                </div>
              </div>
              <div class="p-6 pt-0 font-sans">
                <a href={`/portfolio/${slug}/`} class="inline-flex items-center text-xs font-semibold text-slate-800 hover:text-indigo-650 transition">
                  Read Case Study
                  <i data-lucide="arrow-right" class="w-4 h-4 ml-1"></i>
                </a>
              </div>
            </article>
          );
        })}
      </div>

      <!-- Demos Rows -->
      <div class="space-y-4">
        <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400 font-sans">⚡ Test Live Mock Demos</h3>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {latestDemos.map((demo) => {
            const slug = demo.id.replace(/\.md$/, '');
            const demoImage = demoImageMap[slug] || '/assets/images/placeholder.png';
            return (
              <a href={`/demos/${slug}/`} class="group p-4 bg-white rounded-2xl border border-slate-200 shadow-sm hover:shadow transition flex items-center gap-4">
                <div class="w-12 h-12 rounded-xl overflow-hidden shrink-0">
                  <SmartImage src={demoImage} alt={demo.data.title} class="w-full h-full object-cover" />
                </div>
                <div>
                  <h4 class="text-xs font-bold text-slate-950 group-hover:text-indigo-600 transition">{demo.data.title}</h4>
                  <p class="text-[10px] text-slate-400 mt-0.5 line-clamp-1">{demo.data.category}</p>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Section 8: The Resources Hub Magnet -->
    <section class="site-shell py-16 md:py-24 border-t border-slate-100" aria-label="Resources Hub Magnet">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-12">
        <div>
          <span class="section-kicker">Free Blueprints</span>
          <h2 class="text-3xl md:text-4xl font-extrabold text-slate-950 leading-tight mt-3">Download premium guides and systems.</h2>
