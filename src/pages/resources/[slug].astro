---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MDXComponents from '../../components/MDXComponents.astro';
import { getCollection, getEntry } from 'astro:content';
import { getAllResources } from '../../lib/supabase';

export async function getStaticPaths() {
  const resources = await getAllResources();
  return resources.map((r) => ({
    params: { slug: r.slug },
    props: { resource: r },
  }));
}

const { resource } = Astro.props;
const { slug, title, category, description, preview_image, estimated_value = '$29 Value' } = resource;
const cleanTitle = title.replace(/^#\s*/, '').trim();

const item = await getEntry('resources', slug);
if (!item) {
  throw new Error(`Local MDX resource file not found for slug: ${slug}`);
}

const { targetServiceTag, bulletPoints = [] } = item.data;
const { Content } = await item.render();

const previewImage = preview_image || item.data.previewImage;
const estimatedValue = estimated_value || item.data.estimatedValue || '$29 Value';

// Fetch related services for Dynamic Context Matching (Self-Promotion Loop)
const services = await getCollection('services');
const matchedService = services.find((s) => s.data.tag === targetServiceTag) || services[0];
const serviceSlug = matchedService?.id.replace(/\.(md|mdx)$/, '') || '';

// Truncate description to max 155 characters for search snippet optimizations
const truncateDesc = (text: string, max: number = 155) => {
  if (!text) return '';
  if (text.length <= max) return text;
  return text.substring(0, max - 3).trim() + '...';
};

const metaDescription = truncateDesc(description);
const metaImage = previewImage ? (previewImage.startsWith('http') ? previewImage : `https://smesh.dev${previewImage}`) : 'https://smesh.dev/assets/images/placeholder.png';

// Structured Data (JSON-LD) for SoftwareApplication discovery
const resourceSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": cleanTitle,
  "description": description,
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "All",
  "downloadUrl": `https://smesh.dev/resources/${slug}/`,
  "author": {
    "@type": "Organization",
    "name": "BismillahTC Digital Services",
    "url": "https://smesh.dev"
  },
  "offers": {
    "@type": "Offer",
    "price": "0.00",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock"
  },
  "keywords": "AI prompts, n8n automation, Supabase RAG, system prompts"
};

const pageTitle = `${cleanTitle} — Free Download`;
---

<BaseLayout 
  title={pageTitle} 
  description={metaDescription} 
  image={metaImage} 
  type="article"
  distractionFree={true} 
  backUrl="/resources/" 
  backLabel="Back to Resources"
>
  <!-- Gated Content Structured JSON-LD Schema (injected into HTML head via slot) -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(resourceSchema)} />

  <!-- Themify Icons CDN for Lock and Checkmark Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@themify/themify-icons@1.0.1/css/themify-icons.css" />

  <!-- Synchronous block check to hide mockup overlay immediately for returning visitors -->
  <script is:inline define:vars={{ slug }}>
    try {
      if (localStorage.getItem('unlocked_' + slug)) {
        document.write('<style>#mockup-gated-overlay { display: none !important; }</style>');
      }
    } catch (e) {}
  </script>

  <div id="resource-details-root" data-resource-title={cleanTitle} data-resource-slug={slug}>
    
    <!-- Hero / Above the Fold Section -->
    <section class="py-12 md:py-20 border-b border-[color:var(--line)] bg-gradient-to-b from-indigo-50/10 via-transparent to-transparent">
      <div class="site-shell">
        <div class="grid gap-12 lg:grid-cols-[1.1fr_0.9fr] items-center">
          
          <!-- Left Column (Value Proposition) -->
          <div class="space-y-6">
            <!-- Breadcrumbs -->
            <nav class="text-[11px] sm:text-xs text-slate-455 flex flex-wrap items-center gap-y-1 gap-x-1.5 select-none font-sans" aria-label="Breadcrumb">
              <a href="/resources/" class="hover:text-indigo-650 transition shrink-0">Resources</a>
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-slate-300 shrink-0"><polyline points="9 18 15 12 9 6"></polyline></svg>
              <span class="shrink-0">{category}s</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-slate-300 shrink-0"><polyline points="9 18 15 12 9 6"></polyline></svg>
              <span class="text-slate-655 font-semibold truncate min-w-0 max-w-[130px] xs:max-w-[180px] sm:max-w-[260px] md:max-w-xs">{cleanTitle}</span>
            </nav>

            <!-- Premium Value Badge -->
            <div class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-amber-50 border border-amber-200/80 text-amber-800 text-[10px] font-bold font-sans uppercase tracking-wide select-none">
              🔥 Premium Resource &middot; {estimatedValue} &mdash; Now Free
            </div>

            <!-- Title -->
            <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight leading-tight">
              {cleanTitle}
            </h1>

            <p class="text-sm sm:text-base leading-relaxed text-slate-650 font-light max-w-xl">
              {description}
            </p>

            <!-- 3 Short Bullet Points -->
            {bulletPoints.length > 0 && (
              <div class="space-y-4 pt-6 border-t border-[color:var(--line)]">
                <p class="text-xs font-bold text-[color:var(--accent-strong)] uppercase tracking-wider font-sans">What you will unlock:</p>
                <ul class="space-y-3 text-[color:var(--ink)] text-xs sm:text-sm font-sans">
                  {bulletPoints.map((bp) => (
                    <li class="flex items-start gap-3">
                      <span class="inline-flex h-5 w-5 items-center justify-center rounded-full bg-[color:var(--accent-soft)] text-[color:var(--accent-strong)] text-[10px] font-bold shrink-0 mt-0.5">✓</span>
                      <span class="font-light text-[color:var(--muted)]">{bp}</span>
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </div>

          <!-- Right Column (Visual Proof & Lock Status overlay) -->
          <div class="ambient-panel rounded-3xl p-4 border border-[color:var(--line)] bg-white/40 backdrop-blur-md shadow-lg overflow-hidden">
            <!-- Image / Mockup Preview -->
            <div class="relative overflow-hidden rounded-2xl aspect-[4/3] bg-slate-950 flex items-center justify-center border border-slate-100">
              <img 
                src={previewImage || "/assets/images/placeholder.png"} 
                alt={`${cleanTitle} Mockup Preview`} 
                class="w-full h-full object-cover select-none" 
                id="resource-preview-img"
              />
              
              <!-- Lock Status Overlay -->
              <div class="absolute inset-0 bg-slate-950/45 backdrop-blur-xs flex flex-col items-center justify-center text-center p-4 transition-opacity duration-300" id="mockup-gated-overlay">
                <div class="w-10 h-10 rounded-full bg-white/95 border border-slate-200 flex items-center justify-center shadow-lg mb-2 transform scale-100 animate-pulse text-slate-700">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-5 h-5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                </div>
                <span class="text-[9px] uppercase tracking-widest font-bold text-white bg-slate-950/80 px-2.5 py-0.5 rounded border border-slate-700/50 font-sans">
                  Gated System Blueprint
                </span>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Middle Section: Inside the Vault (Deep-Dive content) -->
    <section class="py-16 bg-slate-50/20 border-t border-[color:var(--line)]">
      <div class="site-shell">
        <div class="max-w-3xl mx-auto space-y-8">
          
          <div class="space-y-2 mb-2 max-w-xl">
            <span class="section-kicker">Resource Vault</span>
            <h2 class="text-2xl sm:text-3xl font-extrabold text-slate-900 tracking-tight">System Outlines & Snippets</h2>
            <p class="text-xs text-slate-550 font-light leading-relaxed font-sans">
              Here is the chapter outline and structured content within this premium integration file.
            </p>
          </div>

          <!-- Gated Vault Container (renders the teaser and the ResourceGate component inside the MDX) -->
          <div class="relative rounded-[32px] border border-[color:var(--line)] bg-white/60 backdrop-blur-md p-6 sm:p-10 shadow-lg" id="gated-vault-container">
            <div class="content-body prose max-w-[72ch] mx-auto px-4 py-6 sm:px-6 md:px-8">
              <MDXComponents>
                <Content />
              </MDXComponents>
            </div>
          </div>

          <!-- Bottom Auditing Option -->
          <div class="text-center pt-8 border-t border-[color:var(--line)]">
            <a href={`/services/${serviceSlug}/`} class="inline-flex items-center gap-2 text-xs font-bold text-[color:var(--accent)] hover:text-[color:var(--accent-strong)] transition font-sans">
              Need this customized for your business? Learn about our {matchedService?.data.title || 'services'} &rarr;
            </a>
          </div>

        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<script>
  // Hide mockup overlay when the page is unlocked dynamically
  window.addEventListener('resource-unlocked', () => {
    const mockupOverlay = document.getElementById('mockup-gated-overlay');
    if (mockupOverlay) {
      mockupOverlay.classList.add('opacity-0');
      setTimeout(() => mockupOverlay.classList.add('hidden'), 300);
    }
  });
</script>
