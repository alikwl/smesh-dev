---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const items = await getCollection('resources');
const categories = [
  'All',
  'n8n Templates',
  'AI Prompt Vault',
  'Supabase Kits',
  'Astro Starters',
  'Business Playbooks',
  'Cheat Sheets'
];

// Map resource slugs/ids to custom mockups/teasers if needed, or let it use the clean blurred preview
const estimatedValues: Record<string, string> = {
  'n8n-whatsapp-order-workflow': '$49 Value',
  'offline-pos-sync-guide': '$29 Value',
  'supabase-vector-rag-prompt': '$39 Value',
  'sample-khazaana': '$19 Value',
  'n8n-lead-router-workflow': '$49 Value',
  'supabase-vector-store-kit': '$39 Value',
  'agency-starter-kit': '$29 Value',
};

const categoryGradients: Record<string, string> = {
  'n8n Templates': 'from-orange-500 via-orange-600 to-amber-600',
  'AI Prompt Vault': 'from-indigo-500 via-indigo-600 to-violet-700',
  'Supabase Kits': 'from-emerald-500 via-emerald-600 to-teal-700',
  'Astro Starters': 'from-purple-500 via-purple-600 to-pink-600',
  'Business Playbooks': 'from-teal-500 via-teal-600 to-emerald-700',
  'Cheat Sheets': 'from-blue-500 via-blue-600 to-cyan-700',
};
const defaultGradient = 'from-slate-600 via-slate-700 to-slate-800';
---

<BaseLayout title="n8n Blueprints & Automation Resources | Smesh.Dev" description="Download free n8n workflows, database schemas, local retail POS checklists, and prompt strategies designed by Haider Ali (BismillahTC)." image="https://drive.google.com/thumbnail?id=1GtxC4TjFV8BQrUKqRayyqWOJORHC9dz3&sz=w1200">
  
  <!-- Hero Section -->
  <section class="pb-16 pt-10 md:pb-20 md:pt-14">
    <div class="site-shell">
      <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
        <div>
          <div class="section-kicker">Resources Hub</div>
          <h1 class="display-title mt-4 text-[color:var(--ink)]">Free blueprints, checklists, and integration guides.</h1>
          <p class="body-copy mt-6 max-w-2xl text-sm font-light">
            Unlock the exact system configurations, database schemas, and prompt strategies I use to design high-speed static integrations and automated workflows.
          </p>
        </div>
        <div class="ambient-panel rounded-[32px] p-6 border border-[color:var(--line)] bg-[color:var(--surface)]/60 font-sans">
          <span class="px-2.5 py-0.5 rounded bg-[color:var(--accent-soft)] text-[color:var(--accent-strong)] text-[10px] font-bold uppercase tracking-wider">AEO Grounded</span>
          <h2 class="font-bold text-[color:var(--ink)] mt-3 text-lg leading-snug">Grounded Execution Blueprints</h2>
          <p class="text-xs text-[color:var(--muted)] leading-relaxed mt-2 font-light">
            These guides are built directly from verified production runs. Instead of high-level theory, they show exactly how to configure nodes, structure databases, and bypass API restrictions.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Interactive Category Filters & Search Section -->
  <section class="site-shell pb-10">
    <div class="mb-8">
      <h2 class="text-3xl font-extrabold text-[color:var(--ink)] leading-tight">Available Blueprints & Guides</h2>
      <p class="text-xs text-[color:var(--muted-soft)] mt-2">Filter and search structured templates, config files, and integration guides.</p>
    </div>
    
    <div class="ambient-panel rounded-3xl p-5 border border-[color:var(--line)] bg-[color:var(--surface)]/40 backdrop-blur-md flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <!-- Category Filters -->
      <div class="flex flex-wrap gap-2.5 font-sans" id="resources-filter-container">
        {categories.map((category, index) => (
          <button
            class:list={[
              'resources-filter-btn rounded-full border px-4 py-2 text-[10px] font-bold uppercase tracking-wider transition cursor-pointer select-none',
              index === 0
                ? 'border-[color:var(--accent)] bg-[color:var(--accent-soft)] text-[color:var(--accent-strong)] shadow-sm'
                : 'border-[color:var(--line)] bg-[color:var(--surface)]/40 backdrop-blur-md text-[color:var(--muted)] hover:border-[color:var(--line-strong)] hover:text-[color:var(--ink)]',
            ]}
            data-filter={category}
          >
            {category === 'All' ? 'All Resources' : category}
          </button>
        ))}
      </div>

      <!-- Live Search Bar -->
      <div class="relative w-full md:max-w-xs font-sans">
        <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 pointer-events-none text-[color:var(--meta)]">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </span>
        <input
          type="text"
          id="resources-search-input"
          placeholder="Search blueprints..."
          class="w-full pl-10 pr-4 py-2.5 rounded-2xl border border-[color:var(--line)] bg-[color:var(--surface)] backdrop-blur-md text-xs font-sans text-[color:var(--ink)] placeholder:text-[color:var(--muted-soft)] focus:border-[color:var(--accent)] focus:bg-[color:var(--surface-strong)] focus:outline-none focus:ring-4 focus:ring-[rgba(15,118,110,0.12)] transition"
        />
      </div>
    </div>
  </section>

  <!-- Resources Hub Grid -->
  <section class="site-shell pb-20 md:pb-24">
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3" id="resources-grid">
      {items.map((item) => {
        // NOTE: Drive images must be shared publicly (Anyone with link → Viewer)
        const { title, category, targetServiceTag, description, premium, previewImage } = item.data;
        const slug = item.id.replace(/\.(md|mdx)$/, '');
        const valText = estimatedValues[slug] || '$29 Value';
        const cleanTitle = title.replace(/^#+\s*/, '').trim();
        const gradientClass = categoryGradients[category] || defaultGradient;
        return (
          <article 
            class="resources-card ambient-panel overflow-hidden rounded-[30px] border border-[color:var(--line)] bg-[color:var(--surface)] hover:-translate-y-1.5 hover:shadow-xl hover:bg-[color:var(--surface-strong)] transition-all duration-300 flex flex-col justify-between"
            data-category={category}
            data-slug={slug}
          >
            <div>
              <!-- 1. The Teaser Visual & Lock Badge -->
              <div class="relative overflow-hidden aspect-[16/10] bg-[color:var(--ink)]/5 flex items-center justify-center border-b border-[color:var(--line)] select-none">
                {previewImage ? (
                  <img 
                    src={previewImage} 
                    alt={cleanTitle} 
                    loading="lazy"
                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    onerror="this.onerror=null;this.src='/assets/images/placeholder.png'"
                  />
                ) : (
                  <div class={`absolute inset-0 bg-gradient-to-br ${gradientClass}`} />
                )}

              </div>

              <!-- Content Area & Value Hook -->
              <div class="p-7 space-y-4">
                <div class="flex items-center justify-between font-sans">
                  <span class="px-2.5 py-0.5 rounded bg-[color:var(--line)] text-[color:var(--ink)] text-[9px] font-bold uppercase tracking-wider">
                    {category}
                  </span>
                  
                  <!-- 2. Value Hook Badge -->
                  <span class="px-2.5 py-0.5 rounded border border-[color:var(--accent-soft)] bg-[color:var(--accent-soft)]/20 text-[color:var(--accent-strong)] text-[9px] font-bold uppercase tracking-wider font-sans">
                    FREE RESOURCE
                  </span>
                </div>

                <div class="space-y-2">
                  <h3 class="text-base font-bold text-[color:var(--ink)] leading-snug line-clamp-2 min-h-[3rem] hover:text-[color:var(--accent-strong)] transition">
                    <a href={`/resources/${slug}/`}>{cleanTitle}</a>
                  </h3>
                  <p class="text-sm text-[color:var(--muted)] leading-relaxed line-clamp-3 font-light">{description}</p>
                </div>
              </div>
            </div>

            <!-- Card Footer -->
            <div class="mx-7 pb-7 pt-5 border-t border-[color:var(--line)] flex items-center justify-between font-sans">
              <div>
                <span class="text-[8px] uppercase tracking-[0.16em] text-[color:var(--muted-soft)] block font-semibold">Best For</span>
                <span class="chip text-[9px] py-0.5 px-2 mt-1 inline-block capitalize bg-[rgba(15,118,110,0.06)] text-[color:var(--accent-strong)] font-semibold rounded">{targetServiceTag.replace(/-/g, ' ')}</span>
              </div>

              <!-- 4. Micro-Copy CTA -->
              <div>
                <a 
                  href={`/resources/${slug}/`}
                  class="inline-flex h-9 px-4 items-center justify-center rounded-xl bg-[color:var(--accent)] hover:bg-[color:var(--accent-strong)] text-white text-xs font-bold transition cursor-pointer font-sans"
                >
                  Read Now
                </a>
              </div>
            </div>
          </article>
        );
      })}
    </div>

    <!-- No Results Placeholder -->
    <div id="no-results-container" class="hidden text-center py-16 px-4 ambient-panel rounded-[30px] border border-[color:var(--line)] bg-[color:var(--surface)]/30 backdrop-blur-md max-w-md mx-auto mt-6 space-y-4">
      <div class="w-12 h-12 rounded-2xl bg-teal-50 border border-teal-100/50 text-[color:var(--accent)] flex items-center justify-center mx-auto">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </div>
      <div class="space-y-1">
        <h4 class="font-bold text-[color:var(--ink)] text-sm">No blueprints found</h4>
        <p class="text-xs text-[color:var(--muted)] font-light leading-relaxed">We couldn't find any resources matching your criteria. Try adjusting your category filters or search query.</p>
      </div>
    </div>
  </section>

  <!-- Newsletter Signup Strip -->
  <section class="site-shell pb-20 md:pb-24">
    <div 
      class="newsletter-signup-strip p-6 sm:p-10 bg-[color:var(--ink)] text-[color:var(--bg-soft)] border border-[color:var(--line-strong)] rounded-[32px] shadow-lg relative overflow-hidden font-sans"
      data-resource-slug="resources-hub"
      data-resource-type="newsletter"
    >
      <div class="absolute inset-0 opacity-5 bg-[radial-gradient(#fff_1px,transparent_1px)] [background-size:16px_16px] pointer-events-none"></div>

      <div class="strip-inner relative z-10 flex flex-col lg:flex-row lg:items-center justify-between gap-6">
        <!-- Left side content -->
        <div class="max-w-xl space-y-2">
          <div class="text-[10px] font-bold tracking-wider text-[color:var(--accent)] uppercase flex items-center gap-1.5 select-none">
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-[color:var(--accent)] animate-pulse"></span>
            WEEKLY BLUEPRINTS
          </div>
          <h3 class="text-xl sm:text-2xl font-bold text-white leading-tight">
            Get new blueprints before they go public.
          </h3>
          <p class="text-xs sm:text-sm text-[color:var(--meta)] font-light leading-relaxed">
            Join developers getting n8n + Supabase resources weekly. No fluff, no spam.
          </p>
        </div>

        <!-- Right side form -->
        <div class="w-full lg:w-auto lg:min-w-[360px]">
          <form class="newsletter-signup-form flex flex-col sm:flex-row gap-3 w-full">
            <input 
              type="email" 
              required 
              placeholder="you@company.com" 
              class="w-full px-4 py-3 rounded-xl border border-[color:var(--line)] bg-[color:var(--ink)]/50 text-[color:var(--bg-soft)] text-xs focus:border-[color:var(--accent)] focus:outline-none focus:ring-4 focus:ring-[rgba(15,118,110,0.12)] transition font-sans"
            />
            <button 
              type="submit" 
              class="submit-btn bg-[color:var(--accent)] hover:bg-[color:var(--accent-strong)] text-white font-bold px-6 py-3 rounded-xl text-xs transition flex items-center justify-center gap-1.5 shrink-0 select-none font-sans cursor-pointer"
            >
              <span>Join the List</span>
              <!-- Loading Spinner -->
              <svg class="spinner hidden animate-spin h-3.5 w-3.5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
            </button>
          </form>
          <!-- Interactive status messaging -->
          <div class="message-box hidden mt-3 text-xs font-semibold text-center py-2.5 px-3 rounded-xl transition-all duration-300"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Client-Side Category Filtering & Newsletter Script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      let currentFilter = 'All';
      let currentSearch = '';

      const filterButtons = document.querySelectorAll('.resources-filter-btn');
      const searchInput = document.getElementById('resources-search-input') as HTMLInputElement | null;
      const cards = document.querySelectorAll('.resources-card');
      const noResultsContainer = document.getElementById('no-results-container');

      const filterCards = () => {
        let visibleCount = 0;
        const query = currentSearch.toLowerCase().trim();

        cards.forEach(card => {
          const cardCategory = card.getAttribute('data-category') || '';
          const cardTitle = card.querySelector('h3')?.textContent?.toLowerCase() || '';
          const cardDesc = card.querySelector('p')?.textContent?.toLowerCase() || '';

          const matchesCategory = currentFilter === 'All' || cardCategory === currentFilter;
          const matchesSearch = query === '' || cardTitle.includes(query) || cardDesc.includes(query);

          if (matchesCategory && matchesSearch) {
            (card as HTMLElement).style.display = 'flex';
            visibleCount++;
          } else {
            (card as HTMLElement).style.display = 'none';
          }
        });

        if (noResultsContainer) {
          if (visibleCount === 0) {
            noResultsContainer.classList.remove('hidden');
            noResultsContainer.classList.add('block');
          } else {
            noResultsContainer.classList.add('hidden');
            noResultsContainer.classList.remove('block');
          }
        }
      };

      filterButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          const filterValue = btn.getAttribute('data-filter') || 'All';
          currentFilter = filterValue;

          filterButtons.forEach(b => {
            b.classList.remove('border-[color:var(--accent)]', 'bg-[color:var(--accent-soft)]', 'text-[color:var(--accent-strong)]', 'shadow-sm');
            b.classList.add('border-[color:var(--line)]', 'bg-[color:var(--surface)]/40', 'text-[color:var(--muted)]');
          });

          btn.classList.remove('border-[color:var(--line)]', 'bg-[color:var(--surface)]/40', 'text-[color:var(--muted)]');
          btn.classList.add('border-[color:var(--accent)]', 'bg-[color:var(--accent-soft)]', 'text-[color:var(--accent-strong)]', 'shadow-sm');

          filterCards();
        });
      });

      searchInput?.addEventListener('input', (e) => {
        currentSearch = (e.target as HTMLInputElement).value;
        filterCards();
      });

      // Newsletter Signup Script
      const newsletterStrip = document.querySelector('.newsletter-signup-strip');
      if (newsletterStrip) {
        const form = newsletterStrip.querySelector('.newsletter-signup-form');
        if (form) {
          form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const resourceSlug = newsletterStrip.getAttribute('data-resource-slug') || 'resources-hub';
            const resourceType = newsletterStrip.getAttribute('data-resource-type') || 'newsletter';
            const input = form.querySelector('input[type="email"]') as HTMLInputElement | null;
            const submitBtn = form.querySelector('.submit-btn') as HTMLButtonElement | null;
            const submitText = submitBtn?.querySelector('span');
            const spinner = submitBtn?.querySelector('.spinner');
            const messageBox = newsletterStrip.querySelector('.message-box') as HTMLDivElement | null;

            if (!input || !submitBtn || !messageBox) return;

            const email = input.value.trim();
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

            if (!email || !emailRegex.test(email)) {
              messageBox.textContent = "Please enter a valid email";
              messageBox.className = 'message-box block mt-2.5 text-xs text-rose-400 font-semibold text-center bg-rose-950/20 border border-rose-900/30 py-2.5 rounded-xl';
              messageBox.classList.remove('hidden');
              return;
            }

            input.disabled = true;
            submitBtn.disabled = true;
            if (submitText) submitText.textContent = 'Joining...';
            if (spinner) spinner.classList.remove('hidden');
            messageBox.classList.add('hidden');

            try {
              const { supabase } = await import('../../lib/supabase');
              const { error } = await supabase.from('email_leads').insert([
                {
                  email: email,
                  resource_id: null,
                  resource_slug: resourceSlug,
                  resource_type: resourceType
                }
              ]);

              if (error) throw error;

              newsletterStrip.innerHTML = `<div class="absolute inset-0 opacity-5 bg-[radial-gradient(#fff_1px,transparent_1px)] [background-size:16px_16px] pointer-events-none"></div><div class="relative z-10 flex items-center justify-center py-8 text-emerald-450 font-bold text-xs sm:text-sm font-sans text-center px-4"><p>✓ Subscribed! Free blueprints and weekly n8n configs are on the way to your inbox. ⚡</p></div>`;
              console.log(`Newsletter signup: ${email}`);
            } catch (err: any) {
              console.error('Failed to subscribe:', err);

              input.disabled = false;
              submitBtn.disabled = false;
              if (submitText) submitText.textContent = 'Join the List';
              if (spinner) spinner.classList.add('hidden');

              const isDuplicate = err.code === '23505' || err.message?.includes('duplicate');
              if (isDuplicate) {
                messageBox.textContent = "You're already on the list! 🎉";
                messageBox.className = 'message-box block mt-2.5 text-xs text-amber-400 font-semibold text-center bg-amber-950/20 border border-amber-900/30 py-2.5 rounded-xl';
              } else {
                messageBox.textContent = "Something went wrong. Please try again.";
                messageBox.className = 'message-box block mt-2.5 text-xs text-rose-400 font-semibold text-center bg-rose-950/20 border border-rose-900/30 py-2.5 rounded-xl';
              }
              messageBox.classList.remove('hidden');
            }
          });
        }
      }
    });
  </script>
</BaseLayout>
