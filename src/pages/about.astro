---
import BaseLayout from '../layouts/BaseLayout.astro';
import SmartImage from '../components/SmartImage.astro';
import { site } from '../data/site';
---

<BaseLayout 
  title="About Smesh.dev & Founder Haider Ali | Automation Engineer" 
  description="Learn about Smesh.dev and founder Haider Ali, specializing in custom n8n workflow automation, AI support chatbots, and integrated database systems."
>
  <section class="site-shell py-16 md:py-24">
    <div class="grid gap-12 lg:grid-cols-[1fr_0.9fr] lg:items-center">
      <div class="space-y-6">
        <span class="section-kicker">
          Founder & Engineer
        </span>
        <h1 class="display-title text-[color:var(--ink)] text-3xl sm:text-4xl md:text-5xl font-extrabold tracking-tight leading-[1.1] font-display">
          Hi, I'm Haider Ali &mdash;<br />
          <span class="text-[color:var(--accent-strong)]">Automation Engineer</span> & Founder of Smesh.dev
        </h1>
        <p class="body-copy text-sm sm:text-base leading-relaxed text-slate-600 font-light">
          Operating under <strong>BismillahTC Digital Services</strong>, based in Khanewal, I bring 8+ years of hands-on experience in building custom digital systems, automating business backends, and building fast web products.
        </p>
        <p class="body-copy text-sm sm:text-base leading-relaxed text-slate-600 font-light">
          I started Smesh.dev as a personal studio to offer high-context engineering directly to founders and business owners. I reject agency bureaucracy—when you book a project, you work directly with me.
        </p>
        <div class="flex flex-wrap gap-4 pt-2 font-sans">
          <a href={site.whatsappLink} target="_blank" rel="noopener" class="button-primary px-8 py-3.5 rounded-xl font-bold flex items-center gap-2 shadow-md">
            <i data-lucide="message-circle" class="w-4 h-4"></i>
            WhatsApp Haider
          </a>
          <a href={`mailto:${site.email}`} class="button-secondary px-8 py-3.5 rounded-xl font-bold flex items-center gap-2">
            <i data-lucide="mail" class="w-4 h-4"></i>
            Email {site.email}
          </a>
        </div>
      </div>

      <div class="surface-card overflow-hidden rounded-[36px] border border-slate-200 bg-slate-50 relative aspect-square max-w-md mx-auto lg:max-w-none w-full shadow-sm">
        <SmartImage
          src="/assets/images/resources/author-haider-ali.webp"
          alt="Haider Ali - Founder & Lead Developer"
          class="w-full h-full object-cover object-center"
        />
        <div class="absolute bottom-4 left-4 right-4 bg-white/90 backdrop-blur-xs px-4 py-3 rounded-2xl border border-slate-100 flex items-center justify-between text-xs font-semibold text-slate-800 font-sans shadow-xs">
          <span>Based in Khanewal, Pakistan</span>
          <span class="flex items-center gap-1.5 text-emerald-600">
            <span class="live-dot h-2 w-2 rounded-full bg-emerald-500 animate-ping"></span>
            Available for Booking
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission Quote Section -->
  <section class="site-shell pb-16 md:pb-24">
    <div class="ambient-panel rounded-[36px] p-8 md:p-12 text-center max-w-4xl mx-auto space-y-4">
      <span class="text-[10px] font-bold uppercase tracking-widest text-[color:var(--accent-strong)] font-sans">Our Purpose</span>
      <blockquote class="text-xl sm:text-2xl font-extrabold text-[color:var(--ink)] leading-normal font-display max-w-2xl mx-auto">
        "I build the autonomous nervous system for small and medium businesses so owners can focus on growth instead of repetitive tasks."
      </blockquote>
      <cite class="block text-xs font-semibold text-slate-450 uppercase tracking-wider font-sans not-italic mt-4">
        &mdash; Haider Ali, Founder
      </cite>
    </div>
  </section>

  <!-- What I Do Section -->
  <section class="site-shell pb-16 md:pb-24">
    <div class="space-y-4 mb-12 text-center">
      <span class="section-kicker">Core Focus</span>
      <h2 class="text-3xl font-extrabold text-slate-900 leading-tight">What I Build</h2>
      <p class="text-xs sm:text-sm text-slate-500 max-w-md mx-auto font-light">Practical digital solutions engineered for immediate efficiency gains.</p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 max-w-4xl mx-auto font-sans">
      <!-- Feature 1 -->
      <article class="surface-card rounded-[28px] p-6 border border-slate-200 bg-white/70 hover:-translate-y-0.5 hover:shadow-md transition duration-300 space-y-4">
        <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-teal-50 text-[color:var(--accent)] shrink-0 border border-teal-100/50">
          <i data-lucide="git-merge" class="w-5 h-5"></i>
        </div>
        <h3 class="text-base font-bold text-slate-955 font-display">Custom n8n Workflows</h3>
        <p class="text-xs text-slate-500 leading-relaxed font-light">
          Connecting your lead captures, database triggers, WhatsApp channels, and third-party APIs into self-running pipelines that run 24/7.
        </p>
      </article>

      <!-- Feature 2 -->
      <article class="surface-card rounded-[28px] p-6 border border-slate-200 bg-white/70 hover:-translate-y-0.5 hover:shadow-md transition duration-300 space-y-4">
        <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-indigo-50 text-indigo-750 shrink-0 border border-indigo-100/50">
          <i data-lucide="message-square" class="w-5 h-5"></i>
        </div>
        <h3 class="text-base font-bold text-slate-955 font-display">AI RAG Support Chatbots</h3>
        <p class="text-xs text-slate-500 leading-relaxed font-light">
          Configuring grounded AI chat agents linked directly to your company knowledge bases (using vector embeddings) to resolve client support tickets instantly.
        </p>
      </article>

      <!-- Feature 3 -->
      <article class="surface-card rounded-[28px] p-6 border border-slate-200 bg-white/70 hover:-translate-y-0.5 hover:shadow-md transition duration-300 space-y-4">
        <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-orange-50 text-orange-600 shrink-0 border border-orange-100/50">
          <i data-lucide="database" class="w-5 h-5"></i>
        </div>
        <h3 class="text-base font-bold text-slate-955 font-display">Offline-First POS Checkout Systems</h3>
        <p class="text-xs text-slate-500 leading-relaxed font-light">
          Designing retail sales interfaces that run locally on low internet connections (with SQLite/IndexedDB) and sync central stock data to Supabase once online.
        </p>
      </article>

      <!-- Feature 4 -->
      <article class="surface-card rounded-[28px] p-6 border border-slate-200 bg-white/70 hover:-translate-y-0.5 hover:shadow-md transition duration-300 space-y-4">
        <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-50 text-emerald-700 shrink-0 border border-emerald-100/50">
          <i data-lucide="layout" class="w-5 h-5"></i>
        </div>
        <h3 class="text-base font-bold text-slate-955 font-display">High-Speed Web Apps (Astro & Supabase)</h3>
        <p class="text-xs text-slate-500 leading-relaxed font-light">
          Scaffolding fast, SEO-ready business sites and internal operational dashboards with sub-second page loads and robust PostgreSQL backends.
        </p>
      </article>
    </div>
  </section>

  <!-- Trust Guarantee Section -->
  <section class="site-shell pb-20 md:pb-28">
    <div class="surface-card rounded-[32px] p-8 md:p-12 border border-slate-200 bg-white max-w-4xl mx-auto flex flex-col md:flex-row items-center gap-8 shadow-sm">
      <div class="inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-teal-50 text-[color:var(--accent)] shrink-0 border border-teal-100/50">
        <i data-lucide="shield-check" class="w-8 h-8"></i>
      </div>
      <div class="space-y-3">
        <h3 class="text-xl font-bold text-slate-900 font-display">I personally handle every project from start to finish.</h3>
        <p class="text-xs md:text-sm text-slate-500 leading-relaxed font-light">
          When you partner with Smesh.dev, you work directly with me. I map your processes, configure the databases, write the code, and manage the final rollout. There are no account managers, no layers of bureaucracy, and no junior handoffs.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
