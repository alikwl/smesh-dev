---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { site } from '../data/site';
---

<BaseLayout 
  title="Contact Smesh.dev | Custom Business Automation Services" 
  description="Contact Smesh.dev to get a free automation audit. We build custom n8n workflows, AI support chatbots, and scalable database integrations."
>
  <section class="site-shell pt-16 md:pt-24 pb-10">
    <div class="max-w-4xl mx-auto text-center space-y-6">
      <span class="section-kicker mx-auto">
        <i data-lucide="zap" class="w-3.5 h-3.5 mr-1 text-[color:var(--accent-strong)] animate-pulse"></i>
        Get A Working System
      </span>
      <h1 class="display-title text-[color:var(--ink)] text-4xl md:text-6xl font-extrabold tracking-tight leading-[1.08] font-display">
        Describe the bottleneck.<br class="hidden sm:inline" /> I will map the automation.
      </h1>
      <p class="body-copy max-w-2xl mx-auto text-[color:var(--muted)] leading-relaxed font-light font-sans">
        Smesh.Dev is an automation and web development studio run by Haider Ali that builds custom n8n workflows, AI support chatbots, and web databases. Contact us to describe your operational bottlenecks and get a functional system proposal.
      </p>
    </div>
  </section>

  <!-- Reassurance / Trust Strip (Full Width) -->
  <div class="w-full bg-[#eae4d5] border-y border-[#e2dacb]/60 py-4 px-4 sm:px-6 md:px-8 mb-12">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-start md:items-center justify-between gap-4 md:gap-6 text-[13px] font-sans text-[color:var(--muted)]">
      <div class="flex items-center gap-2.5">
        <i data-lucide="shield" class="w-4 h-4 shrink-0 text-[color:var(--accent)]"></i>
        <span class="leading-normal">
          <strong class="font-semibold text-[color:var(--ink)]">100% Confidential</strong>
          <span class="text-[color:var(--muted-soft)] mx-1">—</span>
          <span>details will only be used for the project</span>
        </span>
      </div>
      <div class="flex items-center gap-2.5">
        <i data-lucide="calendar" class="w-4 h-4 shrink-0 text-[color:var(--accent)]"></i>
        <span class="leading-normal">
          <strong class="font-semibold text-[color:var(--ink)]">Free 15-min consultation</strong>
          <span class="text-[color:var(--muted-soft)] mx-1">—</span>
          <span>no commitment required</span>
        </span>
      </div>
      <div class="flex items-center gap-2.5">
        <i data-lucide="zap" class="w-4 h-4 shrink-0 text-[color:var(--accent)]"></i>
        <span class="leading-normal">
          <strong class="font-semibold text-[color:var(--ink)]">Fast turnaround</strong>
          <span class="text-[color:var(--muted-soft)] mx-1">—</span>
          <span>10-15 day delivery standard</span>
        </span>
      </div>
    </div>
  </div>

  <section class="site-shell pt-4 pb-16 md:pb-24">
    <div class="grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-start max-w-6xl mx-auto">
      
      <!-- Left Column: Context, WhatsApp CTA, and Dev Q&A -->
      <div class="space-y-10">
        
        <!-- Addressing Both Target Groups -->
        <div class="grid gap-6 sm:grid-cols-2">
          
          <!-- Operations & API Automation -->
          <div class="surface-card rounded-[28px] border border-[color:var(--line)] bg-[color:var(--surface)]/50 p-6 space-y-4">
            <span class="chip bg-emerald-50 border border-emerald-100 text-emerald-700 text-[9px] font-bold uppercase tracking-wider font-sans">
              Workflow & API Automation
            </span>
            <h2 class="text-base font-bold text-[color:var(--ink)] font-display">Eliminate Manual Operations</h2>
            <p class="text-xs text-[color:var(--muted)] leading-relaxed font-light font-sans">
              Stop paying staff to manually copy orders, check inventory levels, or type customer details. Connect your WhatsApp, Google Sheets, databases, and logistics APIs to run 24/7.
            </p>
            <div class="text-[11px] font-medium text-[color:var(--accent-strong)] font-sans flex items-center gap-1">
              <span>Standard workflow setups start at $1,500 USD</span>
            </div>
          </div>

          <!-- SaaS & MVP builders -->
          <div class="surface-card rounded-[28px] border border-[color:var(--line)] bg-[color:var(--surface)]/50 p-6 space-y-4">
            <span class="chip bg-indigo-50 border border-indigo-100 text-[color:var(--accent-strong)] text-[9px] font-bold uppercase tracking-wider font-sans">
              SaaS, MVPs & Extensions
            </span>
            <h2 class="text-base font-bold text-[color:var(--ink)] font-display">Launch Products in Weeks</h2>
            <p class="text-xs text-[color:var(--muted)] leading-relaxed font-light font-sans">
              Deploy secure SaaS applications with user authentication, payment processing (Stripe), and vector databases (pgvector/Supabase). Build custom extensions to sync data from the browser.
            </p>
            <div class="text-[11px] font-medium text-[color:var(--accent)] font-sans flex items-center gap-1">
              <span>Full product builds start at $3,500 USD</span>
            </div>
          </div>

        </div>

        <!-- Primary WhatsApp CTA Banner -->
        <div class="surface-card rounded-[32px] border border-emerald-200 bg-emerald-50/30 p-6 md:p-8 space-y-6 relative overflow-hidden">
          <div class="absolute -right-16 -top-16 w-36 h-36 rounded-full bg-emerald-100/30 blur-2xl"></div>
          <div class="space-y-3 relative z-10">
            <div class="flex items-center gap-2 text-emerald-750 font-sans">
              <span class="live-dot h-2.5 w-2.5 rounded-full bg-emerald-500 animate-ping"></span>
              <span class="text-xs font-bold uppercase tracking-widest">Instant Direct Line</span>
            </div>
            <h2 class="text-xl md:text-2xl font-bold text-slate-950 font-display leading-tight">
              Prefer direct text? Message Haider on WhatsApp.
            </h2>
            <p class="text-xs text-[color:var(--muted)] leading-relaxed font-light font-sans max-w-lg">
              Skip the forms entirely. Click the button below to message me directly. Describe what you need automated, what tools you use, and I will reply within a few hours.
            </p>
          </div>
          <div class="pt-2 relative z-10">
            <a 
              href={`${site.whatsappLink}?text=${encodeURIComponent('Hi Haider, I am checking Smesh.dev. I want to discuss an automation / web project.')}`}
              target="_blank"
              rel="noopener"
              class="button-primary justify-center w-full sm:w-auto text-xs py-3.5 px-8 font-sans font-bold flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 border-emerald-650 text-white shadow-lg"
            >
              <i data-lucide="message-circle" class="w-4 h-4 text-white"></i>
              Start WhatsApp Discussion
            </a>
          </div>
        </div>

        <!-- Developer Direct Q&A (Overcoming friction) -->
        <div class="space-y-6 pt-4 border-t border-[color:var(--line)]/60 font-sans">
          <h2 class="text-xs font-bold uppercase tracking-wider text-[color:var(--muted-soft)] font-sans">🛠️ Direct Developer Assurances</h2>
          
          <div class="grid gap-6 sm:grid-cols-2">
            <div class="space-y-2">
              <h3 class="text-xs font-bold text-[color:var(--ink)] leading-snug">What happens after I submit details?</h3>
              <p class="text-[11px] text-[color:var(--muted-soft)] leading-relaxed font-light">
                I will review your brief within 24 hours. If it fits my focus, I will reply on WhatsApp or email with a conceptual flow diagram or a starting budget estimate.
              </p>
            </div>
            
            <div class="space-y-2">
              <h3 class="text-xs font-bold text-[color:var(--ink)] leading-snug">What if I don't know what tool I need?</h3>
              <p class="text-[11px] text-[color:var(--muted-soft)] leading-relaxed font-light">
                That is completely fine. Simply write down what tasks your team does manually every day (e.g. copying order details to Google Sheets). I will map the nodes and choose the correct tech stack.
              </p>
            </div>

            <div class="space-y-2">
              <h3 class="text-xs font-bold text-[color:var(--ink)] leading-snug">Who actually builds my system?</h3>
              <p class="text-[11px] text-[color:var(--muted-soft)] leading-relaxed font-light">
                I do. Smesh.Dev is my personal development studio. You work directly with me from discovery to delivery. No account managers or junior developers-in-training.
              </p>
            </div>

            <div class="space-y-2">
              <h3 class="text-xs font-bold text-[color:var(--ink)] leading-snug">How fast are projects delivered?</h3>
              <p class="text-[11px] text-[color:var(--muted-soft)] leading-relaxed font-light">
                Simple WhatsApp bot integrations take 10-15 days. Custom multi-app n8n pipelines, Chrome scraper extensions, or full SaaS MVP builds typically take 3-4 weeks.
              </p>
            </div>
          </div>
        </div>

      </div>

      <!-- Right Column: Interactive Project Brief Form -->
      <div class="surface-card rounded-[36px] p-6 md:p-8 border border-[color:var(--line)] bg-[color:var(--surface)] shadow-md space-y-6">
        <div class="space-y-2">
          <span class="chip bg-[color:var(--bg-soft)] border border-[color:var(--line)] text-[color:var(--muted)] text-[9px] font-bold uppercase tracking-wider font-sans">
            Step 1 of 1
          </span>
          <h2 class="text-lg font-bold text-slate-950 font-display">Submit A Project Brief</h2>
          <p class="text-xs text-[color:var(--muted-soft)] leading-relaxed font-light font-sans">
            Fill in your project goals below. The more concrete details you share, the sharper and more realistic my initial proposal will be.
          </p>
        </div>
        <div class="border-t border-[color:var(--line)] pt-6">
          <ContactForm isBare={true} />
        </div>
      </div>

    </div>
  </section>
</BaseLayout>
