---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { site } from '../../data/site';

export async function getStaticPaths() {
  const items = await getCollection('demos');
  return items.map((item) => ({
    params: { slug: item.id.replace(/\.md$/, '') },
    props: { item },
  }));
}

const { item } = Astro.props as { item: CollectionEntry<'demos'> };
const { title, category, description, tech = [], use_case, steps = [] } = item.data;
const slug = item.id.replace(/\.md$/, '');
const { Content } = await item.render();

const demoImageMap: Record<string, string> = {
  'whatsapp-order-system': '/assets/images/whatsapp-phone-mockup.png',
  'ai-support-chatbot': '/assets/images/ai-network-illustration.png',
  'booking-dashboard': '/assets/images/calendar-booking-mockup.png',
  'pos-inventory-dashboard': '/assets/images/saas-dashboard-illustration.png',
  'saas-mvp-dashboard': '/assets/images/saas-dashboard-illustration.png',
  'lead-capture-workflow': '/assets/images/automation-workflow-illustration.png',
};
const heroImage = demoImageMap[slug] || '/assets/images/placeholder.png';

const metaDescription = description || `Test the interactive sandbox demo for ${title}. See how this automation workflow speeds up business operations.`;

const demoSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": title,
  "description": metaDescription,
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "All",
  "image": `${site.url}${heroImage}`,
  "author": {
    "@type": "Person",
    "name": "Haider Ali",
    "url": "https://smesh.dev/"
  },
  "publisher": {
    "@type": "Organization",
    "name": "BismillahTC Digital Services"
  }
};
---

<BaseLayout title={title} description={metaDescription} image={heroImage}>
  <!-- Injected SoftwareApplication JSON-LD Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(demoSchema)} />

  <!-- Breadcrumbs -->
  <nav class="site-shell py-6 text-xs font-sans" aria-label="Breadcrumb">
    <ol class="inline-flex flex-wrap items-center gap-2 rounded-full border border-[color:var(--line)] bg-white/78 px-4 py-2 text-[color:var(--muted)]">
      <li class="inline-flex items-center">
        <a href="/" class="inline-flex items-center transition hover:text-[color:var(--ink)]">
          <i data-lucide="home" class="w-3 h-3 mr-1.5"></i>
          Home
        </a>
      </li>
      <li>
        <div class="flex items-center">
          <i data-lucide="chevron-right" class="mx-1 h-3 w-3 text-[color:var(--muted-soft)]"></i>
          <a href="/demos/" class="transition hover:text-[color:var(--ink)]">Demos</a>
        </div>
      </li>
      <li aria-current="page">
        <div class="flex items-center">
          <i data-lucide="chevron-right" class="mx-1 h-3 w-3 text-[color:var(--muted-soft)]"></i>
          <span class="font-medium text-[color:var(--ink)]">{title}</span>
        </div>
      </li>
    </ol>
  </nav>

  <!-- Hero Header Section -->
  <section class="site-shell py-10 md:py-14" aria-label="Demo Header">
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8">
      <div class="max-w-3xl space-y-4">
        <span class="section-kicker">
          <i data-lucide="play-circle" class="w-3.5 h-3.5"></i>
          Simulated Sandbox
        </span>
        <h1 class="display-title font-extrabold text-slate-950 leading-[1.08] font-display">
          {title}
        </h1>
        <p class="body-copy text-slate-650 font-light max-w-2xl leading-relaxed">
          {description}
        </p>
      </div>

      <div class="shrink-0 pt-2 lg:pt-0">
        <a href="#interactive-demo-sandbox" class="inline-flex items-center justify-center button-primary py-3.5 px-6 text-xs font-bold shadow-md cursor-pointer">
          Launch Sandbox Preview
          <i data-lucide="arrow-down" class="w-4 h-4 ml-2 animate-bounce"></i>
        </a>
      </div>
    </div>
  </section>

  <!-- macOS Browser Frame Wrapper for Sandbox Content -->
  <section id="interactive-demo-sandbox" class="site-shell pb-20" aria-label="Interactive Demo Sandbox">
    <!-- Browser Mockup Window -->
    <div class="w-full bg-slate-50/20 border border-slate-200/80 rounded-[32px] overflow-hidden shadow-xl flex flex-col">
      <!-- Browser Top Bar Controls -->
      <div class="bg-slate-100/90 border-b border-slate-200/60 h-12 px-5 flex items-center justify-between shrink-0 select-none">
        <!-- Window circles -->
        <div class="flex items-center gap-1.5">
          <span class="w-3 h-3 rounded-full bg-[#ff5f56]"></span>
          <span class="w-3 h-3 rounded-full bg-[#ffbd2e]"></span>
          <span class="w-3 h-3 rounded-full bg-[#27c93f]"></span>
        </div>
        <!-- URL Input -->
        <div class="flex-grow max-w-sm px-4 hidden sm:block">
          <div class="bg-white/80 border border-slate-200/50 rounded-lg py-1 px-4 text-[10px] font-mono text-slate-400 select-all truncate text-center">
            https://sandbox.smesh.dev/demo/{slug}
          </div>
        </div>
        <!-- Active Status Badge -->
        <div class="flex items-center gap-1.5 select-none shrink-0">
          <span class="live-dot h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
          <span class="text-[9px] font-mono text-emerald-700 bg-emerald-50 border border-emerald-100/50 px-2.5 py-0.5 rounded-full uppercase tracking-wider font-bold">Simulated Live</span>
        </div>
      </div>

      <!-- Browser Workspace Body (Directly Renders the Content) -->
      <div class="p-6 md:p-8 bg-slate-50/50 backdrop-blur-sm relative">
        <Content />
      </div>
    </div>
  </section>

  <!-- Details & Breakdown Section -->
  <section class="border-t border-slate-200/60 bg-slate-50/40 py-24" aria-label="Technical Details">
    <div class="site-shell">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-14 items-start font-sans">
        
        <!-- LEFT: How It Works Process (col-span-7) -->
        <div class="lg:col-span-7 space-y-8">
          <div class="space-y-3">
            <span class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--accent-strong)]">
              Workflow Mechanics
            </span>
            <h2 class="text-2xl font-bold text-slate-900 font-display">How This Automation Works</h2>
            <p class="body-copy text-slate-600 font-light max-w-xl">
              A step-by-step breakdown of the backend logic, triggers, and sync rules powering this application mockup.
            </p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {steps.length > 0 ? (
              steps.map((step, idx) => (
                <div class="surface-card p-5 rounded-2xl border border-slate-200 shadow-sm flex gap-4 hover:shadow-md transition duration-150 bg-white">
                  <div class="w-10 h-10 rounded-xl bg-indigo-50 border border-indigo-100/30 flex items-center justify-center text-indigo-600 shrink-0 mt-0.5">
                    <i data-lucide={step.icon || 'check-circle'} class="w-5 h-5"></i>
                  </div>
                  <div class="space-y-1">
                    <h4 class="font-bold text-slate-950 text-sm font-display">{idx + 1}. {step.title}</h4>
                    <p class="text-xs text-slate-500 leading-relaxed font-light">{step.description}</p>
                  </div>
                </div>
              ))
            ) : (
              <!-- Fallback steps if none provided -->
              <>
                <div class="surface-card p-5 rounded-2xl border border-slate-200 shadow-sm flex gap-4 bg-white">
                  <div class="w-10 h-10 rounded-xl bg-indigo-50 border border-indigo-100/30 flex items-center justify-center text-indigo-600 shrink-0 mt-0.5">
                    <i data-lucide="message-square" class="w-5 h-5"></i>
                  </div>
                  <div class="space-y-1">
                    <h4 class="font-bold text-slate-950 text-sm font-display">1. User Trigger Event</h4>
                    <p class="text-xs text-slate-500 leading-relaxed font-light">A customer interacts with the frontend widget, chatbot interface, or webhook landing node.</p>
                  </div>
                </div>
                <div class="surface-card p-5 rounded-2xl border border-slate-200 shadow-sm flex gap-4 bg-white">
                  <div class="w-10 h-10 rounded-xl bg-indigo-50 border border-indigo-100/30 flex items-center justify-center text-indigo-600 shrink-0 mt-0.5">
                    <i data-lucide="cpu" class="w-5 h-5"></i>
                  </div>
                  <div class="space-y-1">
                    <h4 class="font-bold text-slate-950 text-sm font-display">2. n8n Routing Logic</h4>
                    <p class="text-xs text-slate-500 leading-relaxed font-light">The incoming payload is mapped, clean data variables are parsed, and API nodes query external datastores.</p>
                  </div>
                </div>
                <div class="surface-card p-5 rounded-2xl border border-slate-200 shadow-sm flex gap-4 bg-white">
                  <div class="w-10 h-10 rounded-xl bg-indigo-50 border border-indigo-100/30 flex items-center justify-center text-indigo-600 shrink-0 mt-0.5">
                    <i data-lucide="database" class="w-5 h-5"></i>
                  </div>
                  <div class="space-y-1">
                    <h4 class="font-bold text-slate-950 text-sm font-display">3. Persistent Record Update</h4>
                    <p class="text-xs text-slate-500 leading-relaxed font-light">Data is written to Google Sheets, PostgreSQL, or Supabase vector tables to ensure historical state logs.</p>
                  </div>
                </div>
                <div class="surface-card p-5 rounded-2xl border border-slate-200 shadow-sm flex gap-4 bg-white">
                  <div class="w-10 h-10 rounded-xl bg-indigo-50 border border-indigo-100/30 flex items-center justify-center text-indigo-600 shrink-0 mt-0.5">
                    <i data-lucide="bell" class="w-5 h-5"></i>
                  </div>
                  <div class="space-y-1">
                    <h4 class="font-bold text-slate-950 text-sm font-display">4. Notification Handoff</h4>
                    <p class="text-xs text-slate-500 leading-relaxed font-light">Notifications are sent immediately to team members via Slack/Email, and confirmation is routed back to the client.</p>
                  </div>
                </div>
              </>
            )}
          </div>
        </div>
        
        <!-- RIGHT: Info Sidebar (col-span-5) -->
        <div class="lg:col-span-5 space-y-8">
          <!-- Tech Stack Card -->
          <div class="ambient-panel bg-white border border-slate-200 rounded-[28px] p-6 md:p-8 space-y-4 shadow-sm">
            <h3 class="text-xs font-bold uppercase text-slate-400 tracking-wider">Technologies Demonstrated</h3>
            <div class="flex flex-wrap gap-1.5 font-sans">
              {tech.map((techItem) => (
                <span class="px-3 py-1 bg-slate-100 border border-slate-200/50 rounded-lg text-[10px] font-semibold text-slate-600 shadow-xs">{techItem}</span>
              ))}
            </div>
          </div>

          <!-- Want This System Card -->
          <div class="bg-slate-950 border border-slate-800 text-white rounded-[32px] p-8 md:p-10 shadow-xl relative overflow-hidden flex flex-col justify-between">
            <div class="absolute -top-12 -right-12 w-40 h-40 bg-indigo-500/10 rounded-full blur-[60px] pointer-events-none"></div>
            
            <div class="relative z-10 space-y-6">
              <div>
                <span class="text-[9px] font-bold uppercase tracking-[0.22em] text-indigo-400 bg-indigo-950 border border-indigo-900 px-2.5 py-0.5 rounded-full">
                  Deployment Scope
                </span>
              </div>

              <div class="space-y-1">
                <h3 class="text-xl font-bold font-display text-white">Need a system like this?</h3>
                <p class="text-xs text-slate-350 leading-relaxed font-sans font-light pt-2">
                  We specialize in building bespoke automation webhooks, Point of Sale dashboards, WhatsApp intake bots, and client booking grids tailored to your data architecture.
                </p>
              </div>
              
              <div class="space-y-2 text-xs text-slate-300 font-sans font-light leading-relaxed pt-2 border-t border-white/10">
                <p>✓ Custom RAG databases & Pinecone integrations.</p>
                <p>✓ Automated lead routing and n8n pipelines.</p>
                <p>✓ Client-side testing sandbox build included.</p>
              </div>
            </div>

            <div class="pt-8 relative z-10">
              <button class="trigger-audit-modal w-full justify-center inline-flex items-center justify-center px-6 py-3.5 bg-[color:var(--accent)] hover:bg-[color:var(--accent-strong)] text-white text-sm font-bold rounded-xl transition shadow-lg cursor-pointer">
                Request Similar Build
                <i data-lucide="sparkles" class="w-4 h-4 ml-2"></i>
              </button>
            </div>
          </div>
          
          <div class="text-center pt-2 font-sans">
            <a href="/portfolio/" class="inline-flex items-center gap-1.5 text-xs text-indigo-650 hover:text-indigo-805 font-bold transition">
              <i data-lucide="arrow-left" class="w-3.5 h-3.5"></i>
              Back to Portfolio Showcase
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Bottom CTA banner -->
  <section class="site-shell py-16 md:py-20" aria-label="Lead funnel conversion banner">
    <div class="bg-white rounded-[36px] border border-slate-200 p-8 md:p-14 text-center space-y-6 shadow-sm relative overflow-hidden font-sans">
      <div class="max-w-2xl mx-auto space-y-6 relative z-10">
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900 font-display">
          Ready to launch a custom automation blueprint?
        </h2>
        <p class="text-xs md:text-sm text-slate-655 max-w-lg mx-auto font-light leading-relaxed">
          Let's schedule a 15-minute Discovery Consultation. We will analyze your workflows, identify manual bottlenecks, and structure a working sandbox.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
          <button class="trigger-audit-modal w-full sm:w-auto inline-flex items-center justify-center px-6 py-3.5 bg-slate-900 hover:bg-slate-800 text-white text-xs font-bold rounded-xl transition shadow cursor-pointer">
            Request Custom Quote
          </button>
          <a href={site.whatsappLink} target="_blank" rel="noopener" class="w-full sm:w-auto inline-flex items-center justify-center px-6 py-3.5 border border-slate-300 text-xs font-bold rounded-xl bg-white text-slate-900 hover:bg-slate-50 transition shadow-xs">
            <i data-lucide="message-circle" class="w-4 h-4 mr-2 text-emerald-600"></i>
            WhatsApp Me
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const auditModal = document.getElementById('audit-modal');
    const openBtns = document.querySelectorAll('.trigger-audit-modal');

    openBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        if (auditModal) {
          auditModal.classList.remove('hidden');
          auditModal.classList.add('flex');
          setTimeout(() => {
            auditModal.classList.remove('opacity-0');
            auditModal.querySelector('.bg-white')?.classList.remove('scale-95');
          }, 10);
        }
      });
    });
  });
</script>
