---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import ServiceIllustration from '../../components/ServiceIllustration.astro';

const collectionServices = (await getCollection('services')).filter(s => !s.id.includes('sample'));

// Custom structured FAQ data matching search engine keywords (H3)
const servicesFaqs = [
  {
    q: "How do n8n and Supabase reduce monthly subscription fees?",
    a: "Traditional automation tools (like Zapier) charge per-task fees that scale rapidly. By deploying custom self-hosted or flat-rate n8n instances connected to Supabase (PostgreSQL), you pay a flat infrastructure fee. This allows you to run millions of automated database tasks and notifications monthly without your bill scaling."
  },
  {
    q: "What is the typical delivery timeline for an automation project?",
    a: "Simple single-path workflows (like an automated lead log) are completed within 5-10 days. Comprehensive business integrations—such as a WhatsApp catalog syncing with a custom Supabase inventory database—typically take 3-4 weeks depending on the complexity of target APIs."
  },
  {
    q: "Do you build custom code or rely solely on low-code platforms?",
    a: "We combine both. We write clean custom code for frontends (using Astro or React) to guarantee maximum speed, security, and search indexing. For backend workflows, we write custom JavaScript or Python logic inside n8n node branches, ensuring flexibility without platform locking."
  },
  {
    q: "How do you handle system maintenance and API updates after launch?",
    a: "Every build comes with 30 days of active post-launch support to resolve any initial edge cases. After that, we offer simple monthly maintenance agreements to manage API changes, review server error logs, and optimize database indexing as your business scales."
  }
];

// Testimonials data with corporate/founder faces
const testimonials = [
  {
    name: "Arsalan Khan",
    role: "E-commerce Founder",
    location: "Khanewal",
    quote: "Our customer response time went from 3 hours to 2 seconds after automating our WhatsApp catalog and order syncing. Sales increased by 35% in the first month.",
    image: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=120&h=120&fit=crop&q=80"
  },
  {
    name: "Sofia Chen",
    role: "SaaS Operator",
    location: "Singapore",
    quote: "The AI Support Chatbot grounded in our docs handles 70% of support queries accurately. The human handoff is seamless and easy.",
    image: "https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=120&h=120&fit=crop&q=80"
  },
  {
    name: "Zubair Sheikh",
    role: "Retail Operations Director",
    location: "Lahore",
    quote: "n8n and Supabase replaced three paid integration tools. Our inventory updates automatically across all outlets without manual errors.",
    image: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=120&h=120&fit=crop&q=80"
  }
];

// 4 Core services with distinct definitions matching slug files
const coreServices = [
  {
    title: "WhatsApp Automation",
    slug: "whatsapp-automation",
    icon: "message-square",
    short: "Build interactive WhatsApp order and customer query flows that reply 24/7 without manual effort.",
    timeline: "10–20 Days (Complex catalog sync & interactive order flows)",
    deliverables: [
      "24/7 automated auto-replies & interactive catalogs",
      "Direct database syncs to Google Sheets or Supabase",
      "n8n-triggered follow-up reminders & customer alerts",
      "Seamless routing to human agents when needed"
    ]
  },
  {
    title: "AI Support Chatbots",
    slug: "ai-support-chatbots",
    icon: "bot",
    short: "Improve support capacity with custom AI chatbots grounded in your facts, featuring human handoff.",
    timeline: "3–4 Weeks (Doc-grounded assistant with pgvector & n8n RAG)",
    deliverables: [
      "A custom-styled chat widget for your website",
      "Secure Supabase Vector database for knowledge docs",
      "n8n workflows connecting OpenAI / Gemini API nodes",
      "Hallucination-free direct answers based on your data"
    ]
  },
  {
    title: "Workflow & n8n Automation",
    slug: "workflow-automation",
    icon: "git-branch",
    short: "Eliminate repetitive tasks by building custom webhooks and robust automation workflows with n8n.",
    timeline: "5–10 Days (API integrations) to 3–4 Weeks (Multi-tool database syncing)",
    deliverables: [
      "End-to-end API integrations connecting your tools",
      "Automated invoice & billing pipeline synchronization",
      "Error-handling & auto-retry webhook scripts",
      "Real-time notifications sent to Slack or WhatsApp"
    ]
  },
  {
    title: "Business Websites & SaaS MVPs",
    slug: "business-websites",
    icon: "globe",
    short: "Professional, clean, credibility-building websites that convert visitors and load instantly.",
    timeline: "2–4 Weeks (High-speed Astro sites & Supabase schemas)",
    deliverables: [
      "High-speed Astro or Next.js static architectures",
      "100/100 Google PageSpeed scores & SEO readiness",
      "Relational Supabase database configuration",
      "Interactive lead-capture contact funnel forms"
    ]
  }
];

// Filter other services to list below core services if any
const otherServices = collectionServices.filter(s => {
  const slug = s.id.replace(/\.md$/, '');
  return !coreServices.map(cs => cs.slug).includes(slug);
});

// JSON-LD ItemList / Service schema for search optimization
const servicesSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "BismillahTC Digital Services — Smesh.Dev Service Menu",
  "description": "Premium automation, custom n8n integration, grounded AI support chatbots, and high-performance Astro/Next.js websites.",
  "itemListElement": coreServices.map((service, idx) => ({
    "@type": "ListItem",
    "position": idx + 1,
    "item": {
      "@type": "Service",
      "name": service.title,
      "description": service.short,
      "provider": {
        "@type": "ProfessionalService",
        "name": "Smesh.Dev",
        "url": "https://smesh.dev"
      }
    }
  }))
};
---

<BaseLayout title="Business Automation, Custom n8n & AI Chatbot Services" description="Bespoke n8n workflow automation, grounded AI support chatbots (RAG), Supabase database integrations, and high-performance business web development." schemaType="service">
  <!-- FAQPage JSON-LD in head slot -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do n8n and Supabase reduce monthly subscription fees?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Traditional automation tools like Zapier charge per-task fees. By deploying self-hosted n8n connected to Supabase PostgreSQL, you pay a flat infrastructure fee and run millions of tasks monthly without scaling costs."
        }
      },
      {
        "@type": "Question",
        "name": "Can you integrate custom OpenAI assistants with WhatsApp?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. We build n8n workflows that connect OpenAI or Gemini APIs to WhatsApp Business Cloud API, creating AI-powered reply bots grounded in your business documents."
        }
      },
      {
        "@type": "Question",
        "name": "Do I own the code and Supabase schemas after delivery?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "100% yes. All n8n workflows, Supabase database schemas, and frontend code are handed over completely. You retain full ownership with no vendor lock-in."
        }
      },
      {
        "@type": "Question",
        "name": "What is the typical delivery timeline for an automation project?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Simple API workflows take 5-10 days. WhatsApp automation takes 10-20 days. AI chatbots and SaaS MVPs take 3-4 weeks depending on complexity."
        }
      }
    ]
  })} />

  <!-- ItemList Service Schema in head slot -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Smesh.Dev Services",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "WhatsApp Automation",
        "url": "https://smesh.dev/services/whatsapp-automation/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "AI Support Chatbots",
        "url": "https://smesh.dev/services/ai-support-chatbots/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "Workflow & n8n Automation",
        "url": "https://smesh.dev/services/workflow-automation/"
      },
      {
        "@type": "ListItem",
        "position": 4,
        "name": "Business Websites & SaaS MVPs",
        "url": "https://smesh.dev/services/business-websites/"
      }
    ]
  })} />

  <!-- Section 1: Hero Section (The Hook) -->
  <section class="site-shell py-20 md:py-28 text-center space-y-8 bg-gradient-to-b from-teal-50/10 via-transparent to-transparent" aria-label="Services Hero Banner">
    <div class="max-w-4xl mx-auto space-y-6">
      <span class="px-3.5 py-1 rounded-full bg-[color:var(--accent-soft)] text-[color:var(--accent-strong)] text-xs font-bold uppercase tracking-wider font-sans">
        Custom n8n & Supabase Solutions
      </span>
      <h1 class="display-title text-slate-900 text-4xl md:text-6xl font-extrabold tracking-tight leading-[1.08]">
        Automate Your Manual Workflows to Scale Operations
      </h1>
      <p class="body-copy max-w-2xl mx-auto text-base md:text-lg font-light text-slate-600 leading-relaxed">
        We integrate your software tools, ground AI support chatbots, and build high-converting web frontends to eliminate repetitive admin work and unlock revenue.
      </p>
    </div>

    <div class="flex flex-wrap justify-center gap-4 pt-4 font-sans">
      <button class="trigger-audit-modal button-primary px-8 py-3.5 rounded-xl text-sm font-bold shadow-md cursor-pointer">
        Book a Free Consultation
        <i data-lucide="sparkles" class="h-4 w-4 ml-1.5"></i>
      </button>
      <a href="#services-matrix" class="button-secondary px-8 py-3.5 rounded-xl text-sm font-bold text-slate-800">
        View All Services
        <i data-lucide="arrow-down" class="h-4 w-4 ml-1.5 text-slate-400"></i>
      </a>
    </div>

    <!-- Social Proof Brand Logo Wall -->
    <div class="pt-12 max-w-3xl mx-auto">
      <p class="text-[10px] uppercase tracking-[0.2em] text-slate-400 font-bold font-sans text-center mb-6">
        Powering integrations across modern platforms
      </p>
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12 opacity-40 grayscale hover:opacity-75 transition duration-355">
        <!-- n8n logo -->
        <span class="text-xs font-bold font-mono tracking-tighter text-slate-900 flex items-center gap-1.5">
          <i data-lucide="git-branch" class="w-4.5 h-4.5"></i> n8n.io
        </span>
        <!-- Supabase logo -->
        <span class="text-xs font-bold font-mono tracking-tighter text-slate-900 flex items-center gap-1.5">
          <i data-lucide="database" class="w-4.5 h-4.5"></i> Supabase
        </span>
        <!-- OpenAI logo -->
        <span class="text-xs font-bold font-mono tracking-tighter text-slate-900 flex items-center gap-1.5">
          <i data-lucide="cpu" class="w-4.5 h-4.5"></i> OpenAI
        </span>
        <!-- Stripe logo -->
        <span class="text-xs font-bold font-mono tracking-tighter text-slate-900 flex items-center gap-1.5">
          <i data-lucide="credit-card" class="w-4.5 h-4.5"></i> Stripe
        </span>
        <!-- WhatsApp logo -->
        <span class="text-xs font-bold font-mono tracking-tighter text-slate-900 flex items-center gap-1.5">
          <i data-lucide="message-square" class="w-4.5 h-4.5"></i> WhatsApp
        </span>
        <!-- Google API logo -->
        <span class="text-xs font-bold font-mono tracking-tighter text-slate-900 flex items-center gap-1.5">
          <i data-lucide="globe" class="w-4.5 h-4.5"></i> Google APIs
        </span>
      </div>
    </div>
  </section>

  <!-- Section 2: Pain Point & Solution (The Connection) -->
  <section class="site-shell py-16 md:py-24 border-t border-slate-200/50 bg-white/40 rounded-[36px] my-6" aria-label="Pain Point and Solution Narrative">
    <div class="grid gap-12 lg:grid-cols-[1fr_1.1fr] lg:items-center">
      <div class="space-y-6">
        <span class="text-xs font-semibold uppercase tracking-[0.2em] text-rose-600 bg-rose-50 border border-rose-100/50 px-3 py-1 rounded-full font-sans">
          The Problem
        </span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-slate-955 leading-tight">
          Slowing Down Due to Copy-Paste Bottlenecks?
        </h2>
        <p class="body-copy text-slate-650 leading-relaxed font-light">
          Most growing businesses waste hours daily moving lead info from Facebook to Google Sheets, sending shipping codes manually on WhatsApp, or copy-pasting customer details into databases.
        </p>
        <p class="body-copy text-slate-650 leading-relaxed font-light">
          This manual lag doesn't just exhaust your team—it costs you sales. Leads left waiting for more than 15 minutes convert at a fraction of the rate.
        </p>
      </div>

      <div class="ambient-panel rounded-[32px] p-8 md:p-10 border border-slate-200 bg-white/80 shadow-md space-y-6">
        <span class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--accent-strong)] bg-[color:var(--accent-soft)] px-3 py-1 rounded-full font-sans">
          Our Solution
        </span>
        <h3 class="text-2xl font-bold text-slate-955 leading-tight">
          Lightweight, Grounded Automation Hubs
        </h3>
        <p class="body-copy text-slate-650 leading-relaxed font-light">
          We architect secure backend logic using <strong>n8n workflows</strong> and <strong>Supabase (PostgreSQL)</strong>. Your tools connect directly and securely. 
        </p>
        <p class="body-copy text-slate-650 leading-relaxed font-light">
          No monthly subscription spikes based on task volume. You get custom, blazing-fast static frontends and automated database pipelines that run smoothly 24/7.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 3: Core Services Grid (The Menu) -->
  <section id="services-matrix" class="site-shell py-16 md:py-24 border-t border-slate-100" aria-label="Our Core Services">
    <div class="space-y-4 mb-14 text-center max-w-2xl mx-auto">
      <span class="section-kicker">Core Service Offerings</span>
      <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 leading-tight">
        Grounded automation systems engineered for growth.
      </h2>
    </div>

    <!-- Core Grid -->
    <div class="grid gap-8 md:grid-cols-2">
      {coreServices.map((service) => (
        <article class="surface-card rounded-[32px] p-6 md:p-8 border border-slate-200 bg-white shadow-sm hover:shadow-lg transition-all duration-300 flex flex-col justify-between">
          <div class="space-y-6">
            <div class="flex items-center justify-between">
              <ServiceIllustration slug={service.slug} class="w-20 h-20 border border-slate-200 bg-white" />
              <span class="chip capitalize font-sans text-[10px] font-bold bg-slate-50 border border-slate-200">Featured Service</span>
            </div>

            <div class="space-y-3">
              <h3 class="text-2xl font-bold text-slate-955 leading-snug">
                <a href={`/services/${service.slug}/`} class="hover:text-[color:var(--accent-strong)] transition">{service.title}</a>
              </h3>
              <p class="text-xs text-slate-550 leading-relaxed min-h-[48px] font-light">{service.short}</p>
            </div>

            <!-- Timeline details -->
            <div class="space-y-2 pt-6 border-t border-slate-100 font-sans">
              <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Delivery Timeline</p>
              <div class="flex items-center gap-2 text-xs text-slate-700">
                <i data-lucide="clock" class="h-4 w-4 text-[color:var(--accent-strong)] shrink-0"></i>
                <span class="font-medium">{service.timeline}</span>
              </div>
            </div>

            <!-- Deliverables checklist -->
            <div class="space-y-3 pt-4 border-t border-slate-100 font-sans">
              <p class="text-[10px] font-bold uppercase tracking-wider text-slate-400">Core Deliverables</p>
              <ul class="space-y-3">
                {service.deliverables.map((item) => (
                  <li class="flex items-start gap-2.5 text-xs text-slate-600 leading-normal font-light">
                    <i data-lucide="check" class="h-4 w-4 text-[color:var(--accent-strong)] shrink-0 mt-0.5"></i>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>

          <!-- Actions -->
          <div class="mt-8 pt-6 border-t border-slate-100 flex items-center justify-between font-sans">
            <a 
              href={`/services/${service.slug}/`} 
              class="inline-flex h-10 px-4 items-center justify-center rounded-xl border border-slate-200 text-slate-700 hover:bg-slate-55 text-xs font-bold transition"
            >
              Learn More
            </a>
            <button 
              data-book-service={service.title} 
              class="book-service-btn inline-flex h-10 px-5 items-center justify-center rounded-xl bg-slate-900 hover:bg-slate-800 text-white text-xs font-bold transition cursor-pointer"
            >
              Book Project
            </button>
          </div>
        </article>
      ))}
    </div>

    <!-- Other Services Listing -->
    {otherServices.length > 0 && (
      <div class="mt-16 pt-10 border-t border-slate-100 space-y-8">
        <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400 font-sans text-center">⚡ Additional Specialized Integrations</h3>
        <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3">
          {otherServices.map((service) => {
            const title = service.data.title;
            const slug = service.id.replace(/\.md$/, '');
            const short = service.data.hero_sub || service.data.description || 'Custom tailored backend workflow system.';
            const icon = service.data.icon || service.data.hero_icon || 'cpu';
            return (
              <a href={`/services/${slug}/`} class="group p-5 bg-white rounded-2xl border border-slate-200 shadow-sm hover:shadow transition flex items-start gap-4">
                <ServiceIllustration slug={slug} class="w-10 h-10 border border-slate-150 transition" />
                <div>
                  <h4 class="text-xs font-bold text-slate-950 group-hover:text-[color:var(--accent-strong)] transition">{title}</h4>
                  <p class="text-[10px] text-slate-450 mt-1 line-clamp-2 leading-relaxed font-light">{short}</p>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    )}
  </section>

  <!-- Section 4: How It Works (The Process Timeline) -->
  <section class="site-shell py-16 md:py-24 border-t border-slate-100" aria-label="Our Project Delivery Workflow">
    <div class="max-w-4xl mx-auto space-y-16">
      <div class="text-center space-y-3">
        <span class="section-kicker">Operational Delivery Process</span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 leading-tight">
          How we build your operational nervous system.
        </h2>
        <p class="text-xs text-slate-500 max-w-sm mx-auto">
          No layers of agency management. Direct developer-to-owner construction.
        </p>
      </div>

      <!-- Timeline Steps -->
      <div class="grid gap-8 md:grid-cols-3 relative font-sans">
        <!-- Connecting Line for Desktop -->
        <div class="hidden md:block absolute top-[52px] left-[15%] right-[15%] h-[1px] bg-slate-200 -z-10"></div>

        <!-- Step 1 -->
        <div class="relative space-y-4 text-center md:text-left bg-white/40 border border-slate-200 p-6 rounded-[24px] shadow-sm">
          <div class="mx-auto md:mx-0 w-11 h-11 rounded-full bg-[color:var(--accent-strong)] text-white text-sm font-bold flex items-center justify-center shadow-sm">
            1
          </div>
          <h3 class="font-bold text-slate-900 text-sm pt-2">Discovery & Flow Mapping</h3>
          <p class="text-xs text-slate-550 leading-relaxed font-light">
            We hold a WhatsApp call to trace your manual bottlenecks node-by-node, creating a clear automation map.
          </p>
        </div>

        <!-- Step 2 -->
        <div class="relative space-y-4 text-center md:text-left bg-white/40 border border-slate-200 p-6 rounded-[24px] shadow-sm">
          <div class="mx-auto md:mx-0 w-11 h-11 rounded-full bg-[color:var(--accent-strong)] text-white text-sm font-bold flex items-center justify-center shadow-sm">
            2
          </div>
          <h3 class="font-bold text-slate-900 text-sm pt-2">Structured Build & Sync</h3>
          <p class="text-xs text-slate-550 leading-relaxed font-light">
            We code the database schemas in Supabase and construct automated backend pipelines in n8n, syncing in real-time.
          </p>
        </div>

        <!-- Step 3 -->
        <div class="relative space-y-4 text-center md:text-left bg-white/40 border border-slate-200 p-6 rounded-[24px] shadow-sm">
          <div class="mx-auto md:mx-0 w-11 h-11 rounded-full bg-[color:var(--accent-strong)] text-white text-sm font-bold flex items-center justify-center shadow-sm">
            3
          </div>
          <h3 class="font-bold text-slate-900 text-sm pt-2">Handover & Support Gate</h3>
          <p class="text-xs text-slate-550 leading-relaxed font-light">
            We deploy to your live channels, provide a customized Loom tutorial, hand over keys, and kick off the 30-day support window.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Table Section -->
  <section class="site-shell py-16 md:py-24 border-t border-slate-100" aria-label="Services Pricing Matrix">
    <div class="space-y-4 mb-12 text-center max-w-2xl mx-auto">
      <span class="section-kicker">Transparent Pricing</span>
      <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 leading-tight">
        Simple, predictable pricing.
      </h2>
      <p class="body-copy max-w-xl text-slate-655 font-light mx-auto">
        No hidden fees. Flat project rates. Hosted on your infrastructure so you own 100% of the system.
      </p>
    </div>

    <!-- Table Container -->
    <div class="overflow-x-auto border border-slate-200 rounded-[24px] bg-white/70 backdrop-blur-md">
      <table class="w-full text-left border-collapse font-sans text-xs sm:text-sm">
        <thead>
          <tr class="border-b border-slate-200 bg-slate-50/50 text-[10px] font-bold uppercase tracking-wider text-slate-500">
            <th class="p-6">Service Type</th>
            <th class="p-6">Est. Timeline</th>
            <th class="p-6">Price Range</th>
            <th class="p-6">Ideal For</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 text-slate-600 font-light">
          <tr>
            <td class="p-6 font-bold text-slate-900">Workflow & n8n Automation</td>
            <td class="p-6">5–10 Days</td>
            <td class="p-6 font-mono text-[color:var(--accent-strong)] font-semibold">$500 - $1,200</td>
            <td class="p-6">Connecting APIs, automated invoice syncing, order logging.</td>
          </tr>
          <tr>
            <td class="p-6 font-bold text-slate-900">WhatsApp Automation</td>
            <td class="p-6">10–20 Days</td>
            <td class="p-6 font-mono text-[color:var(--accent-strong)] font-semibold">$800 - $2,000</td>
            <td class="p-6">Interactive WhatsApp catalogs, order bots, custom triggers.</td>
          </tr>
          <tr>
            <td class="p-6 font-bold text-slate-900">AI Support Chatbots (RAG)</td>
            <td class="p-6">3–4 Weeks</td>
            <td class="p-6 font-mono text-[color:var(--accent-strong)] font-semibold">$1,500 - $3,500</td>
            <td class="p-6">Doc-grounded AI assistant with pgvector & n8n workflow fallback.</td>
          </tr>
          <tr>
            <td class="p-6 font-bold text-slate-900">Business Websites & SaaS MVPs</td>
            <td class="p-6">2–4 Weeks</td>
            <td class="p-6 font-mono text-[color:var(--accent-strong)] font-semibold">$2,000 - $4,500</td>
            <td class="p-6">Blazing-fast Astro websites, landing pages, database integration.</td>
          </tr>
        </tbody>
      </table>
    </div>
