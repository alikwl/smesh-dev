<!-- Booking & Testimonials Script -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const bookBtns = document.querySelectorAll('.book-service-btn');

    bookBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const serviceName = btn.getAttribute('data-book-service') || '';
        let targetValue = 'Something else';
        if (serviceName.includes('WhatsApp')) targetValue = 'WhatsApp Bot';
        else if (serviceName.includes('Chatbot') || serviceName.includes('AI')) targetValue = 'AI Chatbot';
        else if (serviceName.includes('Workflow') || serviceName.includes('Automation')) targetValue = 'n8n Workflow';
        else if (serviceName.includes('SaaS') || serviceName.includes('MVP')) targetValue = 'SaaS/MVP';
        else if (serviceName.includes('Extension')) targetValue = 'Chrome Extension';

        // Check the matching checkbox inside the modal contact form
        const modalFormContainer = document.querySelector('#audit-modal .smesh-contact-form-container');
        if (modalFormContainer) {
          const checkbox = modalFormContainer.querySelector(`input[name="services"][value="${targetValue}"]`) as HTMLInputElement | null;
          if (checkbox) {
            checkbox.checked = true;
            checkbox.dispatchEvent(new Event('change'));
          }
        }

        // Programmatically trigger modal open
        const triggerBtn = document.querySelector('.trigger-audit-modal') as HTMLElement | null;
        triggerBtn?.click();
      });
    });

    // Testimonials Carousel Logic
    const slider = document.getElementById('testimonials-slider');
    const prevBtn = document.getElementById('testimonial-prev-btn');
    const nextBtn = document.getElementById('testimonial-next-btn');
    const dots = document.querySelectorAll('.testimonial-dot');
    
    if (slider && dots.length > 0) {
      let currentIndex = 0;
      const totalSlides = dots.length;
      
      const updateSlider = (index: number) => {
        currentIndex = index;
        if (slider) {
          slider.style.transform = `translateX(-${currentIndex * 100}%)`;
        }
        dots.forEach((dot, idx) => {
          if (idx === currentIndex) {
            dot.classList.remove('w-1.5', 'bg-slate-300');
            dot.classList.add('w-4', 'bg-teal-600');
          } else {
            dot.classList.remove('w-4', 'bg-teal-600');
            dot.classList.add('w-1.5', 'bg-slate-300');
          }
        });
      };
      
      prevBtn?.addEventListener('click', () => {
        let prevIndex = currentIndex - 1;
        if (prevIndex < 0) prevIndex = totalSlides - 1;
        updateSlider(prevIndex);
      });
      
      nextBtn?.addEventListener('click', () => {
        let nextIndex = (currentIndex + 1) % totalSlides;
        updateSlider(nextIndex);
      });
      
      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          const index = parseInt(dot.getAttribute('data-index') || '0', 10);
          updateSlider(index);
        });
      });
    }
  });
</script>
