---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SmartImage from '../../components/SmartImage.astro';
import { getAllPortfolio, getAllDemos } from '../../lib/supabase';

const portfolioItems = await getAllPortfolio();
const demos = await getAllDemos();

// Exclude sample portfolio template if present
const filteredPortfolio = portfolioItems.filter(item => item.slug !== 'sample-portfolio');

const demoImageMap: Record<string, string> = {
  'whatsapp-order-system': '/assets/images/whatsapp-phone-mockup.png',
  'ai-support-chatbot': '/assets/images/ai-network-illustration.png',
  'booking-dashboard': '/assets/images/calendar-booking-mockup.png',
  'pos-inventory-dashboard': '/assets/images/saas-dashboard-illustration.png',
  'saas-mvp-dashboard': '/assets/images/saas-dashboard-illustration.png',
  'lead-capture-workflow': '/assets/images/automation-workflow-illustration.png',
};
---

<BaseLayout title="Portfolio & Systems Showcase" description="Explore Smesh.Dev's case studies, web systems, and interactive automation playgrounds demonstrating scalable operational growth.">
  
  <!-- Hero Section -->
  <section class="site-shell py-20 md:py-28 text-center space-y-6" aria-label="Introduction Hero">
    <div class="max-w-4xl mx-auto space-y-6">
      <span class="section-kicker">
        <i data-lucide="award" class="w-3.5 h-3.5"></i>
        Proven Implementations
      </span>
      <h1 class="display-title text-slate-955 font-extrabold tracking-tight leading-[1.08] font-display">
        Systems Built. Workflows Automated. Results Delivered.
      </h1>
      <p class="body-copy max-w-2xl mx-auto text-slate-655 leading-relaxed font-light">
        Discover how BismillahTC Digital Services transforms complex business requirements into elegant static applications and live pipelines.
      </p>
    </div>
  </section>

  <!-- The Portfolio Showcase Grid (Dynamic Consistent 4:3 Entries) -->
  <section class="site-shell pb-24" aria-label="Portfolio Case Studies">
    <div class="space-y-4 mb-14">
      <span class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--accent-strong)] font-sans">
        Deployments & Metrics
      </span>
      <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 leading-tight font-display">
        Real-world scalability at work.
      </h2>
    </div>

    <!-- Clean, Consistent 3-Column Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
      {filteredPortfolio.map((project) => {
        const slug = project.slug;
        const image = project.cover_image || '/assets/images/placeholder.png';
        const client = project.client_type || 'Enterprise';
        const description = project.description || '';
        const problem = description;
        const techList = project.tech_stack || [];
        
        const hasLiveLink = false;
        const projectUrl = `/portfolio/${slug}/`;
        const linkText = "Read Case Study";
        const linkIcon = "arrow-up-right";

        return (
          <article class="surface-card rounded-[32px] overflow-hidden border border-slate-200 bg-white/70 backdrop-blur-md shadow-sm hover:shadow-lg transition-all duration-300 flex flex-col justify-between group">
            <div class="flex flex-col h-full w-full">
              <!-- Thumbnail Wrapper (Strictly aspect-ratio 4:3) -->
              <div class="relative overflow-hidden aspect-[4/3] shrink-0 bg-slate-100/50 border-b border-slate-200">
                <SmartImage src={image} alt={`${project.title} Case Study Image`} class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500" />
              </div>

              <!-- Card Content details -->
              <div class="p-6 md:p-8 flex flex-col justify-between flex-grow space-y-6">
                <div class="space-y-4">
                  <div class="flex items-center justify-between">
                    <span class="chip text-[10px] font-sans font-bold capitalize">
                      {client}
                    </span>
                  </div>

                  <h3 class="text-lg font-bold text-slate-950 leading-snug font-display group-hover:text-[color:var(--accent-strong)] transition-colors">{project.title}</h3>
                  
                  <!-- Problem vs Solution breakdown -->
                  <div class="space-y-4 text-xs font-sans">
                    <div class="space-y-1">
                      <span class="text-[9px] uppercase tracking-wider font-bold text-slate-400">The Case Study Context</span>
                      <p class="text-slate-655 leading-relaxed font-light line-clamp-3">{problem}</p>
                    </div>
                  </div>
                </div>

                <!-- Tech Badges & CTA Link -->
                <div class="space-y-4 pt-4 border-t border-slate-100">
                  {techList.length > 0 && (
                    <div class="flex flex-wrap gap-1.5 font-sans">
                      {techList.map((tech) => (
                        <span class="px-2.5 py-0.5 rounded bg-slate-100 border border-slate-200/50 text-[9px] font-medium text-slate-500">{tech}</span>
                      ))}
                    </div>
                  )}

                  <div class="pt-2 flex items-center justify-between font-sans">
                    <a href={projectUrl} class="inline-flex items-center text-xs font-bold text-indigo-650 hover:text-indigo-850 transition">
                      {linkText}
                      <i data-lucide={linkIcon} class="w-3.5 h-3.5 ml-1"></i>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <!-- Live Interactive Demos Grid (The Playground) -->
  <section class="border-t border-slate-200/60 bg-slate-50/40 py-24" aria-label="Interactive Proof-of-Concepts">
    <div class="site-shell">
      <div class="space-y-4 mb-14">
        <span class="text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--accent-strong)] font-sans">
          Interactive Sandboxes
        </span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 leading-tight font-display">
          Interactive Proof-of-Concepts
        </h2>
        <p class="body-copy max-w-xl text-slate-655 font-light">
          Test our simulated live applications directly in your browser. Click through the steps to see automated catalog updates, chat workflows, and instant data integrations.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {demos.map((demo) => {
          const slug = demo.slug;
          const demoImage = demo.cover_image || demoImageMap[slug] || '/assets/images/placeholder.png';
          const tech = demo.tech || [];
          return (
            <article class="surface-card rounded-[32px] border border-slate-200 bg-white/70 backdrop-blur-md p-6 md:p-8 flex flex-col justify-between hover:shadow-lg hover:border-[color:var(--accent-strong)] transition-all duration-300 relative group">
              <!-- Live status indicator -->
              <div class="absolute top-6 right-6 flex items-center gap-1.5 z-10">
                <span class="live-dot h-2 w-2 rounded-full bg-emerald-500"></span>
                <span class="text-[9px] font-bold uppercase tracking-wider text-emerald-700 bg-emerald-50 border border-emerald-100/50 px-2.5 py-0.5 rounded-full">Live Demo</span>
              </div>

              <div class="space-y-5">
                <!-- Thumbnail -->
                <div class="w-16 h-16 rounded-[20px] border border-slate-200/60 overflow-hidden bg-slate-50 flex items-center justify-center p-0.5">
                  <SmartImage src={demoImage} alt={`${demo.title} Thumbnail`} class="w-full h-full object-cover rounded-[17px]" />
                </div>

                <div class="space-y-2">
                  <span class="text-[9px] uppercase tracking-widest text-[color:var(--accent-strong)] font-bold font-sans">{demo.category || 'Automation'}</span>
                  <h3 class="text-lg font-bold text-slate-900 leading-snug font-display">{demo.title}</h3>
                  <p class="text-xs text-slate-600 leading-relaxed font-light line-clamp-3">{demo.description}</p>
                </div>

                <!-- Tech Badges -->
                {tech.length > 0 && (
                  <div class="flex flex-wrap gap-1.5 pt-2">
                    {tech.map((t) => (
                      <span class="px-2.5 py-0.5 rounded-md bg-slate-100/80 border border-slate-200/50 text-[9px] font-medium text-slate-500 font-sans">{t}</span>
                    ))}
                  </div>
                )}
              </div>

              <div class="mt-8 pt-4 border-t border-slate-100 flex items-center justify-between font-sans">
                <span class="text-[10px] font-mono text-slate-400">Simulation: Active</span>
                <a href={`/demos/${slug}/`} class="inline-flex h-9 px-4 items-center justify-center rounded-xl bg-slate-900 hover:bg-slate-800 text-white text-xs font-bold transition shadow-sm">
                  Test Sandbox
                  <i data-lucide="play" class="w-3.5 h-3.5 ml-1.5 fill-current"></i>
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- The Ultimate CTA Funnel (Next Success Story) -->
  <section class="site-shell py-16 md:py-24" aria-label="Conversion Banner">
    <div class="bg-slate-950 text-white rounded-[40px] p-8 md:p-16 text-center space-y-6 shadow-xl relative overflow-hidden font-sans border border-slate-800">
      <div class="absolute inset-0 bg-gradient-to-tr from-indigo-950/40 to-teal-950/30 pointer-events-none"></div>
      
      <!-- Ambient light effect -->
      <div class="absolute -top-1/2 -left-1/4 w-96 h-96 bg-indigo-500/10 rounded-full blur-[100px] pointer-events-none"></div>
      <div class="absolute -bottom-1/2 -right-1/4 w-96 h-96 bg-teal-500/10 rounded-full blur-[100px] pointer-events-none"></div>
      
      <div class="max-w-2xl mx-auto space-y-6 relative z-10">
        <h2 class="text-3xl md:text-5xl font-extrabold tracking-tight leading-tight font-display">
          Ready to Be Our Next Case Study?
        </h2>
        <p class="text-xs md:text-sm text-slate-300 max-w-md mx-auto font-light leading-relaxed">
          Let's engineer customized automation systems, robust data layers, and sync workflows designed for your business.
        </p>
        <div class="pt-4">
          <button id="portfolio-closer-btn" class="inline-flex items-center justify-center px-8 py-3.5 bg-[color:var(--accent)] hover:bg-[color:var(--accent-strong)] text-white text-sm font-bold rounded-xl transition shadow-lg cursor-pointer">
            Let's Scale Your Business
            <i data-lucide="sparkles" class="h-4 w-4 ml-2"></i>
          </button>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const auditModal = document.getElementById('audit-modal');
    const openBtn = document.getElementById('portfolio-closer-btn');

    if (auditModal && openBtn) {
      openBtn.addEventListener('click', () => {
        auditModal.classList.remove('hidden');
        auditModal.classList.add('flex');
        setTimeout(() => {
          auditModal.classList.remove('opacity-0');
          auditModal.querySelector('.bg-white')?.classList.remove('scale-95');
        }, 10);
      });
    }
  });
</script>
