---
interface Props {
  slug: string;
  resourceTitle: string;
  downloadUrl?: string;
}

const { slug, resourceTitle, downloadUrl = '#' } = Astro.props;
---

<!-- Gated Content Container -->
<div class="resource-gate-wrapper w-full max-w-2xl mx-auto my-8 font-sans" data-slug={slug} data-title={resourceTitle} data-download={downloadUrl}>
  
  <!-- Blocking script to adjust UI immediately on page load for returning visitors (prevents flash) -->
  <script is:inline define:vars={{ slug }}>
    try {
      if (localStorage.getItem(`unlocked_${slug}`)) {
        document.write('<style>#gate-lock-state { display: none !important; } #gate-success-state { display: flex !important; }</style>');
      }
    } catch (e) {
      console.error(e);
    }
  </script>

  <!-- Toast message (hidden by default, positioned fixed) -->
  <div 
    id="unlock-toast" 
    class="fixed bottom-6 right-6 z-50 transform translate-y-12 opacity-0 pointer-events-none transition-all duration-500 bg-emerald-800 text-white px-5 py-3.5 rounded-xl shadow-xl flex items-center gap-2.5 text-xs font-bold font-sans"
  >
    <span class="ti-check text-sm"></span>
    <span>Access link sent to email</span>
  </div>

  <!-- Gate Card Container -->
  <div 
    id="gate-card" 
    class="ambient-panel rounded-3xl p-6 sm:p-10 border border-[color:var(--line)] bg-white/60 backdrop-blur-md shadow-xl transition-all duration-300"
  >
    <!-- 1. Locked State Form (Visible by default) -->
    <div id="gate-lock-state" class="space-y-6">
      <div class="flex flex-col items-center text-center space-y-3">
        <!-- Icon Container -->
        <div class="w-12 h-12 rounded-2xl bg-teal-50 border border-teal-100/50 text-[color:var(--accent)] flex items-center justify-center shrink-0 shadow-sm">
          <span class="ti-lock text-lg" id="gate-lock-icon"></span>
        </div>
        <div class="space-y-1">
          <h3 class="text-base font-bold text-[color:var(--ink)] leading-tight">Unlock system blueprint.</h3>
          <p class="text-xs text-[color:var(--muted)] font-light leading-relaxed max-w-sm">
            Enter your email to receive the download link and configuration credentials directly in your inbox.
          </p>
        </div>
      </div>

      <!-- Form -->
      <form id="gate-form" class="space-y-4">
        <div>
          <label for="gate-email-input" class="block text-[9px] font-bold uppercase tracking-wider text-slate-400 mb-1.5 font-sans">Email Address</label>
          <input 
            type="email" 
            id="gate-email-input"
            required 
            placeholder="you@example.com" 
            class="w-full px-4 py-3 rounded-xl border border-[color:var(--line)] bg-white text-xs focus:border-[color:var(--accent)] focus:outline-none focus:ring-4 focus:ring-[rgba(15,118,110,0.12)] transition font-sans"
          />
        </div>

        <!-- GDPR Checklist -->
        <label class="flex items-start gap-2.5 rounded-xl border border-slate-150 bg-slate-50/50 px-3.5 py-3 text-xs text-slate-500 font-sans cursor-pointer select-none">
          <input 
            id="gate-gdpr-input" 
            type="checkbox" 
            required 
            class="mt-0.5 h-4 w-4 rounded border-slate-350 text-[color:var(--accent)] focus:ring-[rgba(15,118,110,0.12)]" 
          />
          <span class="font-light leading-normal">I agree to receive free weekly resources & updates.</span>
        </label>

        <button 
          type="submit" 
          id="gate-submit-btn" 
          class="w-full bg-[color:var(--accent)] hover:bg-[color:var(--accent-strong)] text-white font-bold py-3.5 rounded-xl text-xs transition flex items-center justify-center cursor-pointer shadow-sm gap-2 select-none font-sans"
        >
          <span id="gate-submit-text">Send Blueprint to Inbox →</span>
          <!-- Loading Spinner -->
          <svg id="gate-spinner" class="hidden animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </button>
      </form>

      <!-- Inline Error -->
      <div id="gate-error-message" class="hidden text-center text-xs text-rose-600 font-semibold leading-tight bg-rose-50 border border-rose-100 py-2.5 rounded-xl">
        Something went wrong &mdash; try again
      </div>

      <!-- Trust Lines -->
      <div class="space-y-1.5 pt-2 select-none border-t border-[color:var(--line)]">
        <span class="text-[10px] text-slate-400 font-light flex items-center gap-1.5 justify-center">
          ✓ Secure delivery &mdash; check inbox in a few moments
        </span>
        <span class="text-[10px] text-slate-400 font-light flex items-center gap-1.5 justify-center">
          ✓ Unsubscribe anytime
        </span>
      </div>
    </div>

    <!-- 2. Success State (Hidden by default) -->
    <div id="gate-success-state" class="hidden flex flex-col items-center text-center space-y-5 py-4 animate-fade-in">
      <!-- Success Envelope Icon -->
      <div class="w-14 h-14 rounded-2xl bg-emerald-50 border border-emerald-100/50 text-emerald-600 flex items-center justify-center shrink-0 shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25H4.5a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
        </svg>
      </div>
      <div class="space-y-2">
        <h3 class="text-base font-bold text-[color:var(--ink)] leading-tight">Blueprint Sent!</h3>
        <p class="text-xs text-[color:var(--muted)] font-light leading-relaxed max-w-sm">
          We have sent the PDF file directly to:
        </p>
        <div class="inline-block bg-teal-50 border border-teal-100/80 text-[color:var(--accent-strong)] text-xs font-semibold px-4 py-1.5 rounded-xl font-mono">
          <span id="success-email-display"></span>
        </div>
        <p class="text-[11px] text-slate-400 font-light leading-relaxed max-w-xs pt-2">
          Please check your email inbox (including the **Spam**, **Promotions**, or **Updates** tab) to access your download link.
        </p>
      </div>

      <button 
        id="success-reset-btn" 
        class="text-[10px] text-slate-400 hover:text-slate-655 underline transition cursor-pointer select-none font-sans mt-3"
      >
        Enter a different email address
      </button>
    </div>
  </div>
</div>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in {
    animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>

<script>
  import { supabase } from '../lib/supabase';

  const initGate = () => {
    const wrapper = document.querySelector('.resource-gate-wrapper');
    if (!wrapper) return;

    const slug = wrapper.getAttribute('data-slug') || '';
    const lockState = document.getElementById('gate-lock-state');
    const successState = document.getElementById('gate-success-state');
    const emailDisplay = document.getElementById('success-email-display');
    const form = document.getElementById('gate-form') as HTMLFormElement | null;
    const emailInput = document.getElementById('gate-email-input') as HTMLInputElement | null;
    const submitBtn = document.getElementById('gate-submit-btn') as HTMLButtonElement | null;
    const submitText = document.getElementById('gate-submit-text');
    const spinner = document.getElementById('gate-spinner');
    const errorMessage = document.getElementById('gate-error-message');
    const toast = document.getElementById('unlock-toast');
    const resetBtn = document.getElementById('success-reset-btn');

    if (!lockState || !successState || !form) return;

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    // Show dynamic success toast
    const showToast = () => {
      if (!toast) return;
      toast.classList.remove('opacity-0', 'translate-y-12', 'pointer-events-none');
      toast.classList.add('opacity-100', 'translate-y-0');

      setTimeout(() => {
        toast.classList.remove('opacity-100', 'translate-y-0');
        toast.classList.add('opacity-0', 'translate-y-12', 'pointer-events-none');
      }, 3500);
    };

    // Transition to success state
    const showSuccess = (email: string, silent: boolean = false) => {
      if (emailDisplay) {
        emailDisplay.textContent = email;
      }
      lockState.classList.add('hidden');
      successState.classList.remove('hidden');
      successState.classList.add('flex');

      // Dispatch global event for other components (e.g. mockup overlay)
      window.dispatchEvent(new CustomEvent('resource-unlocked', { detail: { slug } }));

      if (!silent) {
        showToast();
      }
    };

    // Transition to input state
    const showInputForm = () => {
      localStorage.removeItem(`unlocked_${slug}`);
      if (emailInput) emailInput.value = '';
      successState.classList.add('hidden');
      successState.classList.remove('flex');
      lockState.classList.remove('hidden');
    };

    // Register lead in Supabase
    const submitLead = async (email: string) => {
      // Show loading state
      if (errorMessage) errorMessage.classList.add('hidden');
      if (submitBtn) submitBtn.disabled = true;
      if (submitText) submitText.textContent = 'Sending blueprint...';
      if (spinner) spinner.classList.remove('hidden');

      try {
        const gdprInput = document.getElementById('gate-gdpr-input') as HTMLInputElement | null;
        const gdprConsent = gdprInput ? gdprInput.checked : false;

        // 1. Proactively write download tracking to resource_downloads table
        try {
          const payload = {
            email: email,
            resource_title: wrapper.getAttribute('data-title') || '',
            resource_slug: slug,
            page_url: window.location.href,
            gdpr_consent: gdprConsent,
            created_at: new Date().toISOString()
          };
          await supabase.from('resource_downloads').insert([payload]);
        } catch (err) {
          console.error('Failed to log to resource_downloads:', err);
        }

        // 2. Call Supabase unlock_resource RPC to write to resource_leads
        const { error } = await supabase.rpc('unlock_resource', {
          email_input: email,
          slug_input: slug,
          page_url_input: window.location.href
        });

        if (error) {
          throw error;
        }

        // 3. Cache submission state in localStorage
        localStorage.setItem(`unlocked_${slug}`, JSON.stringify({ 
          email, 
          unlockedAt: Date.now()
        }));

        // 4. Show success screen
        showSuccess(email, false);

      } catch (err) {
        console.error('Failed to register lead:', err);
        // Revert form state and show simple error
        if (submitBtn) submitBtn.disabled = false;
        if (submitText) submitText.textContent = 'Send Blueprint to Inbox →';
        if (spinner) spinner.classList.add('hidden');
        if (errorMessage) {
          errorMessage.textContent = 'Something went wrong — try again';
          errorMessage.classList.remove('hidden');
        }
      }
    };

    // 1. Check if returning visitor has already submitted
    const saved = localStorage.getItem(`unlocked_${slug}`);
    if (saved) {
      try {
        const { email } = JSON.parse(saved);
        if (email && emailRegex.test(email)) {
          showSuccess(email, true);
        } else {
          showInputForm();
        }
      } catch (e) {
        showInputForm();
      }
    }

    // 2. Form Submission Flow
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!emailInput) return;

      const email = emailInput.value.trim();

      // Client-side email validation
      if (!email || !emailRegex.test(email)) {
        if (errorMessage) {
          errorMessage.textContent = 'Please enter a valid email address';
          errorMessage.classList.remove('hidden');
        }
        return;
      }

      await submitLead(email);
    });

    // 3. Reset Button Flow
    if (resetBtn) {
      resetBtn.addEventListener('click', (e) => {
        e.preventDefault();
        showInputForm();
      });
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGate);
  } else {
    initGate();
  }
</script>
