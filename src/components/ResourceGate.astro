---
interface Props {
  slug: string;
  resourceTitle: string;
  downloadUrl?: string;
}

const { slug, resourceTitle, downloadUrl = '#' } = Astro.props;
---

{downloadUrl && downloadUrl !== '#' && (
  <div class="resource-gate-wrapper w-full max-w-2xl mx-auto my-8 font-sans" data-slug={slug} data-title={resourceTitle} data-download={downloadUrl}>
    
    <!-- Download Card Container -->
    <div 
      id="gate-card" 
      class="ambient-panel rounded-3xl p-6 sm:p-10 border border-[color:var(--line)] bg-[color:var(--surface)]/60 backdrop-blur-md shadow-xl transition-all duration-300 flex flex-col items-center text-center space-y-4"
    >
      <!-- Icon Container -->
      <div class="w-12 h-12 rounded-2xl bg-teal-50 border border-teal-100/50 text-[color:var(--accent)] flex items-center justify-center shrink-0 shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
      </div>

      <div class="space-y-1">
        <h3 class="text-base font-bold text-[color:var(--ink)] leading-tight">Download system blueprint</h3>
        <p class="text-xs text-[color:var(--muted)] font-light leading-relaxed max-w-sm">
          Access the configuration files, database schemas, and integration credentials instantly.
        </p>
      </div>

      <!-- Download Button -->
      <a 
        href={downloadUrl} 
        id="download-blueprint-btn" 
        target="_blank"
        rel="noopener noreferrer"
        class="w-full max-w-xs bg-[color:var(--accent)] hover:bg-[color:var(--accent-strong)] text-white font-bold py-3.5 rounded-xl text-xs transition flex items-center justify-center cursor-pointer shadow-sm gap-2 select-none font-sans"
      >
        <span>Download Files &rarr;</span>
      </a>

      <!-- Trust/Info Lines -->
      <div class="space-y-1 pt-2 border-t border-[color:var(--line)] w-full">
        <span class="text-[10px] text-[color:var(--meta)] font-light flex items-center gap-1.5 justify-center">
          ✓ Verified Production Run Blueprint
        </span>
      </div>
    </div>
  </div>
)}

<script>
  const initDownloadTracking = () => {
    const btn = document.getElementById('download-blueprint-btn');
    const wrapper = document.querySelector('.resource-gate-wrapper');
    if (!btn || !wrapper) return;

    const slug = wrapper.getAttribute('data-slug') || '';
    const title = wrapper.getAttribute('data-title') || '';
    
    btn.addEventListener('click', async () => {
      try {
        const payload = {
          email: 'anonymous@smesh.dev',
          resource_title: title,
          resource_slug: slug,
          page_url: window.location.href,
          gdpr_consent: false,
          created_at: new Date().toISOString()
        };
        const { supabase } = await import('../lib/supabase');
        await supabase.from('resource_downloads').insert([payload]);
      } catch (err) {
        console.error('Failed to log to resource_downloads:', err);
      }
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDownloadTracking);
  } else {
    initDownloadTracking();
  }
</script>
