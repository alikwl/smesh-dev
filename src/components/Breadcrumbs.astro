---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<nav class="site-shell py-6 text-xs" aria-label="Breadcrumb">
  <ol class="inline-flex flex-wrap items-center gap-2 rounded-full border border-[color:var(--line)] bg-[color:var(--surface-strong)]/78 px-4 py-2 text-[color:var(--muted)]">
    <li class="inline-flex items-center">
      <a href="/" class="inline-flex items-center transition hover:text-[color:var(--ink)]">
        <i data-lucide="home" class="w-3 h-3 mr-1.5"></i>
        Home
      </a>
    </li>
    <li>
      <div class="flex items-center">
        <i data-lucide="chevron-right" class="mx-1 h-3 w-3 text-[color:var(--muted-soft)]"></i>
        <a href="/services/" class="transition hover:text-[color:var(--ink)]">Services</a>
      </div>
    </li>
    <li aria-current="page">
      <div class="flex items-center">
        <i data-lucide="chevron-right" class="mx-1 h-3 w-3 text-[color:var(--muted-soft)]"></i>
        <span class="font-medium text-[color:var(--ink)]">{title}</span>
      </div>
    </li>
  </ol>
</nav>
