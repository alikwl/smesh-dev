---
import { navigation } from '../data/navigation';

const currentPath = Astro.url.pathname;
const isActive = (url: string) => {
  if (url === '/') return currentPath === '/' || currentPath === '/index.html';
  return currentPath.startsWith(url);
};
---

<header id="site-header" class="sticky top-0 z-50 border-b border-transparent bg-[color:var(--bg-soft)]/88 backdrop-blur-md transition-all duration-300">
  <div class="site-shell">
    <div class="flex min-h-[58px] items-center justify-between gap-3 lg:gap-4">
      <a href="/" class="flex min-w-0 items-center gap-2.5">
        <img src="/assets/logo.png" alt="Smesh.Dev logo" class="h-8 w-8 shrink-0 object-contain" />
        <div class="min-w-0">
          <div class="truncate font-display text-[1.1rem] font-semibold leading-none text-[color:var(--ink)] sm:text-[1.25rem]">Smesh.Dev</div>
          <div class="mt-1 text-[9px] uppercase tracking-[0.2em] text-[color:var(--muted-soft)]">Automation studio</div>
        </div>
      </a>

      <nav class="hidden items-center gap-1 lg:flex">
        {navigation.map((item) => (
          <a
            href={item.url}
            class:list={[
              'rounded-full px-3 py-1.5 text-[13px] font-semibold transition',
              isActive(item.url)
                ? 'bg-white text-[color:var(--ink)] shadow-sm'
                : 'text-[color:var(--muted)] hover:bg-white hover:text-[color:var(--ink)]',
            ]}
          >
            {item.name}
          </a>
        ))}
      </nav>

      <div class="hidden items-center gap-2 md:flex">
        <a href="/contact/" class="button-secondary px-3.5 py-2 text-[13px]">Book call</a>
        <a href="/contact/" class="button-primary px-3.5 py-2 text-[13px]">
          Contact
          <i data-lucide="arrow-up-right" class="h-4 w-4"></i>
        </a>
      </div>

      <button id="mobile-menu-button" type="button" class="inline-flex h-10 w-10 items-center justify-center rounded-[18px] border border-[color:var(--line)] bg-white text-[color:var(--ink)] lg:hidden" aria-controls="mobile-menu" aria-expanded="false">
        <span class="sr-only">Open main menu</span>
        <span id="menu-icon" class="flex h-5 w-5 flex-col items-center justify-center gap-[3px]">
          <span class="block h-[1.8px] w-5 rounded-full bg-current"></span>
          <span class="block h-[1.8px] w-5 rounded-full bg-current"></span>
          <span class="block h-[1.8px] w-5 rounded-full bg-current"></span>
        </span>
        <span id="close-icon" class="hidden relative h-5 w-5">
          <span class="absolute left-1/2 top-1/2 block h-[1.8px] w-5 -translate-x-1/2 -translate-y-1/2 rotate-45 rounded-full bg-current"></span>
          <span class="absolute left-1/2 top-1/2 block h-[1.8px] w-5 -translate-x-1/2 -translate-y-1/2 -rotate-45 rounded-full bg-current"></span>
        </span>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t border-[color:var(--line)] bg-[color:var(--bg-soft)] lg:hidden">
    <div class="site-shell origin-top py-4 transition-all duration-300">
      <div class="grid gap-2">
        {navigation.map((item) =>
          <a href={item.url} class={`block rounded-[22px] px-4 py-3 text-sm font-semibold ${isActive(item.url) ? 'bg-white text-[color:var(--ink)] shadow-sm' : 'surface-card text-[color:var(--muted)]'}`}>
            {item.name}
          </a>
        )}
      </div>

      <div class="mt-4 grid gap-2 sm:grid-cols-2">
        <a href="/contact/" class="button-secondary justify-center">Book call</a>
        <a href="/contact/" class="button-primary justify-center">Contact</a>
      </div>
    </div>
  </div>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');
  const siteHeader = document.getElementById('site-header');
  const mobileLinks = Array.from(mobileMenu?.querySelectorAll('a') ?? []);

  const handleHeaderState = () => {
    if (!siteHeader) return;
    const isScrolled = window.scrollY > 14;
    siteHeader.classList.toggle('shadow-[0_10px_30px_rgba(23,23,19,0.08)]', isScrolled);
    siteHeader.classList.toggle('border-[color:var(--line)]', isScrolled);
    siteHeader.classList.toggle('bg-[color:var(--bg-soft)]/95', isScrolled);
  };

  if (mobileMenuBtn instanceof HTMLButtonElement && mobileMenu) {
    mobileMenuBtn.addEventListener('click', () => {
      const expanded = mobileMenuBtn.getAttribute('aria-expanded') === 'true';
      mobileMenuBtn.setAttribute('aria-expanded', String(!expanded));
      mobileMenu.classList.toggle('hidden');
      mobileMenu.classList.toggle('animate-fade-slide-down');
      menuIcon?.classList.toggle('hidden');
      closeIcon?.classList.toggle('hidden');
    });
  }

  mobileLinks.forEach((link) => {
    link.addEventListener('click', () => {
      if (mobileMenuBtn instanceof HTMLButtonElement && mobileMenu && mobileMenuBtn.getAttribute('aria-expanded') === 'true') {
        mobileMenuBtn.setAttribute('aria-expanded', 'false');
        mobileMenu.classList.add('hidden');
        menuIcon?.classList.remove('hidden');
        closeIcon?.classList.add('hidden');
      }
    });
  });

  handleHeaderState();
  window.addEventListener('scroll', handleHeaderState, { passive: true });
</script>
