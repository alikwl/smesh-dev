---
import { site } from '../data/site';

const serviceLinks = [
  { name: 'AI Support Chatbots', href: '/services/ai-support-chatbots/' },
  { name: 'WhatsApp Automation', href: '/services/whatsapp-automation/' },
  { name: 'Workflow Automation', href: '/services/workflow-automation/' },
  { name: 'SaaS MVP Development', href: '/services/saas-mvp-development/' },
];

const resourceLinks = [
  { name: 'Resources Hub', href: '/resources/' },
  { name: 'Free Blueprints', href: '/resources/n8n-whatsapp-order-workflow/' },
  { name: 'Latest Blog Posts', href: '/blog/' },
];

const legalLinks = [
  { name: 'Privacy Policy', href: '/privacy/' },
  { name: 'Terms of Service', href: '/terms/' },
  { name: 'Disclaimer', href: '/disclaimer/' },
  { name: 'Cookie Policy', href: '/cookie-policy/' },
];

const companyLinks = [
  { name: 'About Us', href: '/about/' },
  { name: 'Contact Us', href: '/contact/' },
];
---

<footer class="border-t border-slate-200 bg-slate-50/50 py-12 md:py-16">
  <div class="site-shell">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-12">
      <!-- Brand & Entity details -->
      <div class="lg:col-span-3 space-y-4">
        <a href="/" class="flex items-center gap-3">
          <img src="/assets/logo.png" alt="" class="h-9 w-9 object-contain" />
          <div>
            <div class="text-lg font-bold text-slate-900 leading-none">Smesh.Dev</div>
            <div class="mt-0.5 text-[9px] uppercase tracking-[0.2em] text-slate-400 font-semibold font-sans">Automation Studio</div>
          </div>
        </a>

        <p class="text-xs leading-relaxed text-slate-500 max-w-sm">
          Smesh.dev is a personal automation studio by <strong>BismillahTC Digital Services</strong>, Khanewal, Pakistan. Managed by lead developer <strong>Haider Ali</strong>, we build custom digital nervous systems for businesses using n8n and Supabase.
        </p>

        <div class="text-[11px] text-slate-400 space-y-1 font-sans">
          <div><strong>WhatsApp:</strong> <a href="https://wa.me/923422222752" target="_blank" rel="noopener" class="hover:text-slate-700 transition">+92 342 2222752</a></div>
          <div><strong>Email:</strong> <a href={`mailto:${site.email}`} class="hover:text-slate-700 transition">{site.email}</a></div>
        </div>

        <!-- SEO Social Graph Anchors -->
        <div class="flex items-center gap-3 pt-2 font-sans" aria-label="Social Profiles">
          <a href="https://github.com/alikwl" target="_blank" rel="me noopener" class="text-slate-400 hover:text-slate-900 transition" aria-label="GitHub Developer Profile">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
              <path d="M9 18c-4.51 2-5-2-7-2" />
            </svg>
          </a>
          <a href="https://wa.me/923422222752" target="_blank" rel="noopener" class="text-slate-400 hover:text-emerald-600 transition" aria-label="WhatsApp Business Contact">
            <i data-lucide="phone-call" class="w-4 h-4"></i>
          </a>
          <!-- developer email is current site.email (ali.kwl@live.com), suggestion: hello@smesh.dev for branding -->
          <a href={`mailto:${site.email}`} class="text-slate-400 hover:text-indigo-650 transition" aria-label="Email Address">
            <i data-lucide="mail" class="w-4 h-4"></i>
          </a>
        </div>
      </div>

      <!-- Links Grid -->
      <div class="grid grid-cols-2 gap-6 sm:grid-cols-4 lg:col-span-6 font-sans">
        <div>
          <div class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400">Services</div>
          <ul class="mt-4 space-y-2.5">
            {serviceLinks.map((link) => (
              <li>
                <a href={link.href} class="text-xs text-slate-500 hover:text-slate-900 transition">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <div class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400">Company</div>
          <ul class="mt-4 space-y-2.5">
            {companyLinks.map((link) => (
              <li>
                <a href={link.href} class="text-xs text-slate-500 hover:text-slate-900 transition">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <div class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400">Resources</div>
          <ul class="mt-4 space-y-2.5">
            {resourceLinks.map((link) => (
              <li>
                <a href={link.href} class="text-xs text-slate-500 hover:text-slate-900 transition">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <div class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400">Legal</div>
          <ul class="mt-4 space-y-2.5">
            {legalLinks.map((link) => (
              <li>
                <a href={link.href} class="text-xs text-slate-500 hover:text-slate-900 transition">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Newsletter Form (Linked to Supabase) -->
      <div class="lg:col-span-3 space-y-4 font-sans">
        <div class="text-[10px] font-bold uppercase tracking-[0.2em] text-slate-400 flex items-center gap-1.5">
          <i data-lucide="mail" class="w-3.5 h-3.5 text-slate-400"></i>
          Join Newsletter
        </div>
        <p class="text-xs text-slate-500 leading-relaxed">Blueprints and setups on n8n and vector setups.</p>
        
        <form id="footer-newsletter-form" class="space-y-2">
          <div class="flex gap-2">
            <input type="email" id="news-email" required placeholder="name@domain.com" class="flex-grow rounded-lg border border-slate-200 bg-white px-3 py-2 text-xs focus:ring-1 focus:ring-slate-900 focus:outline-none">
            <button type="submit" id="news-submit-btn" class="bg-slate-900 hover:bg-slate-800 text-white rounded-lg px-3 flex items-center justify-center transition" aria-label="Subscribe">
              <i data-lucide="arrow-right" class="w-3.5 h-3.5"></i>
            </button>
          </div>
          <p id="news-status-msg" class="text-[10px] text-emerald-600 hidden font-semibold font-sans"></p>
        </form>
      </div>
    </div>

    <!-- Copyright banner -->
    <div class="mt-12 flex flex-col gap-4 border-t border-slate-200 pt-6 text-[11px] text-slate-400 md:flex-row md:items-center md:justify-between font-sans">
      <span>&copy; {new Date().getFullYear()} BismillahTC Digital Services. All rights reserved.</span>
      <span>Engineered for SEO entity mapping, AEO positioning, and automated flow scaling.</span>
    </div>
  </div>
</footer>

<script>
  import { supabase } from '../lib/supabase';

  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('footer-newsletter-form') as HTMLFormElement | null;
    const emailInput = document.getElementById('news-email') as HTMLInputElement | null;
    const submitBtn = document.getElementById('news-submit-btn') as HTMLButtonElement | null;
    const successMsg = document.getElementById('news-status-msg');

    if (!form || !emailInput || !submitBtn) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = emailInput.value.trim();
      if (!email) return;

      submitBtn.disabled = true;
      if (successMsg) {
        successMsg.classList.add('hidden');
        successMsg.textContent = '';
      }

      try {
        const payload = {
          email: email,
          resource_slug: 'footer-newsletter',
          resource_type: 'newsletter',
          created_at: new Date().toISOString()
        };

        const { error } = await supabase.from('email_leads').insert([payload]);
        
        if (error) {
          if (error.code === '23505') {
            if (successMsg) {
              successMsg.textContent = "You're already on our automation list! 🎉";
              successMsg.className = "text-[10px] text-emerald-650 font-bold font-sans";
            }
            const inputContainer = form.querySelector('.flex');
            if (inputContainer) inputContainer.classList.add('hidden');
            return;
          }
          throw error;
        }

        if (successMsg) {
          successMsg.textContent = "✓ Subscribed! Free blueprints are on the way. ⚡";
          successMsg.className = "text-[10px] text-emerald-650 font-bold font-sans";
        }
        const inputContainer = form.querySelector('.flex');
        if (inputContainer) inputContainer.classList.add('hidden');
        form.reset();
      } catch (err) {
        console.error('Newsletter sign-up failed:', err);
        if (successMsg) {
          successMsg.textContent = "Something went wrong.";
          successMsg.className = "text-[10px] text-rose-600 font-semibold font-sans";
        }
      } finally {
        submitBtn.disabled = false;
      }
    });
  });
</script>
