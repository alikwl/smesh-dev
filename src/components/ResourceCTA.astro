---
interface Props {
  resourceId: string;
  resourceSlug: string;
  resourceType: string;
  ctaHeadline: string;
  ctaSubtext: string;
}

const { resourceId, resourceSlug, resourceType, ctaHeadline, ctaSubtext } = Astro.props;

// Standardize resourceType to valid DB values
const validTypes = ['article', 'pdf', 'tool', 'snippet', 'guide', 'prompt', 'newsletter'];
let mappedType = (resourceType || '').toLowerCase().trim();
if (!validTypes.includes(mappedType)) {
  if (mappedType.includes('pdf')) mappedType = 'pdf';
  else if (mappedType.includes('prompt')) mappedType = 'prompt';
  else if (mappedType.includes('snippet')) mappedType = 'snippet';
  else if (mappedType.includes('guide')) mappedType = 'guide';
  else if (mappedType.includes('article')) mappedType = 'article';
  else if (mappedType.includes('tool')) mappedType = 'tool';
  else if (mappedType.includes('newsletter')) mappedType = 'newsletter';
  else mappedType = 'article';
}
---

<div 
  class="resource-cta-card my-12 p-6 sm:p-8 bg-slate-900 text-white border border-slate-800 rounded-3xl shadow-lg relative overflow-hidden font-sans" 
  data-resource-id={resourceId} 
  data-resource-slug={resourceSlug}
  data-resource-type={mappedType}
>
  <!-- Grid/background pattern -->
  <div class="absolute inset-0 opacity-5 bg-[radial-gradient(#fff_1px,transparent_1px)] [background-size:16px_16px] pointer-events-none"></div>

  <div class="card-inner relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
    <!-- Left side text content -->
    <div class="max-w-md space-y-2">
      <div class="text-[10px] font-bold tracking-wider text-[color:var(--accent)] uppercase flex items-center gap-1.5 select-none">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-[color:var(--accent)] animate-pulse"></span>
        GET RESOURCE UPDATES
      </div>
      <h3 class="text-xl font-bold text-white leading-tight">
        {ctaHeadline}
      </h3>
      <p class="text-xs text-slate-400 font-light leading-relaxed">
        {ctaSubtext}
      </p>
    </div>

    <!-- Right side input form -->
    <div class="w-full md:w-auto md:min-w-[320px]">
      <form class="resource-cta-form flex flex-col sm:flex-row gap-3 w-full">
        <input 
          type="email" 
          required 
          placeholder="you@company.com" 
          class="w-full px-4 py-3 rounded-xl border border-slate-700 bg-slate-800 text-slate-200 text-xs focus:border-[color:var(--accent)] focus:outline-none focus:ring-4 focus:ring-[rgba(15,118,110,0.12)] transition font-sans"
        />
        <button 
          type="submit" 
          class="submit-btn bg-[color:var(--accent)] hover:bg-[color:var(--accent-strong)] text-white font-bold px-6 py-3 rounded-xl text-xs transition flex items-center justify-center gap-1.5 shrink-0 select-none font-sans cursor-pointer"
        >
          <span>Send me this</span>
          <!-- Loading Spinner -->
          <svg class="spinner hidden animate-spin h-3.5 w-3.5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </button>
      </form>
      <!-- Interactive status messaging -->
      <div class="message-box hidden mt-3 text-xs font-semibold text-center py-2.5 px-3 rounded-xl transition-all duration-300"></div>
    </div>
  </div>
</div>

<script>
  const initCTA = () => {
    const cards = document.querySelectorAll('.resource-cta-card');
    cards.forEach(card => {
      const form = card.querySelector('.resource-cta-form');
      if (!form || form.getAttribute('data-cta-initialized') === 'true') return;
      form.setAttribute('data-cta-initialized', 'true');

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const resourceId = card.getAttribute('data-resource-id') || '';
        const resourceSlug = card.getAttribute('data-resource-slug') || '';
        const resourceType = card.getAttribute('data-resource-type') || '';
        const input = form.querySelector('input[type="email"]') as HTMLInputElement | null;
        const submitBtn = form.querySelector('.submit-btn') as HTMLButtonElement | null;
        const submitText = submitBtn?.querySelector('span');
        const spinner = submitBtn?.querySelector('.spinner');
        const messageBox = card.querySelector('.message-box') as HTMLDivElement | null;
        const innerContainer = card.querySelector('.card-inner');

        if (!input || !submitBtn || !messageBox || !innerContainer) return;

        const email = input.value.trim();
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

        // 1. Validate email format
        if (!email || !emailRegex.test(email)) {
          messageBox.textContent = "Please enter a valid email";
          messageBox.className = 'message-box block mt-2.5 text-xs text-rose-400 font-semibold text-center bg-rose-950/20 border border-rose-900/30 py-2.5 rounded-xl';
          messageBox.classList.remove('hidden');
          return;
        }

        // Disable input and button while request in flight
        input.disabled = true;
        submitBtn.disabled = true;
        if (submitText) submitText.textContent = 'Sending...';
        if (spinner) spinner.classList.remove('hidden');
        messageBox.classList.add('hidden');

        // Check if resourceId is a valid UUID, otherwise insert NULL (database allows nullable FK)
        const uuidRegex = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
        const dbResourceId = uuidRegex.test(resourceId) ? resourceId : null;

        try {
          const { supabase } = await import('../lib/supabase');
          const { error } = await supabase.from('email_leads').insert([
            {
              email: email,
              resource_id: dbResourceId,
              resource_slug: resourceSlug,
              resource_type: resourceType
            }
          ]);

          if (error) {
            throw error;
          }

          // On success: replace card innerHTML
          card.innerHTML = `<div class="absolute inset-0 opacity-5 bg-[radial-gradient(#fff_1px,transparent_1px)] [background-size:16px_16px] pointer-events-none"></div><div class="relative z-10 flex items-center justify-center py-8 text-emerald-450 font-bold text-xs sm:text-sm font-sans text-center px-4"><p>✓ Blueprint Unlocked! We have sent the direct download link and n8n workflow file to your email. ⚡</p></div>`;
          
          // Log success to console for debugging
          console.log(`Lead captured: ${email} from ${resourceSlug}`);

        } catch (err: any) {
          console.error('Failed to submit lead:', err);

          // Re-enable fields
          input.disabled = false;
          submitBtn.disabled = false;
          if (submitText) submitText.textContent = 'Send me this';
          if (spinner) spinner.classList.add('hidden');

          // Check if unique constraint violation (error code '23505' or duplicate message)
          const isDuplicate = err.code === '23505' || err.message?.includes('duplicate');
          if (isDuplicate) {
            messageBox.textContent = "You're already on the list! 🎉";
            messageBox.className = 'message-box block mt-2.5 text-xs text-amber-400 font-semibold text-center bg-amber-950/20 border border-amber-900/30 py-2.5 rounded-xl';
          } else {
            messageBox.textContent = "Something went wrong. Please try again.";
            messageBox.className = 'message-box block mt-2.5 text-xs text-rose-400 font-semibold text-center bg-rose-950/20 border border-rose-900/30 py-2.5 rounded-xl';
          }
          messageBox.classList.remove('hidden');
        }
      });
    });
  };

  // Run on initial load
  initCTA();

  // Run on DOMContentLoaded
  document.addEventListener('DOMContentLoaded', initCTA);

  // Run on Astro page load (for ViewTransitions compatibility)
  document.addEventListener('astro:page-load', initCTA);
</script>
