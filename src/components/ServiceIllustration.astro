---
interface Props {
  slug: string;
  class?: string;
}

const { slug, class: className = '' } = Astro.props;

// Determine colors and SVG path based on slug
---

<div class:list={["service-illustration-wrapper flex items-center justify-center shrink-0 rounded-2xl overflow-hidden shadow-sm relative group/illus", className]}>
  {slug === 'ai-support-chatbots' && (
    <!-- AI Support Chatbots: Chat bubble + brain/AI network icon in Indigo/Purple -->
    <div class="absolute inset-0 bg-gradient-to-tr from-indigo-500/10 to-purple-500/5"></div>
    <svg class="w-12 h-12 text-indigo-650 relative z-10 transition-transform duration-300 group-hover/illus:scale-105" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Chat Bubble -->
      <path d="M40 24C40 32.8366 32.8366 39 24 39C21.5 39 19.5 38.5 17 37.5L8 40L10.5 31.5C9.5 29 9 27 9 24C9 15.1634 16.1634 9 25 9C33.8366 9 40 15.1634 40 24Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      <!-- Brain/AI Network Nodes -->
      <circle cx="21" cy="20" r="2" fill="currentColor" />
      <circle cx="29" cy="20" r="2" fill="currentColor" />
      <circle cx="25" cy="28" r="2" fill="currentColor" />
      <!-- Connection Lines -->
      <line x1="21" y1="20" x2="25" y2="28" stroke="currentColor" stroke-width="1.5" stroke-dasharray="1 1" />
      <line x1="29" y1="20" x2="25" y2="28" stroke="currentColor" stroke-width="1.5" stroke-dasharray="1 1" />
      <line x1="21" y1="20" x2="29" y2="20" stroke="currentColor" stroke-width="1.5" stroke-dasharray="1 1" />
      <!-- Sparkles/AI Glow -->
      <path d="M34 13L35 15L37 16L35 17L34 19L33 17L31 16L33 15L34 13Z" fill="#a855f7" />
      <path d="M12 29L12.5 30L13.5 30.5L12.5 31L12 32L11.5 31L10.5 30.5L11.5 30L12 29Z" fill="#a855f7" />
    </svg>
  )}

  {slug === 'appointment-booking' && (
    <!-- Appointment Booking: Calendar + clock icon in Emerald/Teal -->
    <div class="absolute inset-0 bg-gradient-to-tr from-emerald-500/10 to-teal-500/5"></div>
    <svg class="w-12 h-12 text-emerald-650 relative z-10 transition-transform duration-300 group-hover/illus:scale-105" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Calendar Body -->
      <rect x="8" y="12" width="32" height="28" rx="4" stroke="currentColor" stroke-width="2" />
      <!-- Calendar Header Bar -->
      <path d="M8 20H40" stroke="currentColor" stroke-width="2" />
      <!-- Binder Rings -->
      <path d="M14 8V14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
      <path d="M34 8V14" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
      <!-- Slots inside Calendar -->
      <rect x="13" y="24" width="4" height="4" rx="1" fill="currentColor" fill-opacity="0.3" />
      <rect x="21" y="24" width="4" height="4" rx="1" fill="currentColor" fill-opacity="0.3" />
      <rect x="29" y="24" width="4" height="4" rx="1" fill="currentColor" fill-opacity="0.3" />
      <rect x="13" y="32" width="4" height="4" rx="1" fill="currentColor" fill-opacity="0.3" />
      <!-- Clock Overlap -->
      <circle cx="31" cy="31" r="9" fill="white" stroke="currentColor" stroke-width="2" />
      <path d="M31 27V31H34" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )}

  {slug === 'business-websites' && (
    <!-- Business Websites: Laptop + website mockup in Blue/Cyan -->
    <div class="absolute inset-0 bg-gradient-to-tr from-blue-500/10 to-sky-500/5"></div>
    <svg class="w-12 h-12 text-blue-650 relative z-10 transition-transform duration-300 group-hover/illus:scale-105" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Laptop Screen -->
      <rect x="9" y="10" width="30" height="22" rx="3" stroke="currentColor" stroke-width="2" />
      <!-- Laptop Base -->
      <path d="M5 34.5C5 33.1193 6.11929 32 7.5 32H40.5C41.8807 32 43 33.1193 43 34.5V36H5V34.5Z" fill="currentColor" fill-opacity="0.1" stroke="currentColor" stroke-width="2" />
      <!-- Keyboard indicator -->
      <path d="M21 34H27" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      <!-- Mock Webpage Grid inside Screen -->
      <rect x="13" y="14" width="22" height="4" rx="1" fill="currentColor" fill-opacity="0.2" />
      <rect x="13" y="21" width="10" height="7" rx="1" fill="currentColor" fill-opacity="0.15" />
      <line x1="26" y1="21" x2="35" y2="21" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      <line x1="26" y1="24" x2="33" y2="24" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      <line x1="26" y1="27" x2="31" y2="27" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
    </svg>
  )}

  {slug === 'whatsapp-automation' && (
    <!-- WhatsApp Automation: Phone + WhatsApp chat bubble in Green/Teal -->
    <div class="absolute inset-0 bg-gradient-to-tr from-green-500/10 to-teal-500/5"></div>
    <svg class="w-12 h-12 text-emerald-600 relative z-10 transition-transform duration-300 group-hover/illus:scale-105" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Phone Frame -->
      <rect x="14" y="8" width="20" height="32" rx="4" stroke="currentColor" stroke-width="2" />
      <path d="M22 36H26" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      <!-- Floating WhatsApp Chat Bubble -->
      <path d="M35 15C39.4183 15 43 18.134 43 22C43 23.75 42.2 25.35 41 26.5L42 30.5L37.5 29.5C36.7 29.8 35.8 30 35 30C30.5817 30 27 26.866 27 22C27 18.134 30.5817 15 35 15Z" fill="white" stroke="currentColor" stroke-width="1.5" />
      <!-- WhatsApp logo phone symbol in bubble -->
      <path d="M33 19.5C32.8 19.3 32.2 19 32.1 19C32 18.9 31.9 18.9 31.8 19.1C31.7 19.2 31.4 19.6 31.3 19.7C31.2 19.8 31.1 19.8 30.9 19.7C30.7 19.6 30.1 19.4 29.4 18.8C28.9 18.3 28.5 17.8 28.4 17.6C28.3 17.4 28.4 17.3 28.5 17.2C28.6 17.1 28.7 17 28.8 16.9C28.9 16.8 28.9 16.7 29 16.6C29.1 16.5 29 16.4 29 16.3C29 16.2 28.7 15.5 28.6 15.2C28.5 14.9 28.3 14.9 28.2 14.9H27.9C27.7 14.9 27.5 15 27.3 15.2C27.1 15.4 26.6 15.9 26.6 16.9C26.6 17.9 27.3 18.9 27.4 19.1C27.5 19.2 28.8 21.2 30.8 22.1C31.3 22.3 31.7 22.4 32 22.5C32.5 22.7 32.9 22.7 33.3 22.6C33.7 22.5 34.6 22 34.8 21.4C35 20.8 35 20.3 34.9 20.2C34.9 20.1 34.8 20 34.6 19.9L33 19.5Z" fill="currentColor" />
    </svg>
  )}

  {slug === 'workflow-automation' && (
    <!-- Workflow & n8n Automation: Gear + connection flows in Orange/Amber -->
    <div class="absolute inset-0 bg-gradient-to-tr from-orange-500/10 to-amber-500/5"></div>
    <svg class="w-12 h-12 text-orange-600 relative z-10 transition-transform duration-300 group-hover/illus:scale-105" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Input Node -->
      <circle cx="12" cy="14" r="5" stroke="currentColor" stroke-width="2" />
      <circle cx="12" cy="14" r="1.5" fill="currentColor" />
      
      <!-- Output Node -->
      <circle cx="36" cy="34" r="5" stroke="currentColor" stroke-width="2" />
      <circle cx="36" cy="34" r="1.5" fill="currentColor" />

      <!-- Center Node (Process/Gear) -->
      <circle cx="24" cy="24" r="6" stroke="currentColor" stroke-width="2" />
      <!-- Gear Teeth -->
      <path d="M24 15V18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      <path d="M24 30V33" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      <path d="M15 24H18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      <path d="M30 24H33" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      
      <!-- Flow Lines -->
      <path d="M17 16L20 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="2 2" />
      <path d="M28 29L31 32" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="2 2" />
      
      <!-- Connection Curve -->
      <path d="M12 19C12 28 20 28 20 28" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      <path d="M28 20C28 20 36 20 36 29" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
    </svg>
  )}

  {slug === 'saas-mvp-development' && (
    <!-- SaaS & MVP Development: Stacked layers in Purple/Rose -->
    <div class="absolute inset-0 bg-gradient-to-tr from-purple-500/10 to-rose-500/5"></div>
    <svg class="w-12 h-12 text-purple-650 relative z-10 transition-transform duration-300 group-hover/illus:scale-105" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Layer 1 (Top) -->
      <path d="M24 8L38 15L24 22L10 15L24 8Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
      <!-- Layer 2 (Middle) -->
      <path d="M10 21.5L24 28.5L38 21.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      <!-- Layer 3 (Bottom) -->
      <path d="M10 28L24 35L38 28" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      
      <!-- Vertical Lines connecting corners -->
      <path d="M10 15V28" stroke="currentColor" stroke-width="1" stroke-dasharray="2 2" />
      <path d="M38 15V28" stroke="currentColor" stroke-width="1" stroke-dasharray="2 2" />
      <path d="M24 22V35" stroke="currentColor" stroke-width="1.5" />
    </svg>
  )}

  {slug === 'dashboards-internal-tools' && (
    <!-- Dashboards & Internal Tools: Web panel + charts in Sky/Violet -->
    <div class="absolute inset-0 bg-gradient-to-tr from-sky-500/10 to-violet-500/5"></div>
    <svg class="w-12 h-12 text-sky-650 relative z-10 transition-transform duration-300 group-hover/illus:scale-105" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Browser Window -->
      <rect x="8" y="10" width="32" height="28" rx="3" stroke="currentColor" stroke-width="2" />
      <!-- Top Dots (Window Buttons) -->
      <circle cx="12" cy="14" r="1" fill="currentColor" />
      <circle cx="15" cy="14" r="1" fill="currentColor" />
      <circle cx="18" cy="14" r="1" fill="currentColor" />
      <!-- Bar Chart inside -->
      <rect x="13" y="24" width="4" height="10" rx="1" fill="currentColor" fill-opacity="0.3" />
      <rect x="19" y="20" width="4" height="14" rx="1" fill="currentColor" fill-opacity="0.6" />
      <rect x="25" y="27" width="4" height="7" rx="1" fill="currentColor" fill-opacity="0.3" />
      <!-- Line Chart Overlay -->
      <path d="M15 22L21 17L27 23L33 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      <circle cx="33" cy="16" r="1.5" fill="currentColor" />
    </svg>
  )}

  {slug === 'pos-inventory-systems' && (
    <!-- POS & Inventory: Cash Register / Database in Rose/Red -->
    <div class="absolute inset-0 bg-gradient-to-tr from-rose-500/10 to-red-500/5"></div>
    <svg class="w-12 h-12 text-rose-650 relative z-10 transition-transform duration-300 group-hover/illus:scale-105" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Shopping Bag -->
      <path d="M14 18V12C14 10 16 8 18 8H30C32 8 34 10 34 12V18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      <rect x="10" y="18" width="28" height="22" rx="4" stroke="currentColor" stroke-width="2" fill="white" />
      <!-- Barcode / Stock Lines -->
      <line x1="16" y1="24" x2="32" y2="24" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      <line x1="16" y1="29" x2="28" y2="29" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      <line x1="16" y1="34" x2="24" y2="34" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      <!-- Checkmark tag -->
      <circle cx="30" cy="31" r="5" fill="#f43f5e" />
      <path d="M28.5 31L29.5 32L32 29.5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  )}

  {slug === 'social-media-lead-automation' && (
    <!-- Social Media Lead Automation: Megaphone/Funnel in Orange/Yellow -->
    <div class="absolute inset-0 bg-gradient-to-tr from-amber-500/10 to-orange-500/5"></div>
    <svg class="w-12 h-12 text-amber-650 relative z-10 transition-transform duration-300 group-hover/illus:scale-105" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Megaphone Body -->
      <path d="M12 18H16L28 10V38L16 30H12C10.8954 30 10 29.1046 10 28V20C10 18.8954 10.8954 18 12 18Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
      <!-- Handle -->
      <path d="M18 30V35C18 36.1046 17.1046 37 16 37C14.8954 37 14 36.1046 14 35" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      <!-- Lead soundwaves / alerts -->
      <path d="M33 16C35 18 36 21 36 24C36 27 35 30 33 32" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      <path d="M38 12C41 15 42 19 42 24C42 29 41 33 38 36" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-dasharray="2 2" />
    </svg>
  )}

  {slug === 'seo-aio-geo-content' && (
    <!-- SEO, AIO & GEO Setup: Target/Search in Fuchsia/Indigo -->
    <div class="absolute inset-0 bg-gradient-to-tr from-fuchsia-500/10 to-indigo-500/5"></div>
    <svg class="w-12 h-12 text-fuchsia-650 relative z-10 transition-transform duration-300 group-hover/illus:scale-105" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Bullseye Target -->
      <circle cx="24" cy="24" r="14" stroke="currentColor" stroke-width="2" />
      <circle cx="24" cy="24" r="9" stroke="currentColor" stroke-width="1.5" stroke-dasharray="2 2" />
      <circle cx="24" cy="24" r="4" fill="currentColor" />
      
      <!-- Magnifying glass overlapping target -->
      <circle cx="34" cy="34" r="6" fill="white" stroke="currentColor" stroke-width="2" />
      <line x1="38" y1="38" x2="43" y2="43" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      <!-- Sparkle/Glow -->
      <path d="M12 12L13 14L15 14.5L13 15L12 17L11 15L9 14.5L11 14L12 12Z" fill="#d946ef" />
    </svg>
  )}

  {slug === 'chrome-extensions' && (
    <!-- Chrome Extensions: Puzzle Piece in Cyan/Blue -->
    <div class="absolute inset-0 bg-gradient-to-tr from-cyan-500/10 to-blue-500/5"></div>
    <svg class="w-12 h-12 text-cyan-600 relative z-10 transition-transform duration-300 group-hover/illus:scale-105" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- Puzzle Piece shape -->
      <path d="M30 16H34C35.1046 16 36 16.8954 36 18V22C38.2091 22 40 23.7909 40 26C40 28.2091 38.2091 30 36 30V34C36 35.1046 35.1046 36 34 36H30C30 38.2091 28.2091 40 26 40C23.7909 40 22 38.2091 22 36H18C16.8954 36 16 35.1046 16 34V30C13.7909 30 12 28.2091 12 26C12 23.7909 13.7909 22 16 22V18C16 16.8954 16.8954 16 18 16H22C22 13.7909 23.7909 12 26 12C28.2091 12 30 13.7909 30 16Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round" fill="white" />
      <circle cx="26" cy="26" r="2.5" fill="currentColor" />
    </svg>
  )}

  {/* Fallback illustration if none of the above matches */}
  {!['ai-support-chatbots', 'appointment-booking', 'business-websites', 'whatsapp-automation', 'workflow-automation', 'saas-mvp-development', 'dashboards-internal-tools', 'pos-inventory-systems', 'social-media-lead-automation', 'seo-aio-geo-content', 'chrome-extensions'].includes(slug) && (
    <div class="absolute inset-0 bg-gradient-to-tr from-slate-200 to-slate-100"></div>
    <svg class="w-12 h-12 text-slate-500 relative z-10 transition-transform duration-300 group-hover/illus:scale-105" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
      <path d="M12 8v8"/>
      <path d="M8 12h8"/>
    </svg>
  )}
</div>
