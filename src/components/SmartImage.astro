---
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  src: string;
  alt?: string;
  class?: string;
  [key: string]: any;
}

const { src, alt = '', class: className = '', ...rest } = Astro.props;

let imageExists = false;
let displaySrc = src;

if (src && typeof src === 'string') {
  // Strip query parameters
  const cleanSrc = src.split('?')[0];
  
  // Resolve path relative to public directory
  const resolvedPath = path.join(process.cwd(), 'public', cleanSrc.startsWith('/') ? cleanSrc : `/${cleanSrc}`);
  
  try {
    imageExists = fs.existsSync(resolvedPath) && fs.statSync(resolvedPath).isFile();
  } catch (e) {
    imageExists = false;
  }
}
---

{imageExists ? (
  <img loading="lazy" src={displaySrc} alt={alt} class={className} {...rest} />
) : (
  <div class:list={["border-2 border-dashed border-rose-300/60 bg-rose-50/40 text-rose-900 p-6 rounded-[24px] flex flex-col items-center justify-center text-center gap-3 min-h-[180px] w-full", className]} {...rest}>
    <div class="flex h-10 w-10 items-center justify-center rounded-full bg-rose-100/80 text-rose-600">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
        <circle cx="9" cy="9" r="2"/>
        <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
      </svg>
    </div>
    <div class="space-y-1">
      <p class="text-xs font-semibold uppercase tracking-[0.16em] text-rose-800">⚠️ Missing Image</p>
      <p class="text-[11px] font-mono text-rose-700 bg-white/60 px-2.5 py-1 rounded-md border border-rose-100">
        public{src.startsWith('/') ? src : `/${src}`}
      </p>
    </div>
  </div>
)}
