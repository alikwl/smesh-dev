---
import { site } from '../data/site';

interface Props {
  isBare?: boolean;
}

const { isBare = false } = Astro.props;
const wrapperClass = isBare ? '' : 'surface-card rounded-[32px] p-6 md:p-8';
const whatsappPrefill = `${site.whatsappLink}?text=${encodeURIComponent('Hi Haider, I want to discuss a website / automation project for my business.')}`;
---

<section id="contact" class:list={[!isBare && 'py-12 md:py-16']}>
  <div class:list={[!isBare && 'site-shell']}>
    <div class={wrapperClass}>
      {!isBare && (
        <div class="mb-7 grid gap-5 lg:grid-cols-[0.94fr_1.06fr] lg:items-end">
          <div>
            <div class="section-kicker">Start a project</div>
            <h2 class="mt-4 text-3xl font-semibold leading-[1.06] text-[color:var(--ink)] sm:text-4xl">Tell me what is slowing the business down, and I will map the shortest path to a working system.</h2>
          </div>
          <div class="grid gap-3 sm:grid-cols-3">
            <div class="rounded-[22px] border border-[color:var(--line)] bg-white/70 p-4">
              <p class="text-[11px] uppercase tracking-[0.18em] text-[color:var(--muted-soft)] font-sans">Response</p>
              <p class="mt-2 text-sm font-semibold text-[color:var(--ink)]">WhatsApp or email follow-up</p>
            </div>
            <div class="rounded-[22px] border border-[color:var(--line)] bg-white/70 p-4">
              <p class="text-[11px] uppercase tracking-[0.18em] text-[color:var(--muted-soft)] font-sans">Scope</p>
              <p class="mt-2 text-sm font-semibold text-[color:var(--ink)]">Web, automation, AI support</p>
            </div>
            <div class="rounded-[22px] border border-[color:var(--line)] bg-white/70 p-4">
              <p class="text-[11px] uppercase tracking-[0.18em] text-[color:var(--muted-soft)] font-sans">Direct line</p>
              <p class="mt-2 text-sm font-semibold text-[color:var(--ink)] font-sans">{site.whatsapp}</p>
            </div>
          </div>
        </div>
      )}

      <!-- Form interactive wrapper -->
      <div id="form-interactive-container">
        <!-- Progress Header -->
        <div class="mb-6 space-y-3 font-sans">
          <div class="flex items-center justify-between text-xs font-bold uppercase tracking-[0.12em] text-[color:var(--muted-soft)]">
            <span id="step-number-display">Step 1 of 4</span>
            <span id="step-name-display" class="text-[color:var(--accent-strong)]">Contact Information</span>
          </div>
          <div class="h-1.5 w-full rounded-full bg-slate-100/85">
            <div id="form-progress-bar" class="h-1.5 rounded-full bg-[color:var(--accent)] transition-all duration-300" style="width: 25%"></div>
          </div>
        </div>

        <form id="smesh-contact-form" class="space-y-4" novalidate>
          <!-- Honeypot -->
          <input type="text" id="company_website" name="company_website" autocomplete="off" tabindex="-1" class="hidden" />

          <!-- STEP 1: Contact Info -->
          <div data-step="1" class="space-y-4">
            <div>
              <label for="name" class="mb-1.5 block text-[10px] sm:text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted-soft)] font-sans">Full Name</label>
              <input type="text" id="name" name="name" required placeholder="Haider Ali" class="w-full rounded-[14px] sm:rounded-[18px] border border-[color:var(--line)] bg-white px-3.5 py-2.5 sm:px-4 sm:py-3 text-xs sm:text-sm text-[color:var(--ink)] placeholder:text-[color:var(--muted-soft)] focus:border-[color:var(--accent)] focus:outline-none focus:ring-4 focus:ring-[rgba(15,118,110,0.12)] font-sans transition-all" />
              <p data-error-for="name" class="mt-1.5 hidden text-xs text-rose-500 font-sans">Please enter your full name.</p>
            </div>

            <div>
              <label for="whatsapp" class="mb-1.5 block text-[10px] sm:text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted-soft)] font-sans">WhatsApp Number</label>
              <input type="tel" id="whatsapp" name="whatsapp" required placeholder="+92 300 0000000" class="w-full rounded-[14px] sm:rounded-[18px] border border-[color:var(--line)] bg-white px-3.5 py-2.5 sm:px-4 sm:py-3 text-xs sm:text-sm text-[color:var(--ink)] placeholder:text-[color:var(--muted-soft)] focus:border-[color:var(--accent)] focus:outline-none focus:ring-4 focus:ring-[rgba(15,118,110,0.12)] font-sans transition-all" />
              <p data-error-for="whatsapp" class="mt-1.5 hidden text-xs text-rose-500 font-sans">Please enter your WhatsApp number (min 8 digits).</p>
            </div>

            <div>
              <div class="flex items-center justify-between mb-1.5">
                <label for="email" class="block text-[10px] sm:text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted-soft)] font-sans">Email</label>
                <span class="text-[9px] uppercase tracking-wider text-slate-400 font-semibold font-sans">Optional</span>
              </div>
              <input type="email" id="email" name="email" placeholder="you@domain.com" class="w-full rounded-[14px] sm:rounded-[18px] border border-[color:var(--line)] bg-white px-3.5 py-2.5 sm:px-4 sm:py-3 text-xs sm:text-sm text-[color:var(--ink)] placeholder:text-[color:var(--muted-soft)] focus:border-[color:var(--accent)] focus:outline-none focus:ring-4 focus:ring-[rgba(15,118,110,0.12)] font-sans transition-all" />
              <p data-error-for="email" class="mt-1.5 hidden text-xs text-rose-500 font-sans">Please enter a valid email address.</p>
            </div>

            <div class="pt-2">
              <button type="button" class="btn-next button-primary w-full text-xs sm:text-sm py-3.5 px-6 rounded-xl flex items-center justify-center gap-1.5 shadow-sm bg-[color:var(--accent)] hover:bg-[color:var(--accent-strong)] text-white border-none cursor-pointer font-sans font-bold">
                <span>Next Step →</span>
              </button>
            </div>
          </div>

          <!-- STEP 2: Business Details -->
          <div data-step="2" class="space-y-4 hidden">
            <div>
              <label for="business_type" class="mb-1.5 block text-[10px] sm:text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted-soft)] font-sans">Business Type</label>
              <input type="text" id="business_type" name="business_type" required placeholder="Retail shop, clinic, SaaS, agency, freelancer..." class="w-full rounded-[14px] sm:rounded-[18px] border border-[color:var(--line)] bg-white px-3.5 py-2.5 sm:px-4 sm:py-3 text-xs sm:text-sm text-[color:var(--ink)] placeholder:text-[color:var(--muted-soft)] focus:border-[color:var(--accent)] focus:outline-none focus:ring-4 focus:ring-[rgba(15,118,110,0.12)] font-sans transition-all" />
              <p data-error-for="business_type" class="mt-1.5 hidden text-xs text-rose-500 font-sans">Please enter your business type.</p>
            </div>

            <div>
              <label for="current_problem" class="mb-1.5 block text-[10px] sm:text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted-soft)] font-sans">Current Problem</label>
              <textarea id="current_problem" name="current_problem" rows="3" required placeholder="What is currently wasting time or bottlenecking revenue?" class="w-full rounded-[14px] sm:rounded-[18px] border border-[color:var(--line)] bg-white px-3.5 py-2.5 sm:px-4 sm:py-3 text-xs sm:text-sm leading-relaxed text-[color:var(--ink)] placeholder:text-[color:var(--muted-soft)] focus:border-[color:var(--accent)] focus:outline-none focus:ring-4 focus:ring-[rgba(15,118,110,0.12)] font-sans transition-all resize-none"></textarea>
              <p data-error-for="current_problem" class="mt-1.5 hidden text-xs text-rose-500 font-sans">Please describe your problem (min 10 characters).</p>
            </div>

            <div>
              <div class="flex items-center justify-between mb-1.5">
                <label for="tools_used" class="block text-[10px] sm:text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted-soft)] font-sans">Tools Already Using</label>
                <span class="text-[9px] uppercase tracking-wider text-slate-400 font-semibold font-sans">Optional</span>
              </div>
              <input type="text" id="tools_used" name="tools_used" placeholder="WhatsApp, Excel, Google Sheets, Shopify... whatever you currently use" class="w-full rounded-[14px] sm:rounded-[18px] border border-[color:var(--line)] bg-white px-3.5 py-2.5 sm:px-4 sm:py-3 text-xs sm:text-sm text-[color:var(--ink)] placeholder:text-[color:var(--muted-soft)] focus:border-[color:var(--accent)] focus:outline-none focus:ring-4 focus:ring-[rgba(15,118,110,0.12)] font-sans transition-all" />
            </div>

            <div class="pt-2 flex gap-3">
              <button type="button" class="btn-back button-secondary py-3 px-5 rounded-xl text-xs sm:text-sm font-semibold shrink-0 cursor-pointer font-sans">
                ← Back
              </button>
              <button type="button" class="btn-next button-primary w-full text-xs sm:text-sm py-3 px-6 rounded-xl flex items-center justify-center gap-1.5 shadow-sm bg-[color:var(--accent)] hover:bg-[color:var(--accent-strong)] text-white border-none cursor-pointer font-sans font-bold">
                <span>Next →</span>
              </button>
            </div>
          </div>

          <!-- STEP 3: Budget & Timeline -->
          <div data-step="3" class="space-y-4 hidden">
            <div>
              <label for="budget" class="mb-1.5 block text-[10px] sm:text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted-soft)] font-sans">Budget Range</label>
              <select id="budget" name="budget" required class="w-full rounded-[14px] sm:rounded-[18px] border border-[color:var(--line)] bg-white px-3.5 py-2.5 sm:px-4 sm:py-3 text-xs sm:text-sm text-[color:var(--ink)] focus:border-[color:var(--accent)] focus:outline-none focus:ring-4 focus:ring-[rgba(15,118,110,0.12)] font-sans transition-all">
                <option value="">Select budget range</option>
                <option value="Under $1,500 USD">Under $1,500 USD</option>
                <option value="$1,500 – $3,500 USD">$1,500 – $3,500 USD</option>
                <option value="$3,500 – $7,500 USD">$3,500 – $7,500 USD</option>
                <option value="$7,500+ USD">$7,500+ USD</option>
                <option value="Not sure yet — suggest a budget">Not sure yet — suggest a budget</option>
              </select>
              <p data-error-for="budget" class="mt-1.5 hidden text-xs text-rose-500 font-sans">Please select a budget range.</p>
            </div>

            <div>
              <label for="timeline" class="mb-1.5 block text-[10px] sm:text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted-soft)] font-sans">Timeline</label>
              <select id="timeline" name="timeline" required class="w-full rounded-[14px] sm:rounded-[18px] border border-[color:var(--line)] bg-white px-3.5 py-2.5 sm:px-4 sm:py-3 text-xs sm:text-sm text-[color:var(--ink)] focus:border-[color:var(--accent)] focus:outline-none focus:ring-4 focus:ring-[rgba(15,118,110,0.12)] font-sans transition-all">
                <option value="">Select timeline</option>
                <option value="As soon as possible">As soon as possible</option>
                <option value="Within 1 month">Within 1 month</option>
                <option value="Within 2-3 months">Within 2-3 months</option>
                <option value="Just exploring/planning">Just exploring/planning</option>
              </select>
              <p data-error-for="timeline" class="mt-1.5 hidden text-xs text-rose-500 font-sans">Please select a project timeline.</p>
            </div>

            <div>
              <label class="mb-2 block text-[10px] sm:text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted-soft)] font-sans">Service Needed</label>
              <div class="flex flex-wrap gap-2 pt-0.5">
                {["AI Chatbot", "WhatsApp Bot", "n8n Workflow", "SaaS/MVP", "Chrome Extension", "Something else"].map((srv) => (
                  <label class="cursor-pointer select-none">
                    <input type="checkbox" name="services" value={srv} class="sr-only peer" />
                    <span class="inline-block rounded-full border border-slate-200 bg-white px-3.5 py-1.5 text-xs font-medium text-slate-700 peer-checked:border-teal-700 peer-checked:bg-teal-50 peer-checked:text-teal-800 transition-all font-sans">
                      {srv}
                    </span>
                  </label>
                ))}
              </div>
              <p data-error-for="services" class="mt-1.5 hidden text-xs text-rose-500 font-sans">Please select at least one service.</p>
            </div>

            <div class="pt-2 flex gap-3">
              <button type="button" class="btn-back button-secondary py-3 px-5 rounded-xl text-xs sm:text-sm font-semibold shrink-0 cursor-pointer font-sans">
                ← Back
              </button>
              <button type="button" class="btn-next button-primary w-full text-xs sm:text-sm py-3 px-6 rounded-xl flex items-center justify-center gap-1.5 shadow-sm bg-[color:var(--accent)] hover:bg-[color:var(--accent-strong)] text-white border-none cursor-pointer font-sans font-bold">
                <span>Almost done →</span>
              </button>
            </div>
          </div>

          <!-- STEP 4: Project Brief -->
          <div data-step="4" class="space-y-4 hidden">
            <div>
              <label for="message" class="mb-1.5 block text-[10px] sm:text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted-soft)] font-sans">Project Brief</label>
              <textarea id="message" name="message" rows="6" required placeholder="Describe what is happening today, what the system should do, and what a successful outcome looks like. The more detail you share, the better proposal you'll get." class="w-full rounded-[14px] sm:rounded-[18px] border border-[color:var(--line)] bg-white px-3.5 py-2.5 sm:px-4 sm:py-3 text-xs sm:text-sm leading-relaxed text-[color:var(--ink)] placeholder:text-[color:var(--muted-soft)] focus:border-[color:var(--accent)] focus:outline-none focus:ring-4 focus:ring-[rgba(15,118,110,0.12)] font-sans transition-all resize-none"></textarea>
              <p data-error-for="message" class="mt-1.5 hidden text-xs text-rose-500 font-sans">Please add a project brief (min 15 characters).</p>
            </div>

            <div>
              <div class="flex items-center justify-between mb-1.5">
                <label for="referral" class="block text-[10px] sm:text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted-soft)] font-sans">How did you find us</label>
                <span class="text-[9px] uppercase tracking-wider text-slate-400 font-semibold font-sans">Optional</span>
              </div>
              <select id="referral" name="referral" class="w-full rounded-[14px] sm:rounded-[18px] border border-[color:var(--line)] bg-white px-3.5 py-2.5 sm:px-4 sm:py-3 text-xs sm:text-sm text-[color:var(--ink)] focus:border-[color:var(--accent)] focus:outline-none focus:ring-4 focus:ring-[rgba(15,118,110,0.12)] font-sans transition-all">
                <option value="">Select source</option>
                <option value="Google Search">Google Search</option>
                <option value="LinkedIn">LinkedIn</option>
                <option value="Referral">Referral</option>
                <option value="Social Media">Social Media</option>
                <option value="Direct/Already knew">Direct/Already knew</option>
              </select>
            </div>

            <div class="pt-2 space-y-3">
              <button type="submit" id="submit-btn" class="button-primary w-full text-xs sm:text-sm py-3.5 px-6 rounded-xl flex items-center justify-center gap-1.5 shadow-sm bg-[color:var(--accent)] hover:bg-[color:var(--accent-strong)] text-white border-none cursor-pointer font-sans font-bold">
                <span>Submit Project Details</span>
                <i data-lucide="send" class="h-4 w-4"></i>
              </button>
              
              <button type="button" class="btn-back text-xs font-semibold text-slate-500 hover:text-slate-900 transition flex items-center justify-center gap-1 mx-auto py-1 font-sans cursor-pointer">
                ← Go back to change details
              </button>
            </div>

            <div class="text-center pt-2">
              <p class="text-xs text-[color:var(--muted)] font-sans">
                Prefer to chat? 
                <a href={whatsappPrefill} target="_blank" rel="noopener" class="font-bold text-[color:var(--accent-strong)] hover:underline inline-flex items-center gap-0.5 font-sans">
                  Message on WhatsApp directly
                  <i data-lucide="arrow-up-right" class="w-3 h-3 text-[color:var(--accent-strong)]"></i>
                </a>
              </p>
            </div>
          </div>
        </form>

        <div id="form-error-alert" class="mt-6 hidden rounded-[22px] border border-rose-100 bg-rose-50/50 p-4 text-xs text-slate-600 font-sans">
          <h4 class="font-bold text-rose-700">Connection failed. Please try again.</h4>
          <p class="mt-1">If the form still fails, email <a href={`mailto:${site.email}`} class="font-semibold text-[color:var(--accent-strong)] hover:underline">{site.email}</a> or send the brief on WhatsApp.</p>
        </div>
      </div>

      <!-- SUCCESS STATE -->
      <div id="form-success-container" class="hidden py-8 text-center space-y-6">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-emerald-50 text-[color:var(--accent)] border border-emerald-100">
          <i data-lucide="check" class="h-8 w-8"></i>
        </div>
        <div class="space-y-2">
          <h3 class="text-xl font-bold text-slate-950 font-display">Brief received — thank you!</h3>
          <p class="text-xs text-slate-655 leading-relaxed font-light font-sans max-w-sm mx-auto">
            I will review your requirements and respond within 4 hours via WhatsApp or email to share the project scope.
          </p>
        </div>
        <div class="pt-2 max-w-sm mx-auto">
          <a 
            href={whatsappPrefill}
            target="_blank"
            rel="noopener"
            class="button-primary w-full justify-center text-xs py-3.5 px-8 font-sans font-bold flex items-center gap-2 bg-[color:var(--accent)] hover:bg-[color:var(--accent-strong)] border-none text-white shadow-sm"
          >
            <span>Message on WhatsApp too →</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { supabase } from '../lib/supabase';

  let currentStep = 1;
  const stepContainers = document.querySelectorAll('[data-step]');
  const stepNumberDisplay = document.getElementById('step-number-display');
  const stepNameDisplay = document.getElementById('step-name-display');
  const progressBar = document.getElementById('form-progress-bar');
  const formInteractiveContainer = document.getElementById('form-interactive-container');
  const successContainer = document.getElementById('form-success-container');
  const errorAlert = document.getElementById('form-error-alert');
  const form = document.getElementById('smesh-contact-form');
  const honeypot = document.getElementById('company_website') as HTMLInputElement | null;

  const stepNames = [
    "Contact Information",
    "Your Business",
    "Budget & Timeline",
    "Project Brief"
  ];

  const nameInput = document.getElementById('name') as HTMLInputElement | null;
  const whatsappInput = document.getElementById('whatsapp') as HTMLInputElement | null;
  const emailInput = document.getElementById('email') as HTMLInputElement | null;
  
  const businessTypeInput = document.getElementById('business_type') as HTMLInputElement | null;
  const currentProblemInput = document.getElementById('current_problem') as HTMLTextAreaElement | null;
  const toolsUsedInput = document.getElementById('tools_used') as HTMLInputElement | null;
  
  const budgetInput = document.getElementById('budget') as HTMLSelectElement | null;
  const timelineInput = document.getElementById('timeline') as HTMLSelectElement | null;
  
  const messageInput = document.getElementById('message') as HTMLTextAreaElement | null;
  const referralInput = document.getElementById('referral') as HTMLSelectElement | null;

  const validators = {
    name: (val: string) => val.trim().length >= 2,
    whatsapp: (val: string) => /^[+]?[0-9\s\-()]{8,}$/.test(val.trim()),
    email: (val: string) => val.trim() === '' || /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val.trim()),
    business_type: (val: string) => val.trim().length >= 2,
    current_problem: (val: string) => val.trim().length >= 10,
    budget: (val: string) => val !== '',
    timeline: (val: string) => val !== '',
    message: (val: string) => val.trim().length >= 15,
  };

  const getErrorNode = (id: string) => document.querySelector(`[data-error-for="${id}"]`);

  const validateField = (field: HTMLElement | null, validator: (val: string) => boolean) => {
    if (!field) return true;
    const errorNode = getErrorNode(field.id);
    const val = (field as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement).value || '';
    const isValid = validator(val);

    field.classList.toggle('border-rose-400', !isValid);
    field.classList.toggle('focus:ring-[rgba(190,24,93,0.12)]', !isValid);
    
    // Reset success indicators to let the design system look clean and professional
    field.classList.toggle('border-emerald-500', isValid && val.trim().length > 0);
    field.classList.toggle('bg-emerald-50/20', isValid && val.trim().length > 0 && field.tagName !== 'SELECT');

    if (errorNode) {
      errorNode.classList.toggle('hidden', isValid);
    }
    return isValid;
  };

  const validateServices = () => {
    const checked = document.querySelectorAll('input[name="services"]:checked');
    const isValid = checked.length > 0;
    const errorNode = document.querySelector('[data-error-for="services"]');
    if (errorNode) {
      errorNode.classList.toggle('hidden', isValid);
    }
    return isValid;
  };

  const validateStep = (step: number) => {
    if (step === 1) {
      const isNameValid = validateField(nameInput, validators.name);
      const isWhatsappValid = validateField(whatsappInput, validators.whatsapp);
      const isEmailValid = validateField(emailInput, validators.email);
      return isNameValid && isWhatsappValid && isEmailValid;
    }
    if (step === 2) {
      const isBizValid = validateField(businessTypeInput, validators.business_type);
      const isProblemValid = validateField(currentProblemInput, validators.current_problem);
      return isBizValid && isProblemValid;
    }
    if (step === 3) {
      const isBudgetValid = validateField(budgetInput, validators.budget);
      const isTimelineValid = validateField(timelineInput, validators.timeline);
      const isServicesValid = validateServices();
      return isBudgetValid && isTimelineValid && isServicesValid;
    }
    if (step === 4) {
      return validateField(messageInput, validators.message);
    }
    return true;
  };

  const showStep = (step: number) => {
    stepContainers.forEach(container => {
      const containerStep = parseInt(container.getAttribute('data-step') || '0', 10);
      if (containerStep === step) {
        container.classList.remove('hidden');
      } else {
        container.classList.add('hidden');
      }
    });

    if (stepNumberDisplay) stepNumberDisplay.textContent = `Step ${step} of 4`;
    if (stepNameDisplay) stepNameDisplay.textContent = stepNames[step - 1];
    if (progressBar) {
      progressBar.style.width = `${step * 25}%`;
    }
  };

  // Setup navigation
  const nextButtons = document.querySelectorAll('.btn-next');
  const backButtons = document.querySelectorAll('.btn-back');

  nextButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      if (validateStep(currentStep)) {
        currentStep++;
        showStep(currentStep);
        const formContainer = document.getElementById('smesh-contact-form');
        formContainer?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    });
  });

  backButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      if (currentStep > 1) {
        currentStep--;
        showStep(currentStep);
      }
    });
  });

  // Setup live validation
  const setupLiveValidation = (input: HTMLElement | null, validatorKey: keyof typeof validators) => {
    if (!input) return;
    const validator = validators[validatorKey];
    input.addEventListener('input', () => validateField(input, validator));
    input.addEventListener('blur', () => validateField(input, validator));
  };

  setupLiveValidation(nameInput, 'name');
  setupLiveValidation(whatsappInput, 'whatsapp');
  setupLiveValidation(emailInput, 'email');
  setupLiveValidation(businessTypeInput, 'business_type');
  setupLiveValidation(currentProblemInput, 'current_problem');
  setupLiveValidation(messageInput, 'message');

  if (budgetInput) {
    budgetInput.addEventListener('change', () => validateField(budgetInput, validators.budget));
    budgetInput.addEventListener('blur', () => validateField(budgetInput, validators.budget));
  }
  if (timelineInput) {
    timelineInput.addEventListener('change', () => validateField(timelineInput, validators.timeline));
    timelineInput.addEventListener('blur', () => validateField(timelineInput, validators.timeline));
  }

  const serviceCheckboxes = document.querySelectorAll('input[name="services"]');
  serviceCheckboxes.forEach(cb => {
    cb.addEventListener('change', validateServices);
  });

  // URL Prefill Handling
  const urlParams = new URLSearchParams(window.location.search);
  const prefillService = urlParams.get('service') || urlParams.get('interest') || urlParams.get('package');
  const ref = urlParams.get('ref');

  if (prefillService) {
    const serviceCheckbox = Array.from(document.querySelectorAll('input[name="services"]'))
      .find((cb) => (cb as HTMLInputElement).value.toLowerCase() === prefillService.toLowerCase());
    if (serviceCheckbox instanceof HTMLInputElement) {
      serviceCheckbox.checked = true;
    }
  }

  if (ref && messageInput && !messageInput.value) {
    messageInput.value = `Lead source: ${ref}\n`;
  }

  // Form submission
  if (form instanceof HTMLFormElement) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (honeypot && honeypot.value) {
        return;
      }

      if (!validateStep(4)) {
        return;
      }

      const submitBtn = document.getElementById('submit-btn');
      if (!(submitBtn instanceof HTMLButtonElement)) return;

      submitBtn.disabled = true;
      const btnLabel = submitBtn.querySelector('span');
      const originalText = btnLabel?.textContent || 'Submit Project Details';
      if (btnLabel) btnLabel.textContent = 'Sending...';

      const selectedServices = Array.from(document.querySelectorAll('input[name="services"]:checked'))
        .map(cb => (cb as HTMLInputElement).value)
        .join(', ');

      const problem = currentProblemInput?.value || '';
      const tools = toolsUsedInput?.value || '';
      const timeline = timelineInput?.value || '';
      const referral = referralInput?.value || '';
      const brief = messageInput?.value || '';

      const messageBlock = [
        `CURRENT PROBLEM:\n${problem}`,
        `TOOLS ALREADY USING:\n${tools || 'None / Not specified'}`,
        `TIMELINE:\n${timeline}`,
        referral ? `HOW DID YOU FIND US:\n${referral}` : null,
        `PROJECT BRIEF:\n${brief}`
      ].filter(Boolean).join('\n\n');

      const payload = {
        name: nameInput?.value || '',
        whatsapp: whatsappInput?.value || '',
        email: emailInput?.value || '',
        business_type: businessTypeInput?.value || '',
        service: selectedServices,
        budget: budgetInput?.value || '',
        message: messageBlock,
        page_url: window.location.pathname + window.location.search,
        created_at: new Date().toISOString(),
      };

      try {
        const { error } = await supabase.from('contact_submissions').insert([payload]);
        if (error) throw error;

        if (formInteractiveContainer) formInteractiveContainer.classList.add('hidden');
        if (successContainer) successContainer.classList.remove('hidden');
        if (errorAlert) errorAlert.classList.add('hidden');
        
        // Re-initialize Lucide check icon
        if ((window as any).lucide) {
          (window as any).lucide.createIcons();
        }
      } catch (err) {
        console.error('Supabase submission failed:', err);
        if (errorAlert) errorAlert.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        if (btnLabel) btnLabel.textContent = originalText;
      }
    });
  }
</script>
