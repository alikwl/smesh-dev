---
import { site } from '../data/site';

interface Props {
  isBare?: boolean;
}

const { isBare = false } = Astro.props;
const uniqueId = Math.random().toString(36).substring(2, 8);
const wrapperClass = isBare ? '' : 'surface-card rounded-[32px] p-6 md:p-8';
const whatsappPrefillDefault = `${site.whatsappLink}?text=${encodeURIComponent('Hi Haider, I want to discuss a website / automation project for my business.')}`;
---

<section id={isBare ? undefined : "contact"} class:list={[!isBare && 'py-12 md:py-16']}>
  <div class:list={[!isBare && 'site-shell']}>
    <div class:list={[wrapperClass, "smesh-contact-form-container"]}>
      {!isBare && (
        <div class="mb-7 grid gap-5 lg:grid-cols-[0.94fr_1.06fr] lg:items-end">
          <div>
            <div class="section-kicker font-sans">Start a project</div>
            <h2 class="mt-4 text-3xl font-semibold leading-[1.06] text-[color:var(--ink)] sm:text-4xl">Tell me what is slowing the business down, and I will map the shortest path to a working system.</h2>
          </div>
          <div class="grid gap-3 sm:grid-cols-3">
            <div class="rounded-[22px] border border-[color:var(--line)] bg-white/70 p-4">
              <p class="text-[11px] uppercase tracking-[0.18em] text-[color:var(--muted-soft)] font-sans font-bold">Response</p>
              <p class="mt-2 text-sm font-semibold text-[color:var(--ink)]">WhatsApp or email follow-up</p>
            </div>
            <div class="rounded-[22px] border border-[color:var(--line)] bg-white/70 p-4">
              <p class="text-[11px] uppercase tracking-[0.18em] text-[color:var(--muted-soft)] font-sans font-bold">Scope</p>
              <p class="mt-2 text-sm font-semibold text-[color:var(--ink)]">Web, automation, AI support</p>
            </div>
            <div class="rounded-[22px] border border-[color:var(--line)] bg-white/70 p-4">
              <p class="text-[11px] uppercase tracking-[0.18em] text-[color:var(--muted-soft)] font-sans font-bold">Direct line</p>
              <p class="mt-2 text-sm font-semibold text-[color:var(--ink)] font-sans">{site.whatsapp}</p>
            </div>
          </div>
        </div>
      )}

      <!-- Form interactive wrapper -->
      <div class="form-interactive-container">
        <form class="smesh-contact-form space-y-5" novalidate>
          <!-- Honeypot -->
          <input type="text" id={`company_website-${uniqueId}`} name="company_website" autocomplete="off" tabindex="-1" class="hidden company_website_input" />

          <!-- Core Grid (Contact & Business Info) -->
          <div class="grid gap-4 sm:grid-cols-2">
            <!-- Full Name -->
            <div>
              <label for={`name-${uniqueId}`} class="mb-1.5 block text-[10px] sm:text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted-soft)] font-sans font-bold">Full Name <span class="text-rose-500">*</span></label>
              <input type="text" id={`name-${uniqueId}`} name="name" required placeholder="Haider Ali" class="w-full rounded-[14px] sm:rounded-[18px] border border-[color:var(--line)] bg-white px-3.5 py-2.5 sm:px-4 sm:py-3 text-xs sm:text-sm text-[color:var(--ink)] placeholder:text-[color:var(--muted-soft)] focus:border-[color:var(--accent)] focus:outline-none focus:ring-4 focus:ring-[rgba(15,118,110,0.12)] font-sans transition-all" />
              <p data-error-for="name" class="mt-1.5 hidden text-xs text-rose-500 font-sans">Please enter your full name.</p>
            </div>

            <!-- WhatsApp Number -->
            <div>
              <label for={`whatsapp-${uniqueId}`} class="mb-1.5 block text-[10px] sm:text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted-soft)] font-sans font-bold">WhatsApp Number <span class="text-rose-500">*</span></label>
              <input type="tel" id={`whatsapp-${uniqueId}`} name="whatsapp" required placeholder="+92 300 0000000" class="w-full rounded-[14px] sm:rounded-[18px] border border-[color:var(--line)] bg-white px-3.5 py-2.5 sm:px-4 sm:py-3 text-xs sm:text-sm text-[color:var(--ink)] placeholder:text-[color:var(--muted-soft)] focus:border-[color:var(--accent)] focus:outline-none focus:ring-4 focus:ring-[rgba(15,118,110,0.12)] font-sans transition-all" />
              <p data-error-for="whatsapp" class="mt-1.5 hidden text-xs text-rose-500 font-sans">Please enter your WhatsApp number (min 8 digits).</p>
            </div>

            <!-- Email Address -->
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <label for={`email-${uniqueId}`} class="block text-[10px] sm:text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted-soft)] font-sans font-bold">Email Address</label>
                <span class="text-[9px] uppercase tracking-wider text-slate-500 font-semibold font-sans">Optional</span>
              </div>
              <input type="email" id={`email-${uniqueId}`} name="email" placeholder="you@domain.com" class="w-full rounded-[14px] sm:rounded-[18px] border border-[color:var(--line)] bg-white px-3.5 py-2.5 sm:px-4 sm:py-3 text-xs sm:text-sm text-[color:var(--ink)] placeholder:text-[color:var(--muted-soft)] focus:border-[color:var(--accent)] focus:outline-none focus:ring-4 focus:ring-[rgba(15,118,110,0.12)] font-sans transition-all" />
              <p data-error-for="email" class="mt-1.5 hidden text-xs text-rose-500 font-sans">Please enter a valid email address.</p>
            </div>

            <!-- Business Type -->
            <div>
              <label for={`business_type-${uniqueId}`} class="mb-1.5 block text-[10px] sm:text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted-soft)] font-sans font-bold">Business Type <span class="text-rose-500">*</span></label>
              <input type="text" id={`business_type-${uniqueId}`} name="business_type" required placeholder="Retail shop, SaaS, clinic, agency..." class="w-full rounded-[14px] sm:rounded-[18px] border border-[color:var(--line)] bg-white px-3.5 py-2.5 sm:px-4 sm:py-3 text-xs sm:text-sm text-[color:var(--ink)] placeholder:text-[color:var(--muted-soft)] focus:border-[color:var(--accent)] focus:outline-none focus:ring-4 focus:ring-[rgba(15,118,110,0.12)] font-sans transition-all" />
              <p data-error-for="business_type" class="mt-1.5 hidden text-xs text-rose-500 font-sans">Please specify your business type.</p>
            </div>
          </div>

          <!-- Services Interested In -->
          <div class="space-y-2">
            <div class="flex items-center justify-between mb-1">
              <label class="block text-[10px] sm:text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted-soft)] font-sans font-bold">Services Interested In</label>
              <span class="text-[9px] uppercase tracking-wider text-slate-500 font-semibold font-sans">Optional</span>
            </div>
            <div class="flex flex-wrap gap-2 pt-0.5">
              {["AI Chatbot", "WhatsApp Bot", "n8n Workflow", "SaaS/MVP", "Chrome Extension", "Something else"].map((srv) => (
                <label class="cursor-pointer select-none">
                  <input type="checkbox" name="services" value={srv} class="sr-only peer" />
                  <span class="inline-block rounded-full border border-slate-200 bg-white px-3.5 py-1.5 text-xs font-medium text-slate-700 peer-checked:border-teal-700 peer-checked:bg-teal-50 peer-checked:text-teal-800 transition-all font-sans">
                    {srv}
                  </span>
                </label>
              ))}
            </div>
          </div>

          <!-- What do you want to automate? -->
          <div>
            <label for={`message-${uniqueId}`} class="mb-1.5 block text-[10px] sm:text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted-soft)] font-sans font-bold">What do you want to automate? <span class="text-rose-500">*</span></label>
            <textarea id={`message-${uniqueId}`} name="message" rows="4" required placeholder="Describe your manual workflows, bottlenecks, or what you want the system to do. The more detail you share, the better proposal you'll get." class="w-full rounded-[14px] sm:rounded-[18px] border border-[color:var(--line)] bg-white px-3.5 py-2.5 sm:px-4 sm:py-3 text-xs sm:text-sm leading-relaxed text-[color:var(--ink)] placeholder:text-[color:var(--muted-soft)] focus:border-[color:var(--accent)] focus:outline-none focus:ring-4 focus:ring-[rgba(15,118,110,0.12)] font-sans transition-all resize-none"></textarea>
            <p data-error-for="message" class="mt-1.5 hidden text-xs text-rose-500 font-sans">Please describe what you want to automate (min 15 characters).</p>
          </div>

          <!-- Qualifications Dropdowns Grid -->
          <div class="grid gap-4 grid-cols-1 sm:grid-cols-3">
            <!-- Budget Range -->
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <label for={`budget-${uniqueId}`} class="block text-[10px] sm:text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted-soft)] font-sans font-bold">Budget Range</label>
                <span class="text-[9px] uppercase tracking-wider text-slate-500 font-semibold font-sans">Optional</span>
              </div>
              <select id={`budget-${uniqueId}`} name="budget" class="w-full rounded-[14px] sm:rounded-[18px] border border-[color:var(--line)] bg-white px-3.5 py-2.5 sm:px-4 sm:py-3 text-xs sm:text-sm text-[color:var(--ink)] focus:border-[color:var(--accent)] focus:outline-none focus:ring-4 focus:ring-[rgba(15,118,110,0.12)] font-sans transition-all">
                <option value="">Select budget range</option>
                <option value="Under $1,500 USD">Under $1,500 USD</option>
                <option value="$1,500 – $3,500 USD">$1,500 – $3,500 USD</option>
                <option value="$3,500 – $7,500 USD">$3,500 – $7,500 USD</option>
                <option value="$7,500+ USD">$7,500+ USD</option>
                <option value="Not sure yet">Not sure yet</option>
              </select>
            </div>

            <!-- Project Timeline -->
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <label for={`timeline-${uniqueId}`} class="block text-[10px] sm:text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted-soft)] font-sans font-bold">Project Timeline</label>
                <span class="text-[9px] uppercase tracking-wider text-slate-500 font-semibold font-sans">Optional</span>
              </div>
              <select id={`timeline-${uniqueId}`} name="timeline" class="w-full rounded-[14px] sm:rounded-[18px] border border-[color:var(--line)] bg-white px-3.5 py-2.5 sm:px-4 sm:py-3 text-xs sm:text-sm text-[color:var(--ink)] focus:border-[color:var(--accent)] focus:outline-none focus:ring-4 focus:ring-[rgba(15,118,110,0.12)] font-sans transition-all">
                <option value="">Select timeline</option>
                <option value="As soon as possible">As soon as possible</option>
                <option value="Within 1 month">Within 1 month</option>
                <option value="Within 2-3 months">Within 2-3 months</option>
                <option value="Just exploring/planning">Just exploring/planning</option>
              </select>
            </div>

            <!-- How did you find us? -->
            <div>
              <div class="flex items-center justify-between mb-1.5">
                <label for={`referral-${uniqueId}`} class="block text-[10px] sm:text-xs font-semibold uppercase tracking-[0.12em] text-[color:var(--muted-soft)] font-sans font-bold">How did you find us?</label>
                <span class="text-[9px] uppercase tracking-wider text-slate-500 font-semibold font-sans">Optional</span>
              </div>
              <select id={`referral-${uniqueId}`} name="referral" class="w-full rounded-[14px] sm:rounded-[18px] border border-[color:var(--line)] bg-white px-3.5 py-2.5 sm:px-4 sm:py-3 text-xs sm:text-sm text-[color:var(--ink)] focus:border-[color:var(--accent)] focus:outline-none focus:ring-4 focus:ring-[rgba(15,118,110,0.12)] font-sans transition-all">
                <option value="">Select source</option>
                <option value="Google Search">Google Search</option>
                <option value="Twitter/X">Twitter/X</option>
                <option value="LinkedIn">LinkedIn</option>
                <option value="Recommendation">Recommendation</option>
                <option value="Other">Other</option>
              </select>
            </div>
          </div>

          <!-- Submit CTA Section -->
          <div class="pt-2 space-y-4">
            <button type="submit" class="submit-btn button-primary w-full text-xs sm:text-sm py-3.5 px-6 rounded-xl flex items-center justify-center gap-1.5 shadow-sm bg-[color:var(--accent)] hover:bg-[color:var(--accent-strong)] text-white border-none cursor-pointer font-sans font-bold">
              <span>Submit Project Details</span>
              <i data-lucide="send" class="h-4 w-4"></i>
            </button>
            
            <p class="text-center text-xs text-[color:var(--muted)] font-sans">
              Prefer to chat? 
              <a href={whatsappPrefillDefault} target="_blank" rel="noopener" class="font-bold text-[color:var(--accent-strong)] hover:underline inline-flex items-center gap-0.5 font-sans">
                Message on WhatsApp directly
                <i data-lucide="arrow-up-right" class="w-3 h-3 text-[color:var(--accent-strong)]"></i>
              </a>
            </p>
          </div>
        </form>

        <div class="form-error-alert mt-6 hidden rounded-[22px] border border-rose-100 bg-rose-50/50 p-4 text-xs text-slate-600 font-sans">
          <h4 class="font-bold text-rose-700">Connection failed. Please try again.</h4>
          <p class="mt-1">If the form still fails, email <a href={`mailto:${site.email}`} class="font-semibold text-[color:var(--accent-strong)] hover:underline">{site.email}</a> or send the brief on WhatsApp.</p>
        </div>
      </div>

      <!-- SUCCESS STATE -->
      <div class="form-success-container hidden py-8 text-center space-y-6">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-emerald-50 text-emerald-700 border border-emerald-100 animate-bounce">
          <i data-lucide="check" class="h-8 w-8"></i>
        </div>
        <div class="space-y-2">
          <h3 class="text-xl sm:text-2xl font-bold text-slate-955 font-display">System Brief Received!</h3>
          <p class="text-xs sm:text-sm text-slate-655 leading-relaxed font-light font-sans max-w-sm mx-auto">
            Your project details have been successfully synced to our Supabase database. Lead engineer <strong>Haider Ali</strong> will review your manual bottlenecks and respond with a tailored workflow proposal within 4 hours.
          </p>
        </div>
        <div class="pt-2 max-w-sm mx-auto">
          <a 
            id={`success-whatsapp-btn-${uniqueId}`}
            href={whatsappPrefillDefault}
            target="_blank"
            rel="noopener"
            class="button-primary w-full justify-center text-xs py-3.5 px-8 font-sans font-bold flex items-center gap-2 bg-[color:var(--accent)] hover:bg-[color:var(--accent-strong)] border-none text-white shadow-sm cursor-pointer"
          >
            <span>Ping via WhatsApp with Form Details →</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const formContainers = document.querySelectorAll('.smesh-contact-form-container');

  formContainers.forEach(container => {
    const formInteractiveContainer = container.querySelector('.form-interactive-container');
    const successContainer = container.querySelector('.form-success-container');
    const errorAlert = container.querySelector('.form-error-alert');
    const form = container.querySelector('.smesh-contact-form');
    const honeypot = container.querySelector('.company_website_input') as HTMLInputElement | null;
    const successWhatsappBtn = container.querySelector('[id^="success-whatsapp-btn-"]') as HTMLAnchorElement | null;

    const nameInput = container.querySelector('[name="name"]') as HTMLInputElement | null;
    const whatsappInput = container.querySelector('[name="whatsapp"]') as HTMLInputElement | null;
    const emailInput = container.querySelector('[name="email"]') as HTMLInputElement | null;
    const businessTypeInput = container.querySelector('[name="business_type"]') as HTMLInputElement | null;
    const messageInput = container.querySelector('[name="message"]') as HTMLTextAreaElement | null;
    
    const budgetInput = container.querySelector('[name="budget"]') as HTMLSelectElement | null;
    const timelineInput = container.querySelector('[name="timeline"]') as HTMLSelectElement | null;
    const referralInput = container.querySelector('[name="referral"]') as HTMLSelectElement | null;

    const validators = {
      name: (val: string) => val.trim().length >= 2,
      whatsapp: (val: string) => /^[+]?[0-9\s\-()]{8,}$/.test(val.trim()),
      email: (val: string) => val.trim() === '' || /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val.trim()),
      business_type: (val: string) => val.trim().length >= 2,
      message: (val: string) => val.trim().length >= 15,
    };

    const getErrorNode = (nameAttr: string) => container.querySelector(`[data-error-for="${nameAttr}"]`);

    const validateField = (field: HTMLElement | null, validator: (val: string) => boolean) => {
      if (!field) return true;
      const nameAttr = field.getAttribute('name') || '';
      const errorNode = getErrorNode(nameAttr);
      const val = (field as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement).value || '';
      const isValid = validator(val);

      field.classList.toggle('border-rose-400', !isValid);
      field.classList.toggle('focus:ring-[rgba(190,24,93,0.12)]', !isValid);
      
      field.classList.toggle('border-emerald-500', isValid && val.trim().length > 0);
      field.classList.toggle('bg-emerald-50/20', isValid && val.trim().length > 0 && field.tagName !== 'SELECT');

      if (errorNode) {
        errorNode.classList.toggle('hidden', isValid);
      }
      return isValid;
    };

    // Setup live validation
    const setupLiveValidation = (input: HTMLElement | null, validatorKey: keyof typeof validators) => {
      if (!input) return;
      const validator = validators[validatorKey];
      input.addEventListener('input', () => validateField(input, validator));
      input.addEventListener('blur', () => validateField(input, validator));
    };

    setupLiveValidation(nameInput, 'name');
    setupLiveValidation(whatsappInput, 'whatsapp');
    setupLiveValidation(emailInput, 'email');
    setupLiveValidation(businessTypeInput, 'business_type');
    setupLiveValidation(messageInput, 'message');

    // URL Prefill Handling
    const urlParams = new URLSearchParams(window.location.search);
    const prefillService = urlParams.get('service') || urlParams.get('interest') || urlParams.get('package');
    const ref = urlParams.get('ref');

    if (prefillService) {
      const serviceCheckbox = Array.from(container.querySelectorAll('input[name="services"]'))
        .find((cb) => (cb as HTMLInputElement).value.toLowerCase() === prefillService.toLowerCase());
      if (serviceCheckbox instanceof HTMLInputElement) {
        serviceCheckbox.checked = true;
      }
    }

    if (ref && messageInput && !messageInput.value) {
      messageInput.value = `Lead source: ${ref}\n`;
    }

    // Form submission
    if (form instanceof HTMLFormElement) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        // Spam bot detection
        if (honeypot && honeypot.value) {
          return;
        }

        // Validate all required fields
        const isNameValid = validateField(nameInput, validators.name);
        const isWhatsappValid = validateField(whatsappInput, validators.whatsapp);
        const isEmailValid = validateField(emailInput, validators.email);
        const isBizValid = validateField(businessTypeInput, validators.business_type);
        const isMessageValid = validateField(messageInput, validators.message);

        if (!isNameValid || !isWhatsappValid || !isEmailValid || !isBizValid || !isMessageValid) {
          // Scroll first invalid field into view
          const firstInvalid = container.querySelector('.border-rose-400');
          if (firstInvalid) {
            firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
          return;
        }

        const submitBtn = container.querySelector('.submit-btn');
        if (!(submitBtn instanceof HTMLButtonElement)) return;

        submitBtn.disabled = true;
        const btnLabel = submitBtn.querySelector('span');
        const originalText = btnLabel?.textContent || 'Submit Project Details';
        if (btnLabel) btnLabel.textContent = 'Sending...';

        const selectedServices = Array.from(container.querySelectorAll('input[name="services"]:checked'))
          .map(cb => (cb as HTMLInputElement).value)
          .join(', ');

        const payload = {
          name: nameInput?.value || '',
          whatsapp: whatsappInput?.value || '',
          email: emailInput?.value || '',
          business_type: businessTypeInput?.value || '',
          service: selectedServices,
          budget: budgetInput?.value || '',
          message: messageInput?.value || '',
          timeline: timelineInput?.value || '',
          referral: referralInput?.value || '',
          page_url: window.location.pathname + window.location.search,
          created_at: new Date().toISOString(),
        };

        try {
          const { supabase } = await import('../lib/supabase');
          const { error } = await supabase.from('contact_submissions').insert([payload]);
          if (error) throw error;

          // Prepare dynamic personalized WhatsApp prefill text
          if (successWhatsappBtn) {
            const name = payload.name;
            const biz = payload.business_type;
            const msgBrief = payload.message.length > 60 ? payload.message.substring(0, 57) + '...' : payload.message;
            const whatsappText = `Hi Haider, my name is ${name} from ${biz}. I just submitted a project brief on smesh.dev regarding: "${msgBrief}".`;
            successWhatsappBtn.href = `https://wa.me/923332029707?text=${encodeURIComponent(whatsappText)}`;
          }

          if (formInteractiveContainer) formInteractiveContainer.classList.add('hidden');
          if (successContainer) successContainer.classList.remove('hidden');
          if (errorAlert) errorAlert.classList.add('hidden');
          
          // Re-initialize Lucide check icon
          if ((window as any).lucide) {
            (window as any).lucide.createIcons();
          }
        } catch (err) {
          console.error('Supabase submission failed:', err);
          if (errorAlert) errorAlert.classList.remove('hidden');
        } finally {
          submitBtn.disabled = false;
          if (btnLabel) btnLabel.textContent = originalText;
        }
      });
    }
  });
</script>
