---
import { site } from '../data/site';

interface Props {
  type?: 'home' | 'service' | 'other';
  title?: string;
  description?: string;
}

const { type = 'other', title, description = site.description } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, site.url).href;

// 2026 SEO/AEO-aligned Schema linking Haider Ali and BismillahTC Digital Services
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "BismillahTC Digital Services",
  "alternateName": "Smesh.Dev",
  "url": `${site.url}/`,
  "logo": `${site.url}/assets/logo.png`,
  "description": site.description,
  "knowsAbout": [
    "n8n automation",
    "Supabase",
    "Vibe Coding",
    "web development",
    "PostgreSQL",
    "Astro",
    "Next.js",
    "AI Support Chatbots",
    "Workflow Automation"
  ],
  "founder": {
    "@type": "Person",
    "name": "Haider Ali",
    "jobTitle": "Principal Developer & Automation Engineer",
    "image": `${site.url}/assets/images/resources/author-haider-ali.webp`,
    "knowsAbout": [
      "n8n automation",
      "Supabase",
      "Vibe Coding",
      "web development",
      "AI agent orchestration"
    ],
    "sameAs": [
      "https://github.com/affaan-m"
    ]
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+923422222752",
    "contactType": "sales",
    "email": "ali.kwl@live.com",
    "areaServed": ["Pakistan", "Worldwide"]
  }
};

// Base ProfessionalService Schema for Local Business indexing
const localServiceSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Smesh.Dev",
  "parentOrganization": "BismillahTC",
  "founder": "Faisal Amin",
  "knowsAbout": ["n8n", "AI Agents"],
  "url": `${site.url}/`,
  "logo": `${site.url}/assets/logo.png`,
  "description": site.description,
  "telephone": "+923422222752",
  "email": "ali.kwl@live.com",
  "address": { 
    "@type": "PostalAddress", 
    "addressCountry": "PK",
    "addressRegion": "KPK",
    "addressLocality": "Kohat"
  },
  "areaServed": ["Pakistan", "Worldwide"],
  "serviceType": [
    "WhatsApp Automation",
    "AI Support Chatbots",
    "Business Websites",
    "Workflow & n8n Automation",
    "Appointment Booking Systems",
    "SaaS & MVP Development",
    "Dashboards & Internal Tools",
    "POS & Inventory Systems",
    "Social Media & Lead Automation",
    "SEO, AIO & GEO Setup"
  ]
};

// Service Schema
const serviceSchema = type === 'service' ? {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": title,
  "provider": {
    "@type": "ProfessionalService",
    "name": "Smesh.Dev",
    "url": `${site.url}/`
  },
  "areaServed": ["Pakistan", "Worldwide"],
  "serviceType": title,
  "description": description
} : null;

// Breadcrumb List Schema
const pathname = Astro.url.pathname;
const paths = pathname.split('/').filter(Boolean);

const itemListElement = [
  {
    "@type": "ListItem",
    "position": 1,
    "name": "Home",
    "item": `${site.url}/`
  }
];

if (paths.length === 1) {
  itemListElement.push({
    "@type": "ListItem",
    "position": 2,
    "name": title || paths[0].charAt(0).toUpperCase() + paths[0].slice(1),
    "item": canonicalURL
  });
} else if (paths.length > 1) {
  const parentName = paths[0].charAt(0).toUpperCase() + paths[0].slice(1);
  const parentURL = `${site.url}/${paths[0]}/`;
  
  itemListElement.push({
    "@type": "ListItem",
    "position": 2,
    "name": parentName,
    "item": parentURL
  });
  
  itemListElement.push({
    "@type": "ListItem",
    "position": 3,
    "name": title || paths[1].replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()),
    "item": canonicalURL
  });
}

const breadcrumbsSchema = pathname !== '/' ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": itemListElement
} : null;
---

<script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(localServiceSchema)} />
{serviceSchema && <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />}
{breadcrumbsSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbsSchema)} />}
