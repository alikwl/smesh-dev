---
import { site } from '../data/site';

interface Props {
  type?: 'home' | 'service' | 'other';
  title?: string;
  description?: string;
}

const { type = 'other', title, description = site.description } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, site.url).href;

// 2026 SEO/AEO-aligned Schema linking Haider Ali and BismillahTC Digital Services
const founderPerson = {
  "@type": "Person",
  "name": "Haider Ali",
  "jobTitle": "Principal Developer & Automation Engineer",
  "image": `${site.url}/assets/images/resources/author-haider-ali.webp`,
  "knowsAbout": [
    "n8n automation",
    "Supabase",
    "Vibe Coding",
    "web development",
    "AI agent orchestration"
  ],
  "sameAs": [
    "https://github.com/alikwl",
    "https://wa.me/923422222752"
  ]
};

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${site.url}/#organization`,
  "name": "BismillahTC Digital Services",
  "legalName": "BismillahTC Digital Services",
  "alternateName": "Smesh.Dev",
  "url": `${site.url}/`,
  "logo": `${site.url}/assets/logo.png`,
  "image": `${site.url}/assets/images/og-preview.png`,
  "description": site.description,
  "email": "ali.kwl@live.com",
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "PK",
    "addressRegion": "Punjab",
    "addressLocality": "Khanewal",
    "postalCode": "58150",
    "streetAddress": "Khanewal, Pakistan"
  },
  "knowsAbout": [
    "n8n automation",
    "Supabase",
    "Vibe Coding",
    "web development",
    "PostgreSQL",
    "Astro",
    "Next.js",
    "AI Support Chatbots",
    "Workflow Automation"
  ],
  "founder": founderPerson,
  "sameAs": [
    "https://github.com/alikwl",
    "https://wa.me/923422222752",
    "https://www.linkedin.com/company/bismillahtc"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+923422222752",
    "contactType": "sales",
    "email": "ali.kwl@live.com",
    "areaServed": ["Worldwide"]
  },
  "areaServed": ["Worldwide"]
};

// Base ProfessionalService Schema for Local Business indexing
const localServiceSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": `${site.url}/#localservice`,
  "name": "Smesh.Dev",
  "parentOrganization": "BismillahTC Digital Services",
  "founder": founderPerson,
  "knowsAbout": ["n8n", "AI Agents", "Supabase", "PostgreSQL", "Workflow Automation"],
  "url": `${site.url}/`,
  "logo": `${site.url}/assets/logo.png`,
  "image": `${site.url}/assets/images/og-preview.png`,
  "description": site.description,
  "telephone": "+923422222752",
  "email": "ali.kwl@live.com",
  "priceRange": "$$",
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday"
    ],
    "opens": "09:00",
    "closes": "18:00"
  },
  "address": { 
    "@type": "PostalAddress", 
    "addressCountry": "PK",
    "addressRegion": "Punjab",
    "addressLocality": "Khanewal",
    "postalCode": "58150",
    "streetAddress": "Khanewal, Pakistan"
  },
  "areaServed": ["Worldwide"],
  "serviceType": [
    "WhatsApp Automation",
    "AI Support Chatbots",
    "Business Websites",
    "Workflow & n8n Automation",
    "Appointment Booking Systems",
    "SaaS & MVP Development",
    "Dashboards & Internal Tools",
    "POS & Inventory Systems",
    "Social Media & Lead Automation",
    "SEO, AIO & GEO Setup"
  ]
};

// Service Schema
const serviceSchema = type === 'service' ? {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": title,
  "logo": `${site.url}/assets/logo.png`,
  "image": `${site.url}/assets/images/og-preview.png`,
  "provider": {
    "@type": "ProfessionalService",
    "name": "Smesh.Dev",
    "url": `${site.url}/`
  },
  "areaServed": ["Worldwide"],
  "serviceType": title,
  "description": description
} : null;

// Breadcrumb List Schema
const pathname = Astro.url.pathname;
const paths = pathname.split('/').filter(Boolean);

const itemListElement = [
  {
    "@type": "ListItem",
    "position": 1,
    "name": "Home",
    "item": `${site.url}/`
  }
];

if (paths.length === 1) {
  itemListElement.push({
    "@type": "ListItem",
    "position": 2,
    "name": title || paths[0].charAt(0).toUpperCase() + paths[0].slice(1),
    "item": canonicalURL
  });
} else if (paths.length > 1) {
  const parentName = paths[0].charAt(0).toUpperCase() + paths[0].slice(1);
  const parentURL = `${site.url}/${paths[0]}/`;
  
  itemListElement.push({
    "@type": "ListItem",
    "position": 2,
    "name": parentName,
    "item": parentURL
  });
  
  itemListElement.push({
    "@type": "ListItem",
    "position": 3,
    "name": title || paths[1].replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()),
    "item": canonicalURL
  });
}

const breadcrumbsSchema = pathname !== '/' ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": itemListElement
} : null;

// Global WebPage Speakable Schema for voice / AI summary assistants
const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${canonicalURL}#webpage`,
  "url": canonicalURL,
  "name": title || site.title,
  "description": description,
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": [".display-title", ".body-copy", ".section-title", "h1", "p"]
  },
  "isPartOf": {
    "@type": "WebSite",
    "@id": `${site.url}/#website`,
    "name": site.title,
    "url": `${site.url}/`
  }
};
---

<script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(localServiceSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
{serviceSchema && <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />}
{breadcrumbsSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbsSchema)} />}

