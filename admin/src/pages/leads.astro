---
import AdminLayout from '../layouts/AdminLayout.astro';
---

<AdminLayout title="Leads & Submissions" activeSection="leads">
  <div class="space-y-6 font-sans pb-12 relative">
    
    <!-- Top Header & Export Action -->
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-xl font-bold text-slate-900 tracking-tight">Leads & Submissions</h1>
        <p class="text-xs text-slate-500 font-light mt-1">Review contact inquiries and gated resource downloads.</p>
      </div>
      
      <!-- Export CSV Button -->
      <button 
        id="export-csv-btn"
        class="inline-flex h-10 px-5 items-center justify-center rounded-xl bg-slate-900 hover:bg-slate-800 text-white text-xs font-bold transition shadow-sm cursor-pointer gap-2"
      >
        <i class="ti ti-download"></i>
        Export CSV
      </button>
    </div>

    <!-- Custom Tabs Navigation -->
    <div class="border-b border-slate-200 flex items-center gap-6">
      <button 
        id="tab-btn-leads"
        class="tab-btn active border-b-2 border-[#1D9E75] text-[#1D9E75] pb-3 text-xs font-bold transition cursor-pointer"
      >
        Resource Leads
      </button>
      <button 
        id="tab-btn-contacts"
        class="tab-btn border-b-2 border-transparent text-slate-450 hover:text-slate-900 pb-3 text-xs font-bold transition cursor-pointer"
      >
        Contact Submissions
      </button>
    </div>

    <!-- Container 1: Resource Leads -->
    <div id="container-resource-leads" class="space-y-4">
      <div class="w-full overflow-x-auto rounded-2xl border border-slate-200 bg-white shadow-sm">
        <table class="w-full border-collapse text-left text-xs">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200">
              <th class="px-6 py-3.5 font-bold uppercase tracking-wider text-slate-450 text-[10px] border-b-2 border-emerald-500/20">Email</th>
              <th class="px-6 py-3.5 font-bold uppercase tracking-wider text-slate-450 text-[10px] border-b-2 border-emerald-500/20">Gated Resource</th>
              <th class="px-6 py-3.5 font-bold uppercase tracking-wider text-slate-450 text-[10px] border-b-2 border-emerald-500/20 text-right">Unlocked At</th>
            </tr>
          </thead>
          <tbody id="leads-table-body" class="divide-y divide-slate-100">
            {Array.from({ length: 3 }).map(() => (
              <tr class="animate-pulse">
                <td class="px-6 py-4"><div class="h-3 w-40 bg-slate-100 rounded"></div></td>
                <td class="px-6 py-4"><div class="h-3 w-56 bg-slate-100 rounded"></div></td>
                <td class="px-6 py-4 text-right"><div class="h-3 w-28 bg-slate-100 rounded ml-auto"></div></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Container 2: Contact Submissions -->
    <div id="container-contact-submissions" class="hidden space-y-4">
      <div class="w-full overflow-x-auto rounded-2xl border border-slate-200 bg-white shadow-sm">
        <table class="w-full border-collapse text-left text-xs">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200">
              <th class="px-6 py-3.5 font-bold uppercase tracking-wider text-slate-450 text-[10px] border-b-2 border-emerald-500/20">Name</th>
              <th class="px-6 py-3.5 font-bold uppercase tracking-wider text-slate-450 text-[10px] border-b-2 border-emerald-500/20">WhatsApp</th>
              <th class="px-6 py-3.5 font-bold uppercase tracking-wider text-slate-450 text-[10px] border-b-2 border-emerald-500/20">Budget</th>
              <th class="px-6 py-3.5 font-bold uppercase tracking-wider text-slate-450 text-[10px] border-b-2 border-emerald-500/20">Service Type</th>
              <th class="px-6 py-3.5 font-bold uppercase tracking-wider text-slate-450 text-[10px] border-b-2 border-emerald-500/20">Project Brief</th>
              <th class="px-6 py-3.5 font-bold uppercase tracking-wider text-slate-450 text-[10px] border-b-2 border-emerald-500/20 text-right">Submitted At</th>
            </tr>
          </thead>
          <tbody id="contacts-table-body" class="divide-y divide-slate-100">
            <!-- Populated via script -->
          </tbody>
        </table>
      </div>
    </div>

    <!-- Project Brief Modal (hidden by default) -->
    <div 
      id="brief-modal" 
      class="fixed inset-0 bg-black/40 z-50 items-center justify-center p-4 hidden transition-opacity duration-300 opacity-0"
    >
      <div class="bg-white w-full max-w-lg rounded-2xl p-6 border border-slate-200 shadow-xl space-y-4 transform scale-95 transition-transform duration-300">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-sm font-bold text-slate-900" id="brief-modal-name">Project Brief</h3>
            <p class="text-[10px] text-slate-400 font-medium mt-0.5" id="brief-modal-service"></p>
          </div>
          <button id="brief-modal-close" class="text-slate-400 hover:text-slate-900 transition p-1 cursor-pointer">
            <i class="ti ti-x text-lg"></i>
          </button>
        </div>
        
        <div class="bg-slate-50 border border-slate-150 rounded-xl p-4 text-xs text-slate-700 leading-relaxed font-sans max-h-60 overflow-y-auto whitespace-pre-wrap" id="brief-modal-content">
          <!-- Full text injected here -->
        </div>

        <div class="flex justify-end">
          <button 
            type="button" 
            id="brief-modal-ok"
            class="px-5 py-2 bg-slate-900 hover:bg-slate-800 text-white text-xs font-bold rounded-xl transition cursor-pointer"
          >
            Close
          </button>
        </div>
      </div>
    </div>

  </div>
</AdminLayout>

<script>
  import { supabase, getLeads } from '../lib/supabase';

  document.addEventListener('DOMContentLoaded', async () => {
    
    // Tab switching controls
    const tabLeads = document.getElementById('tab-btn-leads');
    const tabContacts = document.getElementById('tab-btn-contacts');
    const containerLeads = document.getElementById('container-resource-leads');
    const containerContacts = document.getElementById('container-contact-submissions');

    const leadsBody = document.getElementById('leads-table-body');
    const contactsBody = document.getElementById('contacts-table-body');

    // Modal controls
    const modal = document.getElementById('brief-modal');
    const modalName = document.getElementById('brief-modal-name');
    const modalService = document.getElementById('brief-modal-service');
    const modalContent = document.getElementById('brief-modal-content');
    const modalClose = document.getElementById('brief-modal-close');
    const modalOk = document.getElementById('brief-modal-ok');

    // Export button
    const exportBtn = document.getElementById('export-csv-btn');

    let leadsData: any[] = [];
    let contactsData: any[] = [];
    let activeTab: 'leads' | 'contacts' = 'leads';

    // 1. Tab toggle listeners
    tabLeads?.addEventListener('click', () => {
      activeTab = 'leads';
      
      tabLeads.classList.add('active', 'border-[#1D9E75]', 'text-[#1D9E75]');
      tabLeads.classList.remove('border-transparent', 'text-slate-450');
      
      tabContacts?.classList.remove('active', 'border-[#1D9E75]', 'text-[#1D9E75]');
      tabContacts?.classList.add('border-transparent', 'text-slate-450');

      containerLeads?.classList.remove('hidden');
      containerContacts?.classList.add('hidden');
    });

    tabContacts?.addEventListener('click', () => {
      activeTab = 'contacts';

      tabContacts.classList.add('active', 'border-[#1D9E75]', 'text-[#1D9E75]');
      tabContacts.classList.remove('border-transparent', 'text-slate-450');
      
      tabLeads?.classList.remove('active', 'border-[#1D9E75]', 'text-[#1D9E75]');
      tabLeads?.classList.add('border-transparent', 'text-slate-450');

      containerContacts?.classList.remove('hidden');
      containerLeads?.classList.add('hidden');
    });

    // 2. Fetch all leads data client-side
    const loadLeadsData = async () => {
      if (!leadsBody || !contactsBody) return;

      const { data: resources } = await supabase.from('resources').select('slug, title');
      const resourceMap: Record<string, string> = {};
      (resources || []).forEach(r => {
        resourceMap[r.slug] = r.title;
      });

      const { leads, contacts } = await getLeads();

      leadsData = leads || [];
      contactsData = contacts || [];

      // Render Resource Leads
      if (leadsData.length === 0) {
        leadsBody.innerHTML = `
          <tr>
            <td colspan="3" class="px-6 py-12 text-center text-slate-400">No resource leads captured yet.</td>
          </tr>
        `;
      } else {
        leadsBody.innerHTML = leadsData.map(l => {
          const date = l.unlocked_at 
            ? new Date(l.unlocked_at).toLocaleString() 
            : 'N/A';
          const title = resourceMap[l.slug] || l.slug;
          return `
            <tr class="hover:bg-slate-50/70 transition-colors">
              <td class="px-6 py-4 text-slate-900 font-bold select-text">${l.email}</td>
              <td class="px-6 py-4 text-slate-655 font-medium">${title}</td>
              <td class="px-6 py-4 text-right text-slate-450">${date}</td>
            </tr>
          `;
        }).join('');
      }

      // Render Contact Submissions
      if (contactsData.length === 0) {
        contactsBody.innerHTML = `
          <tr>
            <td colspan="6" class="px-6 py-12 text-center text-slate-400">No contact submissions captured yet.</td>
          </tr>
        `;
      } else {
        contactsBody.innerHTML = contactsData.map(c => {
          const date = c.submitted_at 
            ? new Date(c.submitted_at).toLocaleString() 
            : 'N/A';
          
          const briefText = c.brief || '';
          const truncatedBrief = briefText.length > 50 
            ? briefText.substring(0, 47) + '...' 
            : briefText;
          
          const briefHtml = briefText 
            ? `<button data-action="view-brief" data-name="${c.name || 'Inquiry'}" data-service="${c.service || ''}" class="text-[#1D9E75] hover:text-[#0F6E56] font-bold hover:underline transition cursor-pointer text-left">${truncatedBrief}</button>`
            : `<span class="text-slate-350 italic">None</span>`;

          return `
            <tr class="hover:bg-slate-50/70 transition-colors">
              <td class="px-6 py-4 text-slate-900 font-bold select-text">${c.name || 'Anonymous'}</td>
              <td class="px-6 py-4 text-slate-600 font-mono select-text">${c.whatsapp || 'N/A'}</td>
              <td class="px-6 py-4 text-slate-655 font-semibold">${c.budget || 'N/A'}</td>
              <td class="px-6 py-4 text-slate-500 font-medium">${c.service || 'N/A'}</td>
              <td class="px-6 py-4">${briefHtml}</td>
              <td class="px-6 py-4 text-right text-slate-450">${date}</td>
            </tr>
          `;
        }).join('');
      }
    };

    // 3. Delegate brief expand modal clicks
    contactsBody?.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.getAttribute('data-action') === 'view-brief') {
        const name = target.getAttribute('data-name') || 'Inquiry';
        const service = target.getAttribute('data-service') || 'General';
        
        // Find match in contacts array
        const match = contactsData.find(c => c.name === name && c.service === service);
        const fullBrief = match ? match.brief : 'Brief details missing.';

        if (modal && modalName && modalService && modalContent) {
          modalName.textContent = `Client Brief: ${name}`;
          modalService.textContent = `Service Category: ${service}`;
          modalContent.textContent = fullBrief;

          // Open Modal
          modal.classList.remove('hidden');
          modal.classList.add('flex');
          setTimeout(() => {
            modal.classList.remove('opacity-0');
            modal.querySelector('.bg-white')?.classList.remove('scale-95');
          }, 10);
        }
      }
    });

    // Close Modal helper
    const closeModal = () => {
      if (!modal) return;
      modal.classList.add('opacity-0');
      modal.querySelector('.bg-white')?.classList.add('scale-95');
      setTimeout(() => {
        modal.classList.remove('flex');
        modal.classList.add('hidden');
      }, 300);
    };

    modalClose?.addEventListener('click', closeModal);
    modalOk?.addEventListener('click', closeModal);

    // 4. CSV Export Downloader
    exportBtn?.addEventListener('click', () => {
      let csvContent = "";
      let filename = "";

      if (activeTab === 'leads') {
        csvContent = "Email,Resource Slug,Unlocked At\n" + 
          leadsData.map(l => `"${l.email}","${l.slug}","${l.unlocked_at}"`).join("\n");
        filename = "resource_leads_export.csv";
      } else {
        csvContent = "Name,WhatsApp,Budget,Service,Submitted At,Brief\n" + 
          contactsData.map(c => {
            // Escape quotes inside fields
            const cleanBrief = (c.brief || '').replace(/"/g, '""');
            return `"${c.name || ''}","${c.whatsapp || ''}","${c.budget || ''}","${c.service || ''}","${c.submitted_at}","${cleanBrief}"`;
          }).join("\n");
        filename = "contact_submissions_export.csv";
      }

      // Trigger browser file download
      const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.setAttribute("href", url);
      link.setAttribute("download", filename);
      link.style.visibility = 'hidden';
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    });

    // Initial load
    await loadLeadsData();
  });
</script>
