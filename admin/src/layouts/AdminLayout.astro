---
import AuthGuard from '../components/AuthGuard.astro';

interface Props {
  title: string;
  activeSection: string;
}

const { title, activeSection } = Astro.props;

const navLinks = [
  { section: 'dashboard', name: 'Dashboard', href: '/dashboard', icon: 'ti-layout-dashboard' },
  { section: 'blog', name: 'Blog Posts', href: '/blog', icon: 'ti-article' },
  { section: 'resources', name: 'Resources', href: '/resources', icon: 'ti-file-text' },
  { section: 'portfolio', name: 'Portfolio', href: '/portfolio', icon: 'ti-briefcase' },
  { section: 'leads', name: 'Leads', href: '/leads', icon: 'ti-users' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Admin Dashboard</title>
  <!-- Load both Tabler and Themify CDNs for maximum icon support -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@themify/themify-icons@1.0.1/css/themify-icons.css" />
</head>
<body class="bg-slate-50 text-slate-800 font-sans min-h-screen">
  
  <!-- Auth Guard checks session on load -->
  <AuthGuard />

  <div class="flex min-h-screen relative overflow-x-hidden">
    
    <!-- Left Sidebar (Desktop fixed, Mobile overlay toggle) -->
    <aside 
      id="sidebar" 
      class="w-60 bg-[#0f1117] text-slate-300 flex flex-col justify-between p-6 shrink-0 fixed inset-y-0 left-0 z-50 transform -translate-x-full md:translate-x-0 transition-transform duration-300 ease-in-out border-r border-slate-900 shadow-xl"
    >
      <div class="space-y-8">
        
        <!-- Sidebar Brand Header -->
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="font-display font-extrabold text-lg text-white tracking-tight">smesh<span class="text-[#1D9E75]">.dev</span></span>
            <span class="text-[9px] font-bold text-emerald-350 bg-emerald-950/60 border border-emerald-900/50 px-2 py-0.5 rounded select-none">Admin</span>
          </div>
          <!-- Close button on Mobile -->
          <button id="sidebar-close-btn" class="md:hidden text-slate-400 hover:text-white transition cursor-pointer">
            <i class="ti ti-x text-lg"></i>
          </button>
        </div>

        <!-- Navigation Links -->
        <nav class="space-y-1">
          {navLinks.map((link) => {
            const isActive = activeSection === link.section;
            return (
              <a 
                href={link.href} 
                class={`flex items-center gap-3 px-3.5 py-3 rounded-xl text-xs font-semibold tracking-wide transition-all group ${
                  isActive 
                    ? 'bg-slate-800/80 text-white border-l-4 border-[#1D9E75] pl-2.5' 
                    : 'hover:bg-slate-800/40 hover:text-white border-l-4 border-transparent'
                }`}
              >
                <!-- Try to render with Tabler icon styling first, falls back to Themify -->
                <i class={`ti ${link.icon} text-sm group-hover:scale-105 transition-transform ${isActive ? 'text-[#1D9E75]' : 'text-slate-450'}`}></i>
                <span>{link.name}</span>
              </a>
            );
          })}
        </nav>
      </div>

      <!-- Sidebar Footer -->
      <div class="space-y-5 pt-6 border-t border-slate-900">
        
        <!-- Trigger Deploy Button -->
        <button 
          id="deploy-btn" 
          class="w-full py-3 bg-[#1D9E75] hover:bg-[#0F6E56] text-white font-bold rounded-xl text-xs transition flex items-center justify-center gap-2 cursor-pointer shadow-md select-none"
        >
          <span id="deploy-text">🚀 Deploy Site</span>
          <!-- Loading spinner -->
          <svg id="deploy-spinner" class="hidden animate-spin h-3.5 w-3.5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </button>

        <!-- Sign Out Link -->
        <div class="text-center">
          <button 
            id="signout-btn" 
            class="text-[11px] text-slate-450 hover:text-rose-455 transition cursor-pointer font-medium tracking-wide"
          >
            Sign Out &rarr;
          </button>
        </div>
      </div>
    </aside>

    <!-- Overlay under mobile sidebar -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-black/40 z-40 hidden md:hidden transition-opacity"></div>

    <!-- Main Content Area -->
    <div class="flex-grow flex flex-col md:pl-60 min-h-screen">
      
      <!-- Top Mobile Navbar -->
      <header class="bg-white border-b border-slate-200/60 h-16 flex items-center justify-between px-6 sticky top-0 z-30 shadow-xs md:shadow-none">
        <div class="flex items-center gap-3">
          <button id="sidebar-toggle-btn" class="md:hidden text-slate-600 hover:text-slate-900 transition cursor-pointer p-1.5 rounded-lg hover:bg-slate-100">
            <i class="ti ti-menu-2 text-xl"></i>
          </button>
          <h2 class="text-sm font-bold text-slate-900 tracking-tight capitalize">{title}</h2>
        </div>
        
        <!-- Live Link Indicator -->
        <a href="https://smesh.dev" target="_blank" class="text-[10px] font-bold text-[#1D9E75] hover:text-[#0F6E56] transition flex items-center gap-1 font-mono uppercase bg-emerald-50 px-2.5 py-1 rounded border border-emerald-100">
          Live Site <i class="ti ti-external-link text-[10px]"></i>
        </a>
      </header>

      <!-- Main Slot Content -->
      <main class="flex-grow p-6 md:p-8">
        <slot />
      </main>

    </div>
  </div>

  <script>
    import { signOut, triggerDeploy } from '../lib/supabase';

    document.addEventListener('DOMContentLoaded', () => {
      // 1. Sidebar Toggle handlers for Mobile
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('sidebar-overlay');
      const openBtn = document.getElementById('sidebar-toggle-btn');
      const closeBtn = document.getElementById('sidebar-close-btn');

      const toggleSidebar = (isOpen: boolean) => {
        if (!sidebar || !overlay) return;
        if (isOpen) {
          sidebar.classList.remove('-translate-x-full');
          overlay.classList.remove('hidden');
        } else {
          sidebar.classList.add('-translate-x-full');
          overlay.classList.add('hidden');
        }
      };

      openBtn?.addEventListener('click', () => toggleSidebar(true));
      closeBtn?.addEventListener('click', () => toggleSidebar(false));
      overlay?.addEventListener('click', () => toggleSidebar(false));

      // 2. Sign Out Handler
      const signoutBtn = document.getElementById('signout-btn');
      signoutBtn?.addEventListener('click', async () => {
        if (confirm('Are you sure you want to sign out?')) {
          await signOut();
        }
      });

      // 3. Deploy Handler
      const deployBtn = document.getElementById('deploy-btn') as HTMLButtonElement | null;
      const deployText = document.getElementById('deploy-text');
      const deploySpinner = document.getElementById('deploy-spinner');

      deployBtn?.addEventListener('click', async () => {
        if (!deployBtn || !deployText || !deploySpinner) return;

        // Loading state
        deployBtn.disabled = true;
        deployText.textContent = 'Deploying...';
        deploySpinner.classList.remove('hidden');
        deployBtn.classList.remove('bg-[#1D9E75]', 'hover:bg-[#0F6E56]');
        deployBtn.classList.add('bg-slate-700');

        try {
          const success = await triggerDeploy();
          if (success) {
            // Success Feedback
            deployText.textContent = '✓ Build triggered!';
            deploySpinner.classList.add('hidden');
            deployBtn.classList.remove('bg-slate-700');
            deployBtn.classList.add('bg-emerald-600');

            setTimeout(() => {
              // Revert back
              deployBtn.disabled = false;
              deployText.textContent = '🚀 Deploy Site';
              deployBtn.classList.remove('bg-emerald-600');
              deployBtn.classList.add('bg-[#1D9E75]', 'hover:bg-[#0F6E56]');
            }, 3000);
          } else {
            throw new Error('Deploy request failed');
          }
        } catch (e) {
          console.error(e);
          // Error Feedback
          deployText.textContent = 'Failed. Try again';
          deploySpinner.classList.add('hidden');
          deployBtn.classList.remove('bg-slate-700');
          deployBtn.classList.add('bg-rose-600');

          setTimeout(() => {
            deployBtn.disabled = false;
            deployText.textContent = '🚀 Deploy Site';
            deployBtn.classList.remove('bg-rose-600');
            deployBtn.classList.add('bg-[#1D9E75]', 'hover:bg-[#0F6E56]');
          }, 3000);
        }
      });
    });
  </script>
</body>
</html>
