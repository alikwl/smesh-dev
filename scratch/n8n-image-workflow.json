    },
    "Supabase - Upload Image": {
      "main": [
        [
          {
            "node": "Supabase - Save Metadata",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Error Trigger": {
      "main": [
        [
          {
            "node": "Slack Error Alert",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "versionId": "df1ce4bd-c90a-4c28-be8e-1dcfe23e9a9a",
