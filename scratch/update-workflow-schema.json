{
  "name": "update_workflow",
  "description": "Apply a small list of operations to an existing workflow (see the operations input schema for the supported op types). The whole batch is atomic: if any op fails the workflow is left unchanged.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "workflowId": {
        "type": "string",
        "description": "The ID of the workflow to update."
      },
      "operations": {
        "type": "array",
        "items": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "updateNodeParameters"
                },
                "nodeName": {
                  "type": "string",
                  "description": "Name of the existing node to update."
                },
                "parameters": {
                  "type": "object",
                  "additionalProperties": {},
                  "description": "Parameter object to merge into (or replace) the node parameters."
                },
                "replace": {
                  "type": "boolean",
                  "description": "If true, replace the node parameters entirely with `parameters`. If false or omitted, deep-merge `parameters` into the existing parameters."
                }
              },
              "required": [
                "type",
                "nodeName",
                "parameters"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "setNodeParameter"
                },
                "nodeName": {
                  "type": "string",
                  "description": "Name of the existing node to update."
                },
                "path": {
                  "type": "string",
                  "minLength": 2,
                  "description": "JSON Pointer (RFC 6901) path to the parameter to set, e.g. \"/jsonSchema\" or \"/options/systemMessage\". Must start with \"/\". Intermediate objects are created on demand. Array indices are NOT supported — to change a value inside an array, set the whole array. Use this instead of `updateNodeParameters` when you only need to set one nested key — the payload stays small regardless of the rest of the parameters object."
                },
                "value": {
                  "description": "Value to set at the path. Any defined JSON value."
                }
              },
              "required": [
                "type",
                "nodeName",
                "path",
                "value"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "addNode"
                },
                "node": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "Unique node name. Must not collide with an existing node."
                    },
                    "type": {
                      "type": "string",
                      "description": "Fully qualified node type, e.g. \"n8n-nodes-base.set\"."
                    },
                    "typeVersion": {
                      "type": "number"
                    },
                    "parameters": {
                      "type": "object",
                      "additionalProperties": {}
                    },
                    "position": {
                      "type": "array",
                      "items": {
                        "type": "number"
                      },
                      "minItems": 2,
                      "maxItems": 2,
                      "description": "Canvas position as [x, y]"
                    },
                    "credentials": {
                      "type": "object",
                      "additionalProperties": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "name": {
                            "type": "string"
                          }
                        },
                        "required": [
                          "name"
                        ],
                        "additionalProperties": false
                      }
                    },
                    "disabled": {
                      "type": "boolean"
                    },
                    "notes": {
                      "type": "string"
                    },
                    "id": {
                      "type": "string",
                      "description": "Optional node id. Generated if omitted."
                    }
                  },
                  "required": [
                    "name",
                    "type",
                    "typeVersion"
                  ],
                  "additionalProperties": false,
                  "description": "The node to add to the workflow."
                }
              },
              "required": [
                "type",
                "node"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "removeNode"
                },
                "nodeName": {
                  "type": "string",
                  "description": "Name of the node to remove. All inbound and outbound connections are removed, including any sub-node attachments (LLM models, memory, tools) — the sub-nodes themselves remain in the workflow but become disconnected and will not be re-attached automatically. To modify a node, use updateNodeParameters or setNodeParameter instead."
                }
              },
              "required": [
                "type",
                "nodeName"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "renameNode"
                },
                "oldName": {
                  "type": "string"
                },
                "newName": {
                  "type": "string",
                  "description": "New unique node name."
                }
              },
              "required": [
                "type",
                "oldName",
                "newName"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "addConnection"
                },
                "source": {
                  "type": "string",
                  "description": "Name of the source node."
                },
                "target": {
                  "type": "string",
                  "description": "Name of the target node."
                },
                "sourceIndex": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Source output index. Default 0."
                },
                "targetIndex": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Target input index. Default 0."
                },
                "connectionType": {
                  "type": "string",
                  "description": "Connection type, e.g. \"main\" or \"ai_languageModel\". Default \"main\"."
                }
              },
              "required": [
                "type",
                "source",
                "target"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "removeConnection"
                },
                "source": {
                  "type": "string"
                },
                "target": {
                  "type": "string"
                },
                "sourceIndex": {
                  "type": "integer",
                  "minimum": 0
                },
                "targetIndex": {
                  "type": "integer",
                  "minimum": 0
                },
                "connectionType": {
                  "type": "string"
                }
              },
              "required": [
                "type",
                "source",
                "target"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "setNodeCredential"
                },
                "nodeName": {
                  "type": "string"
                },
                "credentialKey": {
                  "type": "string",
                  "description": "Credential key on the node, e.g. \"slackApi\" or \"httpHeaderAuth\"."
                },
                "credentialId": {
                  "type": "string"
                },
                "credentialName": {
                  "type": "string"
                }
              },
              "required": [
                "type",
                "nodeName",
                "credentialKey",
                "credentialId",
                "credentialName"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "setNodePosition"
                },
                "nodeName": {
                  "type": "string"
                },
                "position": {
                  "type": "array",
                  "items": {
                    "type": "number"
                  },
                  "minItems": 2,
                  "maxItems": 2,
                  "description": "Canvas position as [x, y]"
                }
              },
              "required": [
                "type",
                "nodeName",
                "position"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "setNodeDisabled"
                },
                "nodeName": {
                  "type": "string"
                },
                "disabled": {
                  "type": "boolean"
                }
              },
              "required": [
                "type",
                "nodeName",
                "disabled"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "const": "setWorkflowMetadata"
                },
                "name": {
                  "type": "string",
                  "maxLength": 128
                },
                "description": {
                  "type": "string",
                  "maxLength": 255
                }
              },
              "required": [
                "type"
              ],
              "additionalProperties": false
            }
          ]
        },
        "minItems": 1,
        "maxItems": 100,
        "description": "Ordered list of operations to apply (max 100). Operations are applied atomically: if any operation fails (e.g. node not found, duplicate name), the whole batch is rejected and no changes are saved."
      }
    },
    "required": [
      "workflowId",
      "operations"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  },
  "annotations": {
    "title": "Updating workflow",
    "readOnlyHint": false,
    "destructiveHint": true,
    "idempotentHint": false,
    "openWorldHint": false
  },
  "execution": {
    "taskSupport": "forbidden"
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "workflowId": {
        "type": "string"
      },
      "name": {
        "type": "string"
      },
      "nodeCount": {
        "type": "number"
      },
      "url": {
        "type": "string"
      },
      "appliedOperations": {
        "type": "number",
        "description": "Number of operations applied."
      },
      "autoAssignedCredentials": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "nodeName": {
              "type": "string"
            },
            "credentialName": {
              "type": "string"
            },
            "credentialType": {
              "type": "string"
            }
          },
          "required": [
            "nodeName",
            "credentialName",
            "credentialType"
          ],
          "additionalProperties": false
        },
        "description": "Credentials auto-assigned to nodes that were added in this update."
      },
      "validationWarnings": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string"
            },
            "message": {
              "type": "string"
            },
            "nodeName": {
              "type": "string"
            }
          },
          "required": [
            "code",
            "message"
          ],
          "additionalProperties": false
        },
        "description": "Graph and JSON validation warnings on the resulting workflow. Use these to self-correct on the next call."
      },
      "note": {
        "type": "string"
      }
    },
    "required": [
      "workflowId",
      "name",
      "nodeCount",
      "url",
      "appliedOperations",
      "autoAssignedCredentials",
      "validationWarnings"
    ],
    "additionalProperties": false,
    "$schema": "http://json-schema.org/draft-07/schema#"
  }
}